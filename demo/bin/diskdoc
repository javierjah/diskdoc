# ---------- Selector animation ----------
selector_animation() {
  local all_x="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  local all_dot="............................................"
  local only_ml="..x........................................."

  # Frame 1: opens with all selected, cursor on Apple Screensavers
  render_selector 0 "$all_x" "44/44 items — 137.1 GB" detail_apple
  sleep 2.4

  # Frame 2: press N — deselect all
  render_selector 0 "$all_dot" "0/44 items — 0 B" detail_apple
  sleep 1.8

  # Frame 3: navigate down to Claude VM Bundles
  render_selector 1 "$all_dot" "0/44 items — 0 B" detail_claude
  sleep 0.5

  # Frame 4: navigate down to ML Asset: downloadDir
  render_selector 2 "$all_dot" "0/44 items — 0 B" detail_mlasset
  sleep 1.0

  # Frame 5: select it
  render_selector 2 "$only_ml" "1/44 items — 9.1 GB" detail_mlasset
  sleep 2.2

  # Frame 6: confirmation
  clear_screen
  header
  printf "  ${B}Confirm cleanup${R}\n\n"
  printf "  ${GR}✓${R} ML Asset: downloadDir       ${YL}9.1 GB${R}\n"
  printf "    ${D}/System/Library/AssetsV2/.../downloadDir${R}\n\n"
  printf "  Total to remove: ${B}9.1 GB${R}\n\n"
  printf "  Proceed? ${GR}[Y]${R}/n  ${D}▮${R}\n"
  sleep 1.6
}

# ---------- Cleanup ----------
cleanup_animation() {
  clear_screen
  header
  printf "  ${B}Cleaning...${R}\n\n"
  printf "  Removing ML Asset: downloadDir\n"
  printf "  ${D}/System/Library/AssetsV2/.../downloadDir${R}\n\n"

  local width=42 pct
  for pct in 5 14 24 35 47 58 68 78 86 93 98 100; do
    local filled=$((pct * width / 100))
    local empty=$((width - filled))
    local bar="" i
    for ((i=0; i<filled; i++)); do bar+="█"; done
    for ((i=0; i<empty; i++)); do bar+="░"; done
    printf "\r  ${CY}%s${R} %3d%%" "$bar" "$pct"
    sleep 0.15
  done
  printf "\n\n"
  printf "  ${GR}✓${R} Removed ${B}9.1 GB${R} in 3.4s\n\n"
  sleep 0.9
}

# ---------- Before / After ----------
before_after() {
  printf "${B}${CY}═══════════════════════════════════════════════${R}\n"
  printf "                  ${B}Disk recovered${R}\n"
  printf "${B}${CY}═══════════════════════════════════════════════${R}\n\n"
  printf "    Before:  ${YL}236.7 GB${R} free    ${D}of 460.4 GB${R}\n"
  printf "    After:   ${GR}245.8 GB${R} free    ${D}of 460.4 GB${R}\n\n"
  printf "              ${B}${GR}+ 9.1 GB${R} ${D}freed${R}\n\n"
  printf "${B}${CY}═══════════════════════════════════════════════${R}\n\n"
  printf "  ${D}128.0 GB still reclaimable. Run ${R}${CY}diskdoc${R}${D} again anytime.${R}\n\n"
}

# ---------- Main dispatch ----------
case "${1:-}" in
  --scan)
    clear_screen
    header
    scan_animation
    sleep 1.0
    ;;
  "")
    if [[ -f /tmp/.diskdoc-mock-scanned ]]; then
      clear_screen
      header
      printf "  ${D}Using cached scan from a moment ago...${R}\n\n"
      sleep 0.7
    else
      clear_screen
      header
      scan_animation
      sleep 0.8
      touch /tmp/.diskdoc-mock-scanned
    fi
    selector_animation
    cleanup_animation
    before_after
    sleep 1.2
    rm -f /tmp/.diskdoc-mock-scanned
    ;;
  --help|-h)
    header
    printf "  ${B}Usage:${R}\n"
    printf "    diskdoc           Scan + interactive selector + clean\n"
    printf "    diskdoc --scan    Preview only (read-only)\n"
    ;;
  *)
    echo "diskdoc: unknown option: $1"
    exit 1
    ;;
esac
