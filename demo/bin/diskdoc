#!/usr/bin/env bash
# diskdoc-mock — visual replica of diskdoc v3.0.2 output for VHS recording.
# NOT functional. Self-animating frames only.

set -u

# ---------- ANSI ----------
B=$'\e[1m'; D=$'\e[2m'; R=$'\e[0m'
CY=$'\e[36m'; BL=$'\e[34m'; YL=$'\e[33m'
GR=$'\e[32m'; RD=$'\e[31m'; MG=$'\e[35m'; GY=$'\e[90m'

hide_cursor() { printf '\e[?25l'; }
show_cursor() { printf '\e[?25h'; }
clear_screen() { printf '\e[2J\e[H'; }
trap show_cursor EXIT
hide_cursor

# ---------- Header ----------
header() {
  printf "${B}╭─ ${CY}diskdoc v3.0.2${R}${B} ──────────────────────────────────────────╮${R}\n"
  printf "${B}│${R} macOS Disk Cleanup CLI                                    ${B}│${R}\n"
  printf "${B}│${R} Sequoia (15.7)                                            ${B}│${R}\n"
  printf "${B}╰──────────────────────────────────────────────────────────╯${R}\n\n"
  printf "  ${B}Disk:${R}  460.4 GB total  ${D}|${R}  ${GR}236.7 GB free${R} (51%%)  ${D}|${R}  223.7 GB used\n\n\n"
}

# ---------- Box helper ----------
# box "Title" "footer"  (body lines via stdin)
box() {
  local title="$1" footer="$2"
  printf "  ${B}┌ %s ${R}" "$title"
  local i len=${#title}
  # strip ANSI for length calc — title may contain ★
  for ((i=len+3; i<60; i++)); do printf "─"; done
  printf "\n"
  while IFS= read -r line; do
    printf "  ${B}│${R}  %s\n" "$line"
  done
  printf "  ${B}└─── %s${R}\n\n" "$footer"
  sleep 0.18
}

