  printf "${B}│${R} Risk: ${GR}🟢 SAFE${R} — Regenerates without effort                       ${B}│${R}\n"
  printf "${B}│${R} Path: /Library/Application Support/com.apple.idleassetsd        ${B}│${R}\n"
  printf "${B}│${R} Size: ${YL}99.2 GB${R}                                                   ${B}│${R}\n"
  printf "${B}│${R} Category: System                                                ${B}│${R}\n"
  printf "${B}│${R} Last modified: 2026-04-05                                       ${B}│${R}\n"
  printf "${B}╰─────────────────────────────────────────────────────────────────╯${R}\n"
}

