# render_selector cursor_idx marks_string count_label detail_fn
render_selector() {
  local cursor=$1 marks=$2 count_label=$3 detail_fn=$4
  clear_screen
  header
  printf "  ${B}Select items to delete:${R}\n\n\n"

  local i
  for ((i=0; i<21; i++)); do
    local item="${ITEMS[$i]}"
    local name="${item%%|*}"
    local rest="${item#*|}"
    local size="${rest%%|*}"
    rest="${rest#*|}"
    local bar="${rest%%|*}"
    local risk="${rest#*|}"

    local mark="${marks:$i:1}"
    local mark_str
    if [[ "$mark" == "x" ]]; then
      mark_str="${GR}[x]${R}"
    else
      mark_str="${D}[ ]${R}"
    fi

    local risk_colored
    case "$risk" in
      *PERSONAL*) risk_colored="${RD}${risk}${R}" ;;
      *REBUILD*)  risk_colored="${YL}${risk}${R}" ;;
      *)          risk_colored="${GR}${risk}${R}" ;;
    esac

    if [[ $i -eq $cursor ]]; then
      printf "  ${CY}>${R} %s ${B}%s${R} %s ${D}%s${R} %s\n" "$mark_str" "$name" "$size" "$bar" "$risk_colored"
    else
      printf "    %s %s %s ${D}%s${R} %s\n" "$mark_str" "$name" "$size" "$bar" "$risk_colored"
    fi
  done

  printf "    ${D}▼ 23 more below${R}\n\n"
  printf "  ${B}Selected:${R} %s\n" "$count_label"
  printf "  ${D}↑↓ move  ␣ toggle  A all  N none  ⏎ confirm  q quit${R}\n\n"
  $detail_fn
}

