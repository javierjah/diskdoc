# ── Initial disk state ───────────────────────────────────────────────────────
DISK_LINE=$(df -k / | tail -1)
DISK_TOTAL=$(echo "$DISK_LINE" | awk '{print $2}')
DISK_AVAIL_BEFORE=$(echo "$DISK_LINE" | awk '{print $4}')
DISK_USED_BEFORE=$((DISK_TOTAL - DISK_AVAIL_BEFORE))
PCT_FREE_NOW=$((DISK_AVAIL_BEFORE * 100 / DISK_TOTAL))

log "  ${DIM}Disk:${NC}  %s total  |  %s free (%d%%)  |  %s used\n" \
  "$(fmt "$DISK_TOTAL")" "$(fmt "$DISK_AVAIL_BEFORE")" "$PCT_FREE_NOW" "$(fmt "$DISK_USED_BEFORE")"

if [[ "$PROFILE" != "all" ]]; then
  log "  ${DIM}Profile:${NC} ${BOLD}%s${NC}\n" "$PROFILE"
fi

if (( MIN_SIZE_MB != 50 )); then
  log "  ${DIM}Min size:${NC} ${BOLD}%d MB${NC}\n" "$MIN_SIZE_MB"
fi

if [[ ${#EXCLUDES[@]} -gt 0 ]]; then
  log "  ${DIM}Exclusions:${NC} %d paths from ~/.diskdocrc\n" "${#EXCLUDES[@]}"
fi

SCAN_START=$(date +%s)
log "\n"

run_all_scans() {

# ── Code directories (shared by node_modules + Rust scans) ──────────────────
CODE_DIRS=("$HOME/code" "$HOME/projects" "$HOME/dev" "$HOME/src" "$HOME/repos" "$HOME/workspace" "$HOME/work" "$HOME/Developer")

# ════════════════════════════════════════════════════════════════════════════
# ★ HIGHLIGHTED: APFS Snapshots + iOS Backups (top priority items)
# ════════════════════════════════════════════════════════════════════════════

TM_SNAP_COUNT=0
if matches_profile "System"; then
  # ── ★ APFS Time Machine Snapshots ──
  snap_list=$(tmutil listlocalsnapshots / 2>/dev/null | grep "com.apple.TimeMachine" || true)
  if [[ -n "$snap_list" ]]; then
    TM_SNAP_COUNT=$(echo "$snap_list" | wc -l | tr -d ' ')
  fi

  if (( TM_SNAP_COUNT > 0 )); then
    log "\n  ${YELLOW}${BOLD}┌ ★ APFS Snapshots ${NC}${DIM}─────────────────────────────────────${NC}\n"
    log "  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "Time Machine local snapshots" "${TM_SNAP_COUNT} snaps"

    T_NAMES+=("★ TM Snapshots (${TM_SNAP_COUNT})")
    T_PATHS+=("__tmutil__")
    T_SIZES+=("0")
    T_CATS+=("System")
    T_RISKS+=("SAFE")
    T_METHODS+=("tm-thin")

    log "  ${DIM}└─── ${TM_SNAP_COUNT} hourly snapshots eating hidden space${NC}\n"
  else
    log "\n  ${DIM}┌ ★ APFS Snapshots ─────────────────────────────────────${NC}\n"
    log "  ${DIM}└─── no local snapshots${NC}\n"
  fi

  # ── ★ iOS/iPadOS Backups ──
  log "\n  ${YELLOW}${BOLD}┌ ★ iOS/iPadOS Backups ${NC}${DIM}──────────────────────────────────${NC}\n"
  scan_target "★ iOS/iPadOS Backups" "$HOME/Library/Application Support/MobileSync/Backup" "System" "SAFE" "rm"
  ios_found=0; ios_kb=0
  for ((i=0; i<${#T_NAMES[@]}; i++)); do
    [[ "${T_NAMES[$i]}" == "★ iOS"* ]] && ((++ios_found)) && ios_kb=$((ios_kb + T_SIZES[$i]))
  done
  if (( ios_found > 0 )); then
    cat_footer "$ios_found" "$ios_kb"
  else
    log "  ${DIM}└─── nothing found${NC}\n"
  fi
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE 1: System
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "System"; then
  cat_header "System" "$YELLOW"

  NEEDS_SUDO=false
  # idleassetsd and system logs need sudo
  if ! is_excluded "/private/var/folders" || ! is_excluded "/private/var/log"; then
    NEEDS_SUDO=true
  fi

  if [[ "$NEEDS_SUDO" == true ]]; then
    log "  │  ${YELLOW}⚠${NC}  ${DIM}System scan needs admin access. You may be prompted for your password.${NC}\n"
  fi

  scan_target "Trash" "$HOME/.Trash" "System" "SAFE" "rm"

  # Apple Screensavers (idleassetsd) — requires sudo + special path search
  if ! is_excluded "/private/var/folders"; then
    logp "\r\033[K  ${DIM}⠹ Scanning Apple Screensavers (idleassetsd)${NC}"
    IDLE_PATH=$(sudo find /private/var/folders -name "com.apple.idleassetsd" -maxdepth 6 2>/dev/null | head -1)
    if [[ -n "$IDLE_PATH" ]]; then
      idle_kb=$(get_kb_sudo "$IDLE_PATH")
      if (( idle_kb > MIN_SIZE_KB )); then
        _flush_cat_header
        T_NAMES+=("Apple Screensavers (idleassetsd)")
        T_PATHS+=("$IDLE_PATH")
        T_SIZES+=("$idle_kb")
        T_CATS+=("System")
        T_RISKS+=("SAFE")
        T_METHODS+=("rm-sudo")
        FOUND_TOTAL=$((FOUND_TOTAL + idle_kb))
        log "\r\033[K  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "Apple Screensavers (idleassetsd)" "$(fmt "$idle_kb")"
      else
        logp "\r\033[K"
      fi
    else
      logp "\r\033[K"
    fi
  fi

  # Category totals
  sys_count=0; sys_kb=0
  for ((i=0; i<${#T_CATS[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "System" ]] && ((++sys_count)) && sys_kb=$((sys_kb + T_SIZES[$i]))
  done
  cat_footer "$sys_count" "$sys_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE 2: Apple Intelligence / ML Assets
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "System"; then
  cat_header "Apple Intelligence / ML" "$MAGENTA"
  ai_start=${#T_NAMES[@]}

  # Static known paths
  scan_target "Siri Caches"         "$HOME/Library/Caches/com.apple.siri.embeddings" "System" "SAFE" "rm"

  # Dynamic scan: /System/Library/AssetsV2/* > 100 MB
  # SIP-protected on Tahoe — route to Untouchable if is_sip_protected
  if [[ -d "/System/Library/AssetsV2" ]]; then
    while IFS=$'\t' read -r kb path; do
      [[ -z "$kb" || -z "$path" ]] && continue
      kb=$(echo "$kb" | tr -d '[:space:]')
      base=$(basename "$path")
      (( kb > 102400 )) || continue  # > 100 MB
      is_excluded "$path" && continue

      if is_sip_protected "$path"; then
        U_NAMES+=("ML Asset: $base")
        U_PATHS+=("$path")
        U_SIZES+=("$kb")
        U_DESCS+=("Apple Intelligence model. /System/Library/AssetsV2/ is protected by SIP on macOS Tahoe. Apple manages these models automatically. To free space, disable Apple Intelligence in Settings.")
        U_TOTAL=$((U_TOTAL + kb))
      else
        _flush_cat_header
        T_NAMES+=("ML Asset: $base")
        T_PATHS+=("$path")
        T_SIZES+=("$kb")
        T_CATS+=("System")
        T_RISKS+=("SAFE")
        T_METHODS+=("rm-sudo")
        FOUND_TOTAL=$((FOUND_TOTAL + kb))
        log "  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "ML Asset: $base" "$(fmt "$kb")"
      fi
    done < <(sudo du -sk /System/Library/AssetsV2/*/ 2>/dev/null | sort -nr)
  fi

  # Dynamic scan: /private/var/MobileAsset/AssetsV2/* > 100 MB
  if sudo test -d "/private/var/MobileAsset/AssetsV2" 2>/dev/null; then
    while IFS=$'\t' read -r kb path; do
      [[ -z "$kb" || -z "$path" ]] && continue
      kb=$(echo "$kb" | tr -d '[:space:]')
      base=$(basename "$path")
      (( kb > 102400 )) || continue
      is_excluded "$path" && continue

      if is_sip_protected "$path"; then
        U_NAMES+=("Mobile Asset: $base")
        U_PATHS+=("$path")
        U_SIZES+=("$kb")
        U_DESCS+=("Apple Intelligence model under /private/var/MobileAsset/. Protected by SIP. Apple manages these automatically.")
        U_TOTAL=$((U_TOTAL + kb))
      else
        _flush_cat_header
        T_NAMES+=("Mobile Asset: $base")
        T_PATHS+=("$path")
        T_SIZES+=("$kb")
        T_CATS+=("System")
        T_RISKS+=("SAFE")
        T_METHODS+=("rm-sudo")
        FOUND_TOTAL=$((FOUND_TOTAL + kb))
        log "  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "Mobile Asset: $base" "$(fmt "$kb")"
      fi
    done < <(sudo du -sk /private/var/MobileAsset/AssetsV2/*/ 2>/dev/null | sort -nr)
  fi

  # Apple system assets — SIP-protected under /Library/Apple/
  if sudo test -d "/Library/Apple/System/Library/Assets" 2>/dev/null; then
    local _asa_path="/Library/Apple/System/Library/Assets"
    if is_sip_protected "$_asa_path"; then
      local _asa_kb
      _asa_kb=$(sudo du -sk "$_asa_path" 2>/dev/null | awk '{print $1}')
      _asa_kb=${_asa_kb:-0}
      if (( _asa_kb > 0 )); then
        U_NAMES+=("Apple System Assets")
        U_PATHS+=("$_asa_path")
        U_SIZES+=("$_asa_kb")
        U_DESCS+=("System assets managed by Apple. Protected by SIP under /Library/Apple/.")
        U_TOTAL=$((U_TOTAL + _asa_kb))
      fi
    else
      scan_target "Apple System Assets" "$_asa_path" "System" "SAFE" "rm-sudo"
    fi
  fi

  ai_count=0; ai_kb=0
  for ((i=ai_start; i<${#T_NAMES[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "System" ]] && ((++ai_count)) && ai_kb=$((ai_kb + T_SIZES[$i]))
  done
  cat_footer "$ai_count" "$ai_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE 3: Dev Tools
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "Dev Tools"; then
  cat_header "Dev Tools" "$CYAN"
  dev_start=${#T_NAMES[@]}

  # Xcode
  scan_target "Xcode DerivedData"        "$HOME/Library/Developer/Xcode/DerivedData"         "Dev Tools" "SAFE" "rm"
  scan_target "Xcode Archives"           "$HOME/Library/Developer/Xcode/Archives"            "Dev Tools" "SAFE" "rm"
  scan_target "Xcode iOS DeviceSupport"  "$HOME/Library/Developer/Xcode/iOS DeviceSupport"   "Dev Tools" "SAFE" "rm"
  scan_target "Xcode watchOS Support"    "$HOME/Library/Developer/Xcode/watchOS DeviceSupport" "Dev Tools" "SAFE" "rm"
  scan_target "Xcode macOS Support"      "$HOME/Library/Developer/Xcode/macOS DeviceSupport" "Dev Tools" "SAFE" "rm"
  scan_target "Xcode Products"           "$HOME/Library/Developer/Xcode/Products"            "Dev Tools" "SAFE" "rm"
  scan_target "Xcode Cache"              "$HOME/Library/Caches/com.apple.dt.Xcode"           "Dev Tools" "SAFE" "rm"
  scan_target "iOS Simulators"           "$HOME/Library/Developer/CoreSimulator"              "Dev Tools" "SAFE" "rm"
  # Simulator Volumes — SIP-protected on Tahoe, moved to Untouchable.
  # xcrun simctl delete unavailable (below) handles simulator cleanup.
  local _simvol_path="/Library/Developer/CoreSimulator/Volumes"
  if [[ -d "$_simvol_path" ]]; then
    local _simvol_kb
    _simvol_kb=$(get_kb_sudo "$_simvol_path")
    if (( _simvol_kb > 0 )); then
      U_NAMES+=("Simulator Volumes (CoreSimulator runtimes)")
      U_PATHS+=("$_simvol_path")
      U_SIZES+=("$_simvol_kb")
      U_DESCS+=("/Library/Developer/CoreSimulator/Volumes/ is protected by SIP on macOS Tahoe. No official command to delete it. xcrun simctl delete unavailable only removes simulators, not volume runtimes. Apple manages these when you update Xcode.")
      U_TOTAL=$((U_TOTAL + _simvol_kb))
    fi
  fi
  scan_target "Simulator Runtimes"       "/Library/Developer/CoreSimulator/Profiles/Runtimes" "Dev Tools" "SAFE" "rm-sudo"

  # Delete unavailable simulators if xcrun is available
  if has_cmd xcrun; then
    logp "\r\033[K  ${DIM}⠹ Scanning Unavailable Simulators${NC}"
    unavail_count=$(xcrun simctl list devices unavailable 2>/dev/null | grep -c "unavailable" || true)
    if (( unavail_count > 0 )); then
      _flush_cat_header
      T_NAMES+=("Unavailable Simulators (${unavail_count})")
      T_PATHS+=("__xcrun_simctl__")
      T_SIZES+=("0")
      T_CATS+=("Dev Tools")
      T_RISKS+=("SAFE")
      T_METHODS+=("xcrun-sim")
      log "\r\033[K  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "Unavailable Simulators" "${unavail_count} devs"
    else
      logp "\r\033[K"
    fi
  fi

  # Other dev tools
  scan_target "Android SDK"         "$HOME/Library/Android"                         "Dev Tools" "SAFE" "rm"
  scan_target "CocoaPods Cache"     "$HOME/Library/Caches/CocoaPods"               "Dev Tools" "SAFE" "rm"

  # node_modules search across code directories
  for code_dir in "${CODE_DIRS[@]}"; do
    [[ -d "$code_dir" ]] || continue
    dir_name="$(basename "$code_dir")"
    matches_profile "Dev Tools" || continue
    is_excluded "$code_dir" && continue

    logp "\r\033[K  ${DIM}⠹ Scanning node_modules (~/$dir_name)${NC}"
    nm_kb=$(find "$code_dir" -name "node_modules" -maxdepth 4 -type d -exec du -sk {} + 2>/dev/null | awk '{s+=$1} END {print s+0}')
    if (( nm_kb > MIN_SIZE_KB )); then
      _flush_cat_header
      T_NAMES+=("node_modules (~/$dir_name)")
      T_PATHS+=("$code_dir")
      T_SIZES+=("$nm_kb")
      T_CATS+=("Dev Tools")
      T_RISKS+=("SAFE")
      T_METHODS+=("find-nm")
      FOUND_TOTAL=$((FOUND_TOTAL + nm_kb))
      log "\r\033[K  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "node_modules (~/$dir_name)" "$(fmt "$nm_kb")"
    else
      logp "\r\033[K"
    fi
  done

  # Rust target/ directories across code directories
  for code_dir in "${CODE_DIRS[@]}"; do
    [[ -d "$code_dir" ]] || continue
    dir_name="$(basename "$code_dir")"
    is_excluded "$code_dir" && continue

    logp "\r\033[K  ${DIM}⠹ Scanning Rust targets (~/$dir_name)${NC}"
    rust_kb=0
    rust_found=false
    while IFS= read -r cargo_file; do
      target_dir="$(dirname "$cargo_file")/target"
      if [[ -d "$target_dir" ]]; then
        kb=$(get_kb "$target_dir")
        rust_kb=$((rust_kb + kb))
        rust_found=true
      fi
    done < <(find "$code_dir" -name "Cargo.toml" -maxdepth 5 2>/dev/null)

    if $rust_found && (( rust_kb > MIN_SIZE_KB )); then
      _flush_cat_header
      T_NAMES+=("Rust targets (~/$dir_name)")
      T_PATHS+=("$code_dir")
      T_SIZES+=("$rust_kb")
      T_CATS+=("Dev Tools")
      T_RISKS+=("SAFE")
      T_METHODS+=("find-rust")
      FOUND_TOTAL=$((FOUND_TOTAL + rust_kb))
      log "\r\033[K  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "Rust targets (~/$dir_name)" "$(fmt "$rust_kb")"
    else
      logp "\r\033[K"
    fi
  done

  dev_count=0; dev_kb=0
  for ((i=dev_start; i<${#T_CATS[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "Dev Tools" ]] && ((++dev_count)) && dev_kb=$((dev_kb + T_SIZES[$i]))
  done
  cat_footer "$dev_count" "$dev_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE: Dev Toolchains (language-specific caches and runtimes)
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "Dev Tools"; then
  cat_header "Dev Toolchains" "$CYAN"
  tc_start=${#T_NAMES[@]}

  # Rust
  scan_target "Cargo Registry"      "$HOME/.cargo/registry"          "Dev Tools" "SAFE" "rm"
  scan_target "Rustup Toolchains"   "$HOME/.rustup/toolchains"       "Dev Tools" "SAFE" "rm"

  # Go
