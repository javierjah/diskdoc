  scan_target "Apple Music Media"  "$HOME/Music/Music/Media"                                    "Media" "REBUILD" "rm"
  scan_target "Podcasts Data"      "$HOME/Library/Group Containers/243LU875E5.groups.com.apple.podcasts" "Media" "REBUILD" "rm"
  scan_target "Apple Books Data"   "$HOME/Library/Containers/com.apple.BKAgentService"          "Media" "REBUILD" "rm"

  # GarageBand / Logic / Final Cut
