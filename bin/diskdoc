    [[ -d "$ff_profile" ]] || continue
    scan_target "Firefox storage" "${ff_profile}storage" "Browser Personal" "PERSONAL" "rm"
  done

  bp_count=0; bp_kb=0
  for ((i=bp_start; i<${#T_CATS[@]}; i++)); do
