# ════════════════════════════════════════════════════════════════════════════
# TIER 2: Large impact categories (5-100+ GB)
# ════════════════════════════════════════════════════════════════════════════

# ── B1: Browser Service Worker Caches (generic Chromium function) ──────────

declare -a CHROMIUM_NAMES=("Chrome" "Edge" "Brave" "Arc" "Vivaldi" "Opera")
declare -a CHROMIUM_PATHS=(
  "$HOME/Library/Application Support/Google/Chrome"
  "$HOME/Library/Application Support/Microsoft Edge"
  "$HOME/Library/Application Support/BraveSoftware/Brave-Browser"
  "$HOME/Library/Application Support/Arc/User Data"
  "$HOME/Library/Application Support/Vivaldi"
  "$HOME/Library/Application Support/com.operasoftware.Opera"
)

scan_chromium_caches() {
  local browser_name="$1" base_path="$2"
  [[ -d "$base_path" ]] || return 0

  local cache_dirs=("Service Worker/CacheStorage" "Service Worker/ScriptCache" "Code Cache" "GPUCache" "Application Cache")

  for profile_dir in "$base_path"/Default "$base_path"/Profile\ *; do
    [[ -d "$profile_dir" ]] || continue
    local profile_name
    profile_name=$(basename "$profile_dir")

    for cdir in "${cache_dirs[@]}"; do
      local full_path="${profile_dir}/${cdir}"
      [[ -d "$full_path" ]] || continue
      local cname
      cname=$(basename "$cdir")
      scan_target "${browser_name} ${profile_name} ${cname}" "$full_path" "Browser" "SAFE" "rm"
    done
  done
}

if matches_profile "App" || [[ "$PROFILE" == "all" ]]; then
  cat_header "Browser Caches" "$CYAN"
  br_start=${#T_NAMES[@]}

  for ((bi=0; bi<${#CHROMIUM_NAMES[@]}; bi++)); do
    scan_chromium_caches "${CHROMIUM_NAMES[$bi]}" "${CHROMIUM_PATHS[$bi]}"
  done

  # B3: Safari
  scan_target "Safari Cache" "$HOME/Library/Caches/com.apple.Safari" "Browser" "SAFE" "rm"
  scan_target "Safari SafeBrowsing" "$HOME/Library/Caches/com.apple.Safari.SafeBrowsing" "Browser" "SAFE" "rm"
  scan_target "Safari WebKit Net" "$HOME/Library/Caches/com.apple.WebKit.Networking" "Browser" "SAFE" "rm"
  scan_target "Safari WebKit Content" "$HOME/Library/Caches/com.apple.WebKit.WebContent" "Browser" "SAFE" "rm"
  scan_target "Safari WebKit GPU" "$HOME/Library/Caches/com.apple.WebKit.GPU" "Browser" "SAFE" "rm"
  scan_target "Safari Container Cache" "$HOME/Library/Containers/com.apple.Safari/Data/Library/Caches" "Browser" "SAFE" "rm"
  scan_target "Safari Favicon Cache" "$HOME/Library/Safari/Favicon Cache" "Browser" "SAFE" "rm"
  scan_target "Safari Touch Icons" "$HOME/Library/Safari/Touch Icons Cache" "Browser" "SAFE" "rm"
  scan_target "Safari Tabs DB" "$HOME/Library/Containers/com.apple.Safari/SafariTabs.db" "Browser" "PERSONAL" "rm"

  # B4: Firefox
  for ff_profile in "$HOME/Library/Application Support/Firefox/Profiles/"*/; do
    [[ -d "$ff_profile" ]] || continue
    local ff_name
    ff_name=$(basename "$ff_profile")
    scan_target "Firefox cache ($ff_name)" "${ff_profile}cache2/entries" "Browser" "SAFE" "rm"
    scan_target "Firefox startup ($ff_name)" "${ff_profile}startupCache" "Browser" "SAFE" "rm"
    scan_target "Firefox datareporting ($ff_name)" "${ff_profile}datareporting" "Browser" "SAFE" "rm"
    scan_target "Firefox crashes ($ff_name)" "${ff_profile}crashes" "Browser" "SAFE" "rm"
    scan_target "Firefox minidumps ($ff_name)" "${ff_profile}minidumps" "Browser" "SAFE" "rm"
  done
  for ff_cache in "$HOME/Library/Caches/Firefox/Profiles/"*/; do
    [[ -d "$ff_cache" ]] || continue
    scan_target "Firefox cache2" "${ff_cache}cache2" "Browser" "SAFE" "rm"
  done

  br_count=0; br_kb=0
  for ((i=br_start; i<${#T_CATS[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "Browser" ]] && ((++br_count)) && br_kb=$((br_kb + T_SIZES[$i]))
  done
  cat_footer "$br_count" "$br_kb"
fi

