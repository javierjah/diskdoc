# ── Untouchable scanners (E1-E6) — NEVER deletable, report only ─────────────

cat_header "Untouchable" "$C_ACCENT"

# E1: dyld shared cache — path varies by macOS version
_dyld_path=""
if (( MACOS_MAJOR >= 13 )); then
  _dyld_path="/System/Volumes/Preboot/Cryptexes/OS/System/Library/dyld"
elif (( MACOS_MAJOR >= 11 )) || { (( MACOS_MAJOR == 10 )) && (( MACOS_MINOR >= 16 )); }; then
  _dyld_path="/System/Library/dyld"
else
  _dyld_path="/private/var/db/dyld"
fi
scan_untouchable_target "dyld shared cache" "$_dyld_path" \
  "Despite the name, this is NOT a cache. It contains all macOS dynamic libraries pre-linked into a single file for faster app startup. An Apple engineer confirmed: 'it is slightly misnamed because it is not really a cache.' Deleting this = system won't boot. Protected by SIP and SSV. Why so big? Apple bundles libraries for all architectures (x86_64 + arm64 + arm64e) and every system framework."

# E2: Rosetta 2 AOT cache (Apple Silicon only)
if [[ "$(uname -m)" == "arm64" ]]; then
  scan_untouchable_target "Rosetta 2 AOT cache" "/private/var/db/oah" \
    "Rosetta 2 translates x86_64 binaries to arm64 ahead-of-time and stores the .aot results here so it doesn't have to retranslate every time you open an Intel app. Even if you delete it (requires disabling SIP), it regenerates as you open Intel apps. No benefit to cleaning it. Why so big? Every Intel binary you've ever opened has its translation stored here — blame Apple's Intel-to-Silicon transition."
fi

# E3: sleepimage — size equals your RAM
scan_untouchable_target "sleepimage" "/private/var/vm/sleepimage" \
  "This file is exactly the size of your RAM because macOS dumps all memory here when the laptop enters deep hibernation (lid closed for long time or critical battery). You CAN reduce it to 0 with 'sudo pmset -a hibernatemode 0', but you'll lose the ability to hibernate — if battery dies completely, you lose unsaved work. Why so big? Apple optimized experience over disk space."

# E4: swap files — created dynamically
_swap_kb=0
if [[ -d "/private/var/vm" ]]; then
  while IFS= read -r _sf; do
    local _sfkb
    _sfkb=$(sudo du -sk "$_sf" 2>/dev/null | awk '{print $1}')
    _swap_kb=$((_swap_kb + _sfkb))
  done < <(find /private/var/vm -name 'swapfile*' -type f 2>/dev/null)
fi
if (( _swap_kb > 0 )); then
  U_NAMES+=("Swap files")
  U_PATHS+=("/private/var/vm/swapfile*")
  U_SIZES+=("$_swap_kb")
  U_DESCS+=("macOS creates these dynamically when it needs more virtual memory than you have in RAM. Deleting them while the system is running causes kernel panic. They clean up on their own when you restart if no longer needed.")
  U_TOTAL=$((U_TOTAL + _swap_kb))
fi

# E5: /Library/Updates — pending macOS updates, SIP-protected
scan_untouchable_target "macOS Update packages" "/Library/Updates" \
  "Apple downloads system updates here before installing them. In theory they should be deleted after installing, but in practice they sometimes aren't. Protected by SIP — even sudo can't delete them. They eventually clean up on their own."

# E6: Staged Frameworks — SIP-protected
scan_untouchable_target "StagedFrameworks" "/Library/Apple/System/Library/StagedFrameworks" \
  "Pre-staged framework translations for Rosetta. Managed entirely by the system. Protected by SIP. Untouchable."

# Log untouchable summary
local _u_count=${#U_NAMES[@]}
if (( _u_count > 0 )); then
  for (( ui=0; ui<_u_count; ui++ )); do
    if (( U_SIZES[ui] > 0 )); then
      log "  │  ${C_ACCENT}🔒${C_RESET}  %-44s ${C_BOLD}%10s${C_RESET}  ${C_ACCENT}UNTOUCHABLE${C_RESET}\n" "${U_NAMES[$ui]}" "$(fmt "${U_SIZES[$ui]}")"
    fi
  done
  log "  │\n"
  log "  │  ${C_DIM}Total untouchable: %s — shown for transparency, never deletable${C_RESET}\n" "$(fmt "$U_TOTAL")"
fi

# ── Scan summary ─────────────────────────────────────────────────────────────

SCAN_END=$(date +%s)
SCAN_ELAPSED=$((SCAN_END - SCAN_START))

log "\n"

if [[ ${#T_NAMES[@]} -eq 0 ]]; then
  log "  ${GREEN}✓  Your disk is clean! No items found above %d MB.${NC}\n" "$MIN_SIZE_MB"
  log "  ${DIM}Scanned in ${SCAN_ELAPSED}s${NC}\n\n"
  exit 0
fi

log "  ${BOLD}Found %d items — %s recoverable${NC}  ${DIM}(scanned in %ds)${NC}\n\n" \
  "${#T_NAMES[@]}" "$(fmt $FOUND_TOTAL)" "$SCAN_ELAPSED"

# ── JSON output ──────────────────────────────────────────────────────────────

if [[ "$JSON_MODE" == true ]]; then
  # Sort: ★ items first, then by size descending
  declare -a JS_SORTED=()
  declare -a _js_star=()
  declare -a _js_rest=()
  for i in "${!T_SIZES[@]}"; do
    if [[ "${T_NAMES[$i]}" == ★* ]]; then
      _js_star+=("${T_SIZES[$i]}|$i")
    else
      _js_rest+=("${T_SIZES[$i]}|$i")
    fi
  done
  if [[ ${#_js_star[@]} -gt 0 ]]; then
    IFS=$'\n' read -r -d '' -a _js_star < <(printf '%s\n' "${_js_star[@]}" | sort -t'|' -k1 -nr && printf '\0') || true
    JS_SORTED+=("${_js_star[@]}")
  fi
  if [[ ${#_js_rest[@]} -gt 0 ]]; then
    IFS=$'\n' read -r -d '' -a _js_rest < <(printf '%s\n' "${_js_rest[@]}" | sort -t'|' -k1 -nr && printf '\0') || true
    JS_SORTED+=("${_js_rest[@]}")
  fi

  json_escape() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    echo "$s"
  }

  echo "{"
  printf '  "version": "%s",\n' "$VERSION"
  printf '  "disk": {\n'
  printf '    "total_bytes": %d,\n' "$((DISK_TOTAL * 1024))"
  printf '    "free_bytes": %d,\n' "$((DISK_AVAIL_BEFORE * 1024))"
  printf '    "used_bytes": %d\n' "$((DISK_USED_BEFORE * 1024))"
  printf '  },\n'
  printf '  "min_size_mb": %d,\n' "$MIN_SIZE_MB"
  printf '  "profile": "%s",\n' "$PROFILE"
  printf '  "scan_seconds": %d,\n' "$SCAN_ELAPSED"
  printf '  "total_recoverable_bytes": %d,\n' "$((FOUND_TOTAL * 1024))"
  printf '  "items": [\n'

  first=true
  for entry in "${JS_SORTED[@]}"; do
    i="${entry#*|}"
    $first || printf ',\n'
    first=false
    printf '    {\n'
    printf '      "name": "%s",\n' "$(json_escape "${T_NAMES[$i]}")"
    printf '      "path": "%s",\n' "$(json_escape "${T_PATHS[$i]}")"
    printf '      "category": "%s",\n' "${T_CATS[$i]}"
    printf '      "size_bytes": %d,\n' "$((T_SIZES[$i] * 1024))"
    printf '      "size_human": "%s",\n' "$(fmt "${T_SIZES[$i]}")"
    printf '      "risk": "%s",\n' "$(json_escape "${T_RISKS[$i]}")"
    printf '      "method": "%s"\n' "${T_METHODS[$i]}"
    printf '    }'
  done

  printf '\n  ],\n'
  printf '  "untouchable_total_bytes": %d,\n' "$((U_TOTAL * 1024))"
  printf '  "untouchable": [\n'
  local uj_first=true
  for (( ui=0; ui<${#U_NAMES[@]}; ui++ )); do
    (( U_SIZES[ui] == 0 )) && continue
    $uj_first || printf ',\n'
    uj_first=false
    printf '    {\n'
    printf '      "name": "%s",\n' "$(json_escape "${U_NAMES[$ui]}")"
    printf '      "path": "%s",\n' "$(json_escape "${U_PATHS[$ui]}")"
    printf '      "size_bytes": %d,\n' "$((U_SIZES[$ui] * 1024))"
    printf '      "size_human": "%s",\n' "$(fmt "${U_SIZES[$ui]}")"
    printf '      "risk": "UNTOUCHABLE",\n'
    printf '      "description": "%s"\n' "$(json_escape "${U_DESCS[$ui]}")"
    printf '    }'
  done
  printf '\n  ]\n'
  echo "}"
  exit 0
fi

# ── Sort: ★ items first, then by size descending ────────────────────────────

declare -a SORTED=()
declare -a _star=()
declare -a _rest=()
for i in "${!T_SIZES[@]}"; do
  if [[ "${T_NAMES[$i]}" == ★* ]]; then
    _star+=("${T_SIZES[$i]}|$i")
  else
    _rest+=("${T_SIZES[$i]}|$i")
  fi
done
if [[ ${#_star[@]} -gt 0 ]]; then
  IFS=$'\n' read -r -d '' -a _star < <(printf '%s\n' "${_star[@]}" | sort -t'|' -k1 -nr && printf '\0') || true
  SORTED+=("${_star[@]}")
fi
if [[ ${#_rest[@]} -gt 0 ]]; then
  IFS=$'\n' read -r -d '' -a _rest < <(printf '%s\n' "${_rest[@]}" | sort -t'|' -k1 -nr && printf '\0') || true
  SORTED+=("${_rest[@]}")
fi

# ── Display table with inline bars ───────────────────────────────────────────

# Find max size for proportional bars
TABLE_MAX_KB=0
for entry in "${SORTED[@]}"; do
  i="${entry#*|}"
  (( T_SIZES[$i] > TABLE_MAX_KB )) && TABLE_MAX_KB=${T_SIZES[$i]}
done

printf "  ${C_DIM}%-3s  %-32s  %10s  %-10s  %-6s${C_RESET}\n" "#" "Name" "Size" "Bar" "Risk"
printf "  ${C_DIM}%s${C_RESET}\n" "────────────────────────────────────────────────────────────────────────────"

idx=1
for entry in "${SORTED[@]}"; do
  i="${entry#*|}"

  if [[ "${T_METHODS[$i]}" == "tm-thin" ]]; then
    size_fmt="${TM_SNAP_COUNT} snaps"
  else
    size_fmt=$(fmt "${T_SIZES[$i]}")
  fi

  local_tag="${T_RISKS[$i]}"
  rc=$(risk_color "$local_tag")
  icon=$(risk_icon "$local_tag")

  name="${T_NAMES[$i]}"
  (( ${#name} > 32 )) && name="${name:0:29}..."

  bar=$(draw_bar "${T_SIZES[$i]}" "$TABLE_MAX_KB" 10)

  printf "  ${C_DIM}%3d${C_RESET}  %-32s  %10s  %s  %s ${rc}${C_BOLD}%-8s${C_RESET}\n" \
    "$idx" "$name" "$size_fmt" "$bar" "$icon" "$local_tag"
  ((idx++))
done

printf "  ${C_DIM}%s${C_RESET}\n" "────────────────────────────────────────────────────────────────────────────"
printf "  ${C_BOLD}${C_ACCENT}     TOTAL RECOVERABLE                %10s${C_RESET}\n" "$(fmt $FOUND_TOTAL)"
echo ""


# ── Report mode (hierarchical audit tree) ────────────────────────────────────

if [[ "$REPORT_MODE" == true ]]; then
  echo -e "  ${BOLD}${CYAN}diskdoc report — Full Disk Audit${NC}"
  echo ""

  # Collect unique categories preserving insertion order
  declare -a report_cats=()
  for entry in "${SORTED[@]}"; do
    i="${entry#*|}"
    c="${T_CATS[$i]}"
    found_cat=false
    for rc in "${report_cats[@]+"${report_cats[@]}"}"; do
      [[ "$rc" == "$c" ]] && found_cat=true && break
    done
    $found_cat || report_cats+=("$c")
  done

  grand_total=0
  for rcat in "${report_cats[@]}"; do
    cat_total=0
    cat_items=()
    for entry in "${SORTED[@]}"; do
      i="${entry#*|}"
      [[ "${T_CATS[$i]}" == "$rcat" ]] || continue
      cat_items+=("$i")
      cat_total=$((cat_total + T_SIZES[$i]))
    done

    # Find max in category for proportional bars
    cat_max_kb=0
    for ci in "${cat_items[@]}"; do
      (( T_SIZES[$ci] > cat_max_kb )) && cat_max_kb=${T_SIZES[$ci]}
    done

    printf "  ${BOLD}%s${NC}  ${DIM}(%s)${NC}\n" "$rcat" "$(fmt "$cat_total")"

    local last_idx=$(( ${#cat_items[@]} - 1 ))
    local ci_idx=0
    for ci in "${cat_items[@]}"; do
      local_tag="${T_RISKS[$ci]}"
      local_rc=$(risk_color "$local_tag")
      local_icon=$(risk_icon "$local_tag")
      if [[ "${T_METHODS[$ci]}" == "tm-thin" ]]; then
        local_size="${TM_SNAP_COUNT} snaps"
      else
        local_size=$(fmt "${T_SIZES[$ci]}")
      fi
      name="${T_NAMES[$ci]}"
      (( ${#name} > 36 )) && name="${name:0:33}..."
      local_bar=$(draw_bar "${T_SIZES[$ci]}" "$cat_max_kb" 10)
      local connector
      if (( ci_idx == last_idx )); then connector="└──"; else connector="├──"; fi
      printf "  ${DIM}%s${NC} %-36s %10s  %s  %s ${local_rc}${BOLD}%s${NC}\n" \
        "$connector" "$name" "$local_size" "$local_bar" "$local_icon" "$local_tag"
      ((ci_idx++))
    done

    grand_total=$((grand_total + cat_total))
    echo ""
  done

  printf "  ${BOLD}${MAGENTA}Total recoverable: %s${NC}  ${DIM}(%d items across %d categories)${NC}\n" \
    "$(fmt "$grand_total")" "${#T_NAMES[@]}" "${#report_cats[@]}"
  echo ""

  # Untouchable section in report
  if (( ${#U_NAMES[@]} > 0 )); then
    draw_box "🔒 Untouchable — Apple's territory" "$C_ACCENT" 60 \
      "Total: $(fmt "$U_TOTAL") — none of this can be safely removed" \
      ""
    for (( ui=0; ui<${#U_NAMES[@]}; ui++ )); do
      if (( U_SIZES[ui] > 0 )); then
        printf "  ${C_ACCENT}🔒${C_RESET} %-38s %10s\n" "${U_NAMES[$ui]}" "$(fmt "${U_SIZES[$ui]}")"
      fi
    done
    echo ""
    printf "  ${C_DIM}These exist because of decisions Apple made about how${C_RESET}\n"
    printf "  ${C_DIM}macOS works. diskdoc shows them for transparency, but${C_RESET}\n"
    printf "  ${C_DIM}will never delete them. Run with --scan for details.${C_RESET}\n"
    echo ""
  fi

  printf "  ${DIM}Report mode: nothing was deleted.${NC}\n"
  printf "  ${DIM}Items tagged PERSONAL are included for audit only.${NC}\n"
  echo ""
  exit 0
fi

# ── Dry-run output ───────────────────────────────────────────────────────────

if [[ "$DRY_RUN" == true ]]; then
  echo -e "  ${BOLD}${YELLOW}Dry run — commands that would execute:${NC}"
  echo ""

  idx=1
  for entry in "${SORTED[@]}"; do
    i="${entry#*|}"
    method="${T_METHODS[$i]}"
    path="${T_PATHS[$i]}"
    name="${T_NAMES[$i]}"
    (( ${#name} > 36 )) && name="${name:0:33}..."

    cmd=""
    case "$method" in
      rm)           cmd="rm -rf \"$path\"" ;;
      rm-sudo)      cmd="sudo rm -rf \"$path\"" ;;
      find-nm)      cmd="find \"$path\" -name node_modules -maxdepth 4 -type d -exec rm -rf {} +" ;;
      find-rust)    cmd="find \"$path\" -name Cargo.toml -maxdepth 5 → rm -rf target/" ;;
      npm-cache)    cmd="npm cache clean --force" ;;
      pnpm-prune)   cmd="pnpm store prune" ;;
      brew-cleanup) cmd="brew cleanup --prune=all" ;;
      tm-thin)      cmd="sudo tmutil thinlocalsnapshots / 99999999999" ;;
      xcrun-sim)    cmd="xcrun simctl delete unavailable" ;;
      qlmanage-reset) cmd="qlmanage -r cache && rm -rf \"$path\"" ;;
      find-artifact)  cmd="find \"$path\" -name '${name%% (*}' -maxdepth 5 -type d -exec rm -rf {} +" ;;
      docker-prune)   cmd="docker system prune -a --volumes -f" ;;
      spotlight-rebuild) cmd="sudo mdutil -E /" ;;
      caskroom-clean) cmd="find \"$path\" -type f \\( -name '*.dmg' -o -name '*.pkg' \\) -delete" ;;
    esac

    printf "  ${DIM}[%2d]${NC} %-36s  ${DIM}%s${NC}\n" "$idx" "$name" "$cmd"
    ((idx++))
  done

  echo ""
  printf "  ${DIM}Total: %s would be recovered${NC}\n" "$(fmt $FOUND_TOTAL)"
  printf "  ${DIM}Run 'diskdoc' without --dry-run to execute.${NC}\n"
  echo ""
  exit 0
fi

# ── Scan only mode ───────────────────────────────────────────────────────────

if [[ "$SCAN_ONLY" == true ]]; then
  echo -e "  ${DIM}Scan mode: nothing was deleted.${NC}"
  echo -e "  ${DIM}Run 'diskdoc' to interactively select and clean.${NC}"
  echo ""
  exit 0
fi

# ── Selection ────────────────────────────────────────────────────────────────

if [[ "$AUTO_MODE" == true ]]; then
  personal_skipped=0
  for ((i=0; i<${#SORTED[@]}; i++)); do
    auto_idx="${SORTED[$i]#*|}"
    if [[ "${T_RISKS[$auto_idx]}" == "PERSONAL" || "${T_RISKS[$auto_idx]}" == "UNTOUCHABLE" ]]; then
      SELECTED[$i]=0
      ((personal_skipped++)) || true
    else
      SELECTED[$i]=1
    fi
  done
  echo -e "  ${YELLOW}Auto mode: proceeding with cleanup (SAFE items only)...${NC}"
  if (( personal_skipped > 0 )); then
    echo -e "  ${DIM}Skipped ${personal_skipped} personal/untouchable items${NC}"
  fi
else
  echo -e "  ${BOLD}Select items to delete:${NC}"
  echo ""
  interactive_select

  any_selected=false
  for s in "${SELECTED[@]}"; do
    [[ "$s" == "1" ]] && any_selected=true && break
  done

  if ! $any_selected; then
    echo ""
    echo -e "  ${DIM}No items selected. Nothing was deleted.${NC}"
    exit 0
  fi
fi

echo ""
echo -e "  ${YELLOW}${BOLD}Cleaning...${NC}"
echo ""

# ── Cleanup ──────────────────────────────────────────────────────────────────

ITEMS_CLEANED=0
ITEMS_FAILED=0
START_TIME=$(date +%s)

selector_idx=0
for entry in "${SORTED[@]}"; do
  i="${entry#*|}"

  if [[ "${SELECTED[$selector_idx]}" != "1" ]]; then
    ((selector_idx++))
    continue
  fi
  ((selector_idx++))

  method="${T_METHODS[$i]}"
  path="${T_PATHS[$i]}"
  name="${T_NAMES[$i]}"
  (( ${#name} > 42 )) && name="${name:0:39}..."

  printf "  ${DIM}[%d/%d]${NC} %-42s " "$((ITEMS_CLEANED + ITEMS_FAILED + 1))" "${#SORTED[@]}" "$name"

  ok=false
  case "$method" in
    rm)
      rm -rf "$path" 2>/dev/null && ok=true
      ;;
    rm-sudo)
      sudo rm -rf "$path" 2>/dev/null && ok=true
      ;;
    find-nm)
      find "$path" -name "node_modules" -maxdepth 4 -type d -exec rm -rf {} + 2>/dev/null
      ok=true
      ;;
    find-rust)
      while IFS= read -r cargo_file; do
        target_dir="$(dirname "$cargo_file")/target"
        [[ -d "$target_dir" ]] && rm -rf "$target_dir" 2>/dev/null
      done < <(find "$path" -name "Cargo.toml" -maxdepth 5 2>/dev/null)
      ok=true
      ;;
    npm-cache)
      npm cache clean --force &>/dev/null && ok=true
      ;;
    pnpm-prune)
      pnpm store prune &>/dev/null && ok=true
      ;;
    brew-cleanup)
      brew cleanup --prune=all -q &>/dev/null && ok=true
      ;;
    tm-thin)
      sudo tmutil thinlocalsnapshots / 99999999999 &>/dev/null && ok=true
      ;;
    xcrun-sim)
      xcrun simctl delete unavailable &>/dev/null && ok=true
      ;;
    qlmanage-reset)
      qlmanage -r cache &>/dev/null && rm -rf "$path" 2>/dev/null && ok=true
      ;;
    find-artifact)
      artifact_name="${name%% (*}"
      find "$path" -name "$artifact_name" -maxdepth 5 -type d -exec rm -rf {} + 2>/dev/null
      ok=true
      ;;
    docker-prune)
      docker system prune -a --volumes -f &>/dev/null && ok=true
      ;;
    spotlight-rebuild)
      sudo mdutil -E / &>/dev/null && ok=true
      ;;
    caskroom-clean)
      find "$path" -type f \( -name '*.dmg' -o -name '*.pkg' \) -delete 2>/dev/null && ok=true
      ;;
  esac

  if $ok; then
    echo -e "${GREEN}done${NC}"
    ((ITEMS_CLEANED++))
  else
    echo -e "${RED}failed${NC}"
    ((ITEMS_FAILED++))
  fi
done

END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))

# ── Final Report ─────────────────────────────────────────────────────────────

DISK_LINE_AFTER=$(df -k / | tail -1)
DISK_AVAIL_AFTER=$(echo "$DISK_LINE_AFTER" | awk '{print $4}')
DISK_USED_AFTER=$((DISK_TOTAL - DISK_AVAIL_AFTER))
ACTUAL_RECOVERED=$((DISK_AVAIL_AFTER - DISK_AVAIL_BEFORE))

(( ACTUAL_RECOVERED < 0 )) && ACTUAL_RECOVERED=0

PCT_FREE_BEFORE=$((DISK_AVAIL_BEFORE * 100 / DISK_TOTAL))
PCT_FREE_AFTER=$((DISK_AVAIL_AFTER * 100 / DISK_TOTAL))

echo ""
draw_box "Final Report" "$C_INFO" 60
echo ""
echo -e "  ${DIM}Total disk .........${NC}  $(fmt "$DISK_TOTAL")"
echo -e "  ${DIM}Free before ........${NC}  $(fmt "$DISK_AVAIL_BEFORE") (${PCT_FREE_BEFORE}%)"
echo -e "  ${DIM}Free after .........${NC}  ${GREEN}${BOLD}$(fmt "$DISK_AVAIL_AFTER") (${PCT_FREE_AFTER}%)${NC}"
echo ""
echo -e "  ${BOLD}${GREEN}Space recovered ....  $(fmt $ACTUAL_RECOVERED)${NC}"
echo -e "  ${DIM}Items cleaned ......${NC}  ${ITEMS_CLEANED} succeeded, ${ITEMS_FAILED} failed"
echo -e "  ${DIM}Time elapsed .......${NC}  ${ELAPSED}s"
echo ""

# ── Progress bar ─────────────────────────────────────────────────────────────
BAR=40

echo -ne "  Before: ["
filled_before=$((DISK_USED_BEFORE * BAR / DISK_TOTAL))
empty_before=$((BAR - filled_before))
for ((j=0; j<filled_before; j++)); do echo -ne "${RED}█${NC}"; done
for ((j=0; j<empty_before; j++)); do echo -ne "${DIM}░${NC}"; done
echo -e "]  ${DIM}$(fmt "$DISK_AVAIL_BEFORE") free${NC}"

echo -ne "  After:  ["
filled_after=$((DISK_USED_AFTER * BAR / DISK_TOTAL))
empty_after=$((BAR - filled_after))
for ((j=0; j<filled_after; j++)); do echo -ne "${YELLOW}█${NC}"; done
for ((j=0; j<empty_after; j++)); do echo -ne "${GREEN}░${NC}"; done
echo -e "]  ${GREEN}${BOLD}$(fmt "$DISK_AVAIL_AFTER") free${NC}"

# ── Save to history ──────────────────────────────────────────────────────────

save_history "$ACTUAL_RECOVERED" "$ITEMS_CLEANED" "$ITEMS_FAILED" "$ELAPSED"

echo ""
echo -e "${BOLD}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "  ${DIM}Cleanup saved to ~/.diskdoc/history.log${NC}"
echo -e "  ${DIM}Run periodically to keep your disk clean.${NC}"
echo -e "${BOLD}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
