# ════════════════════════════════════════════════════════════════════════════
# PHASE: Dev Artifacts (--dev-artifacts deep scan)
# ════════════════════════════════════════════════════════════════════════════

if [[ "$DEV_ARTIFACTS" == true ]] && matches_profile "Dev Tools"; then
  cat_header "Dev Artifacts (deep scan)" "$CYAN"
  da_start=${#T_NAMES[@]}

  ARTIFACT_DIRS=("node_modules" "target" ".next" ".nuxt" ".turbo" "dist" "build" ".gradle" "__pycache__" ".venv" "venv" "vendor" ".prisma" "coverage")

  for code_dir in "${CODE_DIRS[@]}"; do
    [[ -d "$code_dir" ]] || continue
    dir_name="$(basename "$code_dir")"
    is_excluded "$code_dir" && continue

    for artifact in "${ARTIFACT_DIRS[@]}"; do
      log "\r\033[K  │  ${DIM}…${NC}  %-44s" "${artifact} (~/$dir_name)"

      art_kb=$(find "$code_dir" -name "$artifact" -maxdepth 5 -type d -exec du -sk {} + 2>/dev/null | awk '{s+=$1} END {print s+0}')

      if (( art_kb > MIN_SIZE_KB )); then
        T_NAMES+=("${artifact} (~/$dir_name)")
        T_PATHS+=("$code_dir")
        T_SIZES+=("$art_kb")
        T_CATS+=("Dev Tools")
        T_RISKS+=("SAFE")
        T_METHODS+=("find-artifact")
        FOUND_TOTAL=$((FOUND_TOTAL + art_kb))
        log "\r\033[K  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "${artifact} (~/$dir_name)" "$(fmt "$art_kb")"
      else
        log "\r\033[K  │  ${DIM}·${NC}  ${DIM}%-44s${NC}\n" "${artifact} (~/$dir_name)"
      fi
    done
  done

  da_count=0; da_kb=0
  for ((i=da_start; i<${#T_NAMES[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "Dev Tools" ]] && ((da_count++)) && da_kb=$((da_kb + T_SIZES[$i]))
  done
  cat_footer "$da_count" "$da_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE: App Data
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "App"; then
  cat_header "App Data" "$MAGENTA"
  app_start=${#T_NAMES[@]}

  if has_cmd docker; then
    scan_target "Docker Data"        "$HOME/Library/Containers/com.docker.docker/Data"             "App" "SAFE" "docker-prune"
  else
    scan_target "Docker Data"        "$HOME/Library/Containers/com.docker.docker/Data"             "App" "SAFE" "rm"
  fi
  scan_target "Claude VM Bundles"    "$HOME/Library/Application Support/Claude/vm_bundles"         "App" "SAFE" "rm"
  scan_target "Claude Cache"         "$HOME/Library/Application Support/Claude/Cache"              "App" "SAFE" "rm"
  scan_target "Claude Code Cache"    "$HOME/Library/Application Support/Claude/Code Cache"         "App" "SAFE" "rm"
  scan_target "ChatGPT App Data"     "$HOME/Library/Application Support/com.openai.chat"          "App" "SAFE" "rm"
  scan_target "ChatGPT Data (atlas)" "$HOME/Library/Application Support/com.openai.atlas"         "App" "SAFE" "rm"
  scan_target "Kiro Data"            "$HOME/Library/Application Support/Kiro"                     "App" "SAFE" "rm"
  scan_target "Windsurf Data"        "$HOME/Library/Application Support/Windsurf"                 "App" "SAFE" "rm"
  scan_target "Cursor Data"          "$HOME/Library/Application Support/Cursor"                   "App" "SAFE" "rm"
  scan_target "Mail Attachment Cache" "$HOME/Library/Containers/com.apple.mail/Data/Library/Mail Downloads" "App" "SAFE" "rm"

  # Known heavy Electron app caches
  scan_target "Slack Cache"          "$HOME/Library/Application Support/Slack/Service Worker/CacheStorage"  "App" "SAFE" "rm"
  scan_target "Discord Cache"        "$HOME/Library/Application Support/discord/Cache"                      "App" "SAFE" "rm"
  scan_target "Notion Cache"         "$HOME/Library/Application Support/Notion"                             "App" "SAFE" "rm"

  # Dynamic: sandbox container caches > threshold
  for cdir in "$HOME/Library/Containers/"*/Data/Library/Caches; do
    [[ -d "$cdir" ]] || continue
    container=$(echo "$cdir" | sed "s|$HOME/Library/Containers/||" | sed 's|/Data/Library/Caches||')
    # Skip already-scanned containers
    already=false
    for existing in "${T_PATHS[@]+"${T_PATHS[@]}"}"; do
      [[ "$cdir" == "$existing" || "$existing" == *"$container"* ]] && already=true && break
    done
    $already && continue
    is_excluded "$cdir" && continue

    kb=$(get_kb "$cdir")
    if (( kb > MIN_SIZE_KB )); then
      short="${container}"
      (( ${#short} > 30 )) && short="${short:0:27}..."
      T_NAMES+=("Container: $short")
      T_PATHS+=("$cdir")
      T_SIZES+=("$kb")
      T_CATS+=("App")
      T_RISKS+=("SAFE")
      T_METHODS+=("rm")
      FOUND_TOTAL=$((FOUND_TOTAL + kb))
      log "  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "Container: $short" "$(fmt "$kb")"
    fi
  done

  # Dynamic: group container caches > threshold
  for gdir in "$HOME/Library/Group Containers/"*/Library/Caches; do
    [[ -d "$gdir" ]] || continue
    group=$(echo "$gdir" | sed "s|$HOME/Library/Group Containers/||" | sed 's|/Library/Caches||')
    already=false
    for existing in "${T_PATHS[@]+"${T_PATHS[@]}"}"; do
      [[ "$gdir" == "$existing" || "$existing" == *"$group"* ]] && already=true && break
    done
    $already && continue
    is_excluded "$gdir" && continue

    kb=$(get_kb "$gdir")
    if (( kb > MIN_SIZE_KB )); then
      short="${group}"
      (( ${#short} > 30 )) && short="${short:0:27}..."
      T_NAMES+=("Group: $short")
      T_PATHS+=("$gdir")
      T_SIZES+=("$kb")
      T_CATS+=("App")
      T_RISKS+=("SAFE")
      T_METHODS+=("rm")
      FOUND_TOTAL=$((FOUND_TOTAL + kb))
      log "  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "Group: $short" "$(fmt "$kb")"
    fi
  done

  app_count=0; app_kb=0
  for ((i=app_start; i<${#T_CATS[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "App" ]] && ((app_count++)) && app_kb=$((app_kb + T_SIZES[$i]))
  done
  cat_footer "$app_count" "$app_kb"
fi

