    dir_name="$(basename "$code_dir")"
    is_excluded "$code_dir" && continue

    for artifact in "${ARTIFACT_DIRS[@]}"; do
      log "\r\033[K  │  ${DIM}…${NC}  %-44s" "${artifact} (~/$dir_name)"

      art_kb=$(find "$code_dir" -name "$artifact" -maxdepth 5 -type d -exec du -sk {} + 2>/dev/null | awk '{s+=$1} END {print s+0}')

      if (( art_kb > MIN_SIZE_KB )); then
        T_NAMES+=("${artifact} (~/$dir_name)")
        T_PATHS+=("$code_dir")
        T_SIZES+=("$art_kb")
        T_CATS+=("Dev Tools")
        T_RISKS+=("SAFE")
        T_METHODS+=("find-artifact")
        FOUND_TOTAL=$((FOUND_TOTAL + art_kb))
        log "\r\033[K  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "${artifact} (~/$dir_name)" "$(fmt "$art_kb")"
      else
        log "\r\033[K  │  ${DIM}·${NC}  ${DIM}%-44s${NC}\n" "${artifact} (~/$dir_name)"
      fi
    done
  done

  da_count=0; da_kb=0
  for ((i=da_start; i<${#T_NAMES[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "Dev Tools" ]] && ((da_count++)) && da_kb=$((da_kb + T_SIZES[$i]))
  done
  cat_footer "$da_count" "$da_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE: App Data
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "App"; then
  cat_header "App Data" "$MAGENTA"
  app_start=${#T_NAMES[@]}

  if has_cmd docker; then
    scan_target "Docker Data"        "$HOME/Library/Containers/com.docker.docker/Data"             "App" "SAFE" "docker-prune"
  else
    scan_target "Docker Data"        "$HOME/Library/Containers/com.docker.docker/Data"             "App" "SAFE" "rm"
  fi
  scan_target "Claude VM Bundles"    "$HOME/Library/Application Support/Claude/vm_bundles"         "App" "SAFE" "rm"
  scan_target "Claude Cache"         "$HOME/Library/Application Support/Claude/Cache"              "App" "SAFE" "rm"
  scan_target "Claude Code Cache"    "$HOME/Library/Application Support/Claude/Code Cache"         "App" "SAFE" "rm"
  scan_target "ChatGPT App Data"     "$HOME/Library/Application Support/com.openai.chat"          "App" "SAFE" "rm"
  scan_target "ChatGPT Data (atlas)" "$HOME/Library/Application Support/com.openai.atlas"         "App" "SAFE" "rm"
  scan_target "Kiro Data"            "$HOME/Library/Application Support/Kiro"                     "App" "SAFE" "rm"
  scan_target "Windsurf Data"        "$HOME/Library/Application Support/Windsurf"                 "App" "SAFE" "rm"
  scan_target "Cursor Data"          "$HOME/Library/Application Support/Cursor"                   "App" "SAFE" "rm"
  scan_target "Mail Attachment Cache" "$HOME/Library/Containers/com.apple.mail/Data/Library/Mail Downloads" "App" "SAFE" "rm"

  # Known heavy Electron app caches
  scan_target "Slack Cache"          "$HOME/Library/Application Support/Slack/Service Worker/CacheStorage"  "App" "SAFE" "rm"
  scan_target "Discord Cache"        "$HOME/Library/Application Support/discord/Cache"                      "App" "SAFE" "rm"
  scan_target "Notion Cache"         "$HOME/Library/Application Support/Notion"                             "App" "SAFE" "rm"

  # Dynamic: sandbox container caches > threshold
  for cdir in "$HOME/Library/Containers/"*/Data/Library/Caches; do
    [[ -d "$cdir" ]] || continue
    container=$(echo "$cdir" | sed "s|$HOME/Library/Containers/||" | sed 's|/Data/Library/Caches||')
    # Skip already-scanned containers
    already=false
    for existing in "${T_PATHS[@]+"${T_PATHS[@]}"}"; do
      [[ "$cdir" == "$existing" || "$existing" == *"$container"* ]] && already=true && break
    done
    $already && continue
    is_excluded "$cdir" && continue

    kb=$(get_kb "$cdir")
    if (( kb > MIN_SIZE_KB )); then
      short="${container}"
      (( ${#short} > 30 )) && short="${short:0:27}..."
      T_NAMES+=("Container: $short")
      T_PATHS+=("$cdir")
      T_SIZES+=("$kb")
      T_CATS+=("App")
      T_RISKS+=("SAFE")
      T_METHODS+=("rm")
      FOUND_TOTAL=$((FOUND_TOTAL + kb))
      log "  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "Container: $short" "$(fmt "$kb")"
    fi
  done

  # Dynamic: group container caches > threshold
  for gdir in "$HOME/Library/Group Containers/"*/Library/Caches; do
    [[ -d "$gdir" ]] || continue
    group=$(echo "$gdir" | sed "s|$HOME/Library/Group Containers/||" | sed 's|/Library/Caches||')
    already=false
    for existing in "${T_PATHS[@]+"${T_PATHS[@]}"}"; do
      [[ "$gdir" == "$existing" || "$existing" == *"$group"* ]] && already=true && break
    done
    $already && continue
    is_excluded "$gdir" && continue

    kb=$(get_kb "$gdir")
    if (( kb > MIN_SIZE_KB )); then
      short="${group}"
      (( ${#short} > 30 )) && short="${short:0:27}..."
      T_NAMES+=("Group: $short")
      T_PATHS+=("$gdir")
      T_SIZES+=("$kb")
      T_CATS+=("App")
      T_RISKS+=("SAFE")
      T_METHODS+=("rm")
      FOUND_TOTAL=$((FOUND_TOTAL + kb))
      log "  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "Group: $short" "$(fmt "$kb")"
    fi
  done

  app_count=0; app_kb=0
  for ((i=app_start; i<${#T_CATS[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "App" ]] && ((app_count++)) && app_kb=$((app_kb + T_SIZES[$i]))
  done
  cat_footer "$app_count" "$app_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE: Media (downloaded content — REBUILD risk)
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "App" || matches_profile "Media" || [[ "$PROFILE" == "all" ]]; then
  cat_header "Media Downloads" "$BLUE"
  media_start=${#T_NAMES[@]}

  scan_target "Apple TV Cache"     "$HOME/Library/Containers/com.apple.TV/Data/Library/Caches"  "Media" "REBUILD" "rm"
  scan_target "Apple TV Downloads" "$HOME/Movies/TV"                                            "Media" "REBUILD" "rm"
  scan_target "Apple Music Media"  "$HOME/Music/Music/Media"                                    "Media" "REBUILD" "rm"
  scan_target "Podcasts Data"      "$HOME/Library/Group Containers/243LU875E5.groups.com.apple.podcasts" "Media" "REBUILD" "rm"
  scan_target "Apple Books Data"   "$HOME/Library/Containers/com.apple.BKAgentService"          "Media" "REBUILD" "rm"

  # GarageBand / Logic / Final Cut
  scan_target "GarageBand Data"    "$HOME/Library/Application Support/GarageBand"                "Media" "REBUILD" "rm"
  scan_target "Logic Pro Data"     "$HOME/Library/Application Support/Logic"                     "Media" "REBUILD" "rm"
  scan_target "Audio Libraries"    "$HOME/Library/Audio"                                         "Media" "REBUILD" "rm"
  scan_target "FCP Renders"        "$HOME/Movies/Final Cut Pro Library/Renders"                  "Media" "REBUILD" "rm"

  media_count=0; media_kb=0
  for ((i=media_start; i<${#T_NAMES[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "Media" ]] && ((media_count++)) && media_kb=$((media_kb + T_SIZES[$i]))
  done
  cat_footer "$media_count" "$media_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE: Personal Data (PERSONAL — report only, never auto-delete)
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "Personal" || [[ "$PROFILE" == "all" ]]; then
  cat_header "Personal Data ⚠ report only" "$MAGENTA"
  personal_start=${#T_NAMES[@]}

  # Mail databases (try multiple versions)
  for v in V10 V9 V8; do
    [[ -d "$HOME/Library/Mail/$v" ]] && {
      scan_target "Mail Database ($v)" "$HOME/Library/Mail/$v" "Personal" "PERSONAL" "rm"
      break
    }
  done

  scan_target "Mail Downloads"        "$HOME/Library/Containers/com.apple.mail/Data/Library/Mail Downloads" "Personal" "PERSONAL" "rm"
  scan_target "Messages Attachments"  "$HOME/Library/Messages/Attachments"                                  "Personal" "PERSONAL" "rm"
  scan_target "Messages Database"     "$HOME/Library/Messages"                                              "Personal" "PERSONAL" "rm"

  # iCloud Drive local cache
  scan_target "iCloud Drive (local)"  "$HOME/Library/Mobile Documents"                                      "Personal" "PERSONAL" "rm"

  # Photos Library derivatives (face recognition cache — takes hours to rebuild)
  scan_target "Photos Derivatives"    "$HOME/Pictures/Photos Library.photoslibrary/resources"                "Personal" "PERSONAL" "rm"

  personal_count=0; personal_kb=0
  for ((i=personal_start; i<${#T_NAMES[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "Personal" ]] && ((personal_count++)) && personal_kb=$((personal_kb + T_SIZES[$i]))
  done
  cat_footer "$personal_count" "$personal_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE: Logs & Diagnostics
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "Logs" || [[ "$PROFILE" == "all" ]] || [[ "$PROFILE" == "system" ]]; then
  cat_header "Logs & Diagnostics" "$DIM"
  logs_start=${#T_NAMES[@]}

  scan_target "System Diagnostics"    "/private/var/db/diagnostics"                          "Logs" "SAFE" "rm-sudo"
  scan_target "UUID Text Logs"        "/private/var/db/uuidtext"                             "Logs" "SAFE" "rm-sudo"
  scan_target "System Logs (var)"     "/private/var/log"                                     "Logs" "SAFE" "rm-sudo"
  scan_target "User Logs"             "$HOME/Library/Logs"                                   "Logs" "SAFE" "rm"
  scan_target "System Diagnostic Rpt" "/Library/Logs/DiagnosticReports"                      "Logs" "SAFE" "rm-sudo"
  scan_target "User Diagnostic Rpt"   "$HOME/Library/Logs/DiagnosticReports"                 "Logs" "SAFE" "rm"
  scan_target "Crash Reporter"        "$HOME/Library/Application Support/CrashReporter"      "Logs" "SAFE" "rm"

  # QuickLook and font caches
  ql_cache_dir=$(getconf DARWIN_USER_CACHE_DIR 2>/dev/null || true)
  if [[ -n "$ql_cache_dir" ]]; then
    scan_target "QuickLook Thumbnails" "${ql_cache_dir}com.apple.QuickLook.thumbnailcache" "Logs" "SAFE" "qlmanage-reset"
  fi
  scan_target "Font ATS Cache"       "/Library/Caches/com.apple.ATS"                          "Logs" "SAFE" "rm-sudo"
  scan_target "Font Registry Cache"  "$HOME/Library/Caches/com.apple.FontRegistry"            "Logs" "SAFE" "rm"

  logs_count=0; logs_kb=0
  for ((i=logs_start; i<${#T_NAMES[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "Logs" ]] && ((logs_count++)) && logs_kb=$((logs_kb + T_SIZES[$i]))
  done
  cat_footer "$logs_count" "$logs_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE: Dynamic caches (~/Library/Caches/* > threshold)
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "Cache"; then
  cat_header "Caches" "$GREEN"
  cache_start=${#T_NAMES[@]}

  if [[ -d "$HOME/Library/Caches" ]]; then
    log "  │  ${DIM}Scanning ~/Library/Caches for entries > %d MB...${NC}\n" "$MIN_SIZE_MB"

    while IFS=$'\t' read -r size path; do
      base=$(basename "$path")
      name="Cache: $base"

      # Skip items already added (CocoaPods, Homebrew, Yarn, pip)
      already=false
      for existing in "${T_PATHS[@]+"${T_PATHS[@]}"}"; do
        [[ "$existing" == "$path" ]] && already=true && break
      done
      $already && continue

      is_excluded "$path" && continue
      matches_profile "Cache" || continue

      kb=$(echo "$size" | tr -d '[:space:]')
      if (( kb > MIN_SIZE_KB )); then
        T_NAMES+=("$name")
        T_PATHS+=("$path")
        T_SIZES+=("$kb")
        T_CATS+=("Cache")
        T_RISKS+=("SAFE")
        T_METHODS+=("rm")
        FOUND_TOTAL=$((FOUND_TOTAL + kb))
        log "  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "$name" "$(fmt "$kb")"
      fi
    done < <(du -sk "$HOME/Library/Caches/"* 2>/dev/null | sort -nr)
  fi

  cache_count=0; cache_kb=0
  for ((i=cache_start; i<${#T_CATS[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "Cache" ]] && ((cache_count++)) && cache_kb=$((cache_kb + T_SIZES[$i]))
  done
  cat_footer "$cache_count" "$cache_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE 5: Package Managers
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "Pkg Manager"; then
  cat_header "Package Managers" "$BLUE"
  pkg_start=${#T_NAMES[@]}

  scan_target "npm Cache"       "$HOME/.npm"                       "Pkg Manager" "SAFE" "npm-cache"
  has_cmd pnpm  && scan_target "pnpm Store"     "$HOME/Library/pnpm/store"     "Pkg Manager" "SAFE" "pnpm-prune"
  has_cmd yarn  && scan_target "Yarn Cache"     "$HOME/Library/Caches/Yarn"    "Pkg Manager" "SAFE" "rm"
  has_cmd pip3  && scan_target "pip Cache"      "$HOME/Library/Caches/pip"     "Pkg Manager" "SAFE" "rm"
  has_cmd brew  && scan_target "Homebrew Cache" "$HOME/Library/Caches/Homebrew" "Pkg Manager" "SAFE" "brew-cleanup"

  pkg_count=0; pkg_kb=0
  for ((i=pkg_start; i<${#T_CATS[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "Pkg Manager" ]] && ((pkg_count++)) && pkg_kb=$((pkg_kb + T_SIZES[$i]))
  done
  cat_footer "$pkg_count" "$pkg_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE: Ghost Apps (uninstalled apps with leftover data)
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "App" || [[ "$PROFILE" == "all" ]]; then
  cat_header "Ghost Apps" "$RED"
  ghost_start=${#T_NAMES[@]}

  log "  │  ${DIM}Checking for leftover data from uninstalled apps...${NC}\n"

  is_app_installed() {
    local bid="$1"
    # Check common app locations
    for app_dir in /Applications ~/Applications /System/Applications; do
      if [[ -d "$app_dir" ]]; then
        while IFS= read -r plist; do
          local pbid
          pbid=$(/usr/libexec/PlistBuddy -c "Print :CFBundleIdentifier" "$plist" 2>/dev/null || true)
          [[ "$pbid" == "$bid" ]] && return 0
        done < <(find "$app_dir" -name "Info.plist" -maxdepth 4 2>/dev/null)
      fi
    done
    # Fallback to Spotlight
    mdfind "kMDItemCFBundleIdentifier == '$bid'" 2>/dev/null | grep -q ".app" && return 0
    return 1
  }

  # Check ~/Library/Containers/*
  for cdir in "$HOME/Library/Containers/"*/; do
    [[ -d "$cdir" ]] || continue
    bid=$(basename "$cdir")
    # Skip system containers and known non-app IDs
    [[ "$bid" == com.apple.* ]] && continue
    is_excluded "$cdir" && continue

    if ! is_app_installed "$bid"; then
      kb=$(get_kb "$cdir")
      if (( kb > MIN_SIZE_KB )); then
        short="$bid"
        (( ${#short} > 36 )) && short="${short:0:33}..."
        T_NAMES+=("Ghost: $short")
        T_PATHS+=("$cdir")
        T_SIZES+=("$kb")
        T_CATS+=("App")
        T_RISKS+=("SAFE")
        T_METHODS+=("rm")
        FOUND_TOTAL=$((FOUND_TOTAL + kb))
        log "  │  ${RED}👻${NC} %-44s ${BOLD}%10s${NC}\n" "Ghost: $short" "$(fmt "$kb")"
      fi
    fi
  done

  # Check ~/Library/Application Support/*
  for asdir in "$HOME/Library/Application Support/"*/; do
    [[ -d "$asdir" ]] || continue
    bid=$(basename "$asdir")
    # Skip non-bundle-id names and known dirs
    [[ "$bid" == *"."* ]] || continue
    [[ "$bid" == com.apple.* ]] && continue
    is_excluded "$asdir" && continue

    # Skip if already scanned (Claude, ChatGPT, etc)
    already=false
    for existing in "${T_PATHS[@]+"${T_PATHS[@]}"}"; do
      [[ "$asdir" == "$existing" || "$existing" == "$asdir"* ]] && already=true && break
    done
    $already && continue

    if ! is_app_installed "$bid"; then
      kb=$(get_kb "$asdir")
      if (( kb > MIN_SIZE_KB )); then
        short="$bid"
        (( ${#short} > 36 )) && short="${short:0:33}..."
        T_NAMES+=("Ghost: $short")
        T_PATHS+=("$asdir")
        T_SIZES+=("$kb")
        T_CATS+=("App")
        T_RISKS+=("SAFE")
        T_METHODS+=("rm")
        FOUND_TOTAL=$((FOUND_TOTAL + kb))
        log "  │  ${RED}👻${NC} %-44s ${BOLD}%10s${NC}\n" "Ghost: $short" "$(fmt "$kb")"
      fi
    fi
  done

  ghost_count=0; ghost_kb=0
  for ((i=ghost_start; i<${#T_NAMES[@]}; i++)); do
    [[ "${T_NAMES[$i]}" == "Ghost:"* ]] && ((ghost_count++)) && ghost_kb=$((ghost_kb + T_SIZES[$i]))
  done
  cat_footer "$ghost_count" "$ghost_kb"
fi

# ── Scan summary ─────────────────────────────────────────────────────────────

SCAN_END=$(date +%s)
SCAN_ELAPSED=$((SCAN_END - SCAN_START))

log "\n"

if [[ ${#T_NAMES[@]} -eq 0 ]]; then
  log "  ${GREEN}✓  Your disk is clean! No items found above %d MB.${NC}\n" "$MIN_SIZE_MB"
  log "  ${DIM}Scanned in ${SCAN_ELAPSED}s${NC}\n\n"
  exit 0
fi

log "  ${BOLD}Found %d items — %s recoverable${NC}  ${DIM}(scanned in %ds)${NC}\n\n" \
  "${#T_NAMES[@]}" "$(fmt $FOUND_TOTAL)" "$SCAN_ELAPSED"

# ── JSON output ──────────────────────────────────────────────────────────────

if [[ "$JSON_MODE" == true ]]; then
  # Sort: ★ items first, then by size descending
  declare -a JS_SORTED=()
  declare -a _js_star=()
  declare -a _js_rest=()
  for i in "${!T_SIZES[@]}"; do
    if [[ "${T_NAMES[$i]}" == ★* ]]; then
      _js_star+=("${T_SIZES[$i]}|$i")
    else
      _js_rest+=("${T_SIZES[$i]}|$i")
    fi
  done
  if [[ ${#_js_star[@]} -gt 0 ]]; then
    IFS=$'\n' read -r -d '' -a _js_star < <(printf '%s\n' "${_js_star[@]}" | sort -t'|' -k1 -nr && printf '\0') || true
    JS_SORTED+=("${_js_star[@]}")
  fi
  if [[ ${#_js_rest[@]} -gt 0 ]]; then
    IFS=$'\n' read -r -d '' -a _js_rest < <(printf '%s\n' "${_js_rest[@]}" | sort -t'|' -k1 -nr && printf '\0') || true
    JS_SORTED+=("${_js_rest[@]}")
  fi

  json_escape() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    echo "$s"
  }

  echo "{"
  printf '  "version": "%s",\n' "$VERSION"
  printf '  "disk": {\n'
  printf '    "total_bytes": %d,\n' "$((DISK_TOTAL * 1024))"
  printf '    "free_bytes": %d,\n' "$((DISK_AVAIL_BEFORE * 1024))"
  printf '    "used_bytes": %d\n' "$((DISK_USED_BEFORE * 1024))"
  printf '  },\n'
  printf '  "min_size_mb": %d,\n' "$MIN_SIZE_MB"
  printf '  "profile": "%s",\n' "$PROFILE"
  printf '  "scan_seconds": %d,\n' "$SCAN_ELAPSED"
  printf '  "total_recoverable_bytes": %d,\n' "$((FOUND_TOTAL * 1024))"
  printf '  "items": [\n'

  first=true
  for entry in "${JS_SORTED[@]}"; do
    i="${entry#*|}"
    $first || printf ',\n'
    first=false
    printf '    {\n'
    printf '      "name": "%s",\n' "$(json_escape "${T_NAMES[$i]}")"
    printf '      "path": "%s",\n' "$(json_escape "${T_PATHS[$i]}")"
    printf '      "category": "%s",\n' "${T_CATS[$i]}"
    printf '      "size_bytes": %d,\n' "$((T_SIZES[$i] * 1024))"
    printf '      "size_human": "%s",\n' "$(fmt "${T_SIZES[$i]}")"
    printf '      "risk": "%s",\n' "$(json_escape "${T_RISKS[$i]}")"
    printf '      "method": "%s"\n' "${T_METHODS[$i]}"
    printf '    }'
  done

  printf '\n  ]\n'
  echo "}"
  exit 0
fi

# ── Sort: ★ items first, then by size descending ────────────────────────────

declare -a SORTED=()
declare -a _star=()
declare -a _rest=()
for i in "${!T_SIZES[@]}"; do
  if [[ "${T_NAMES[$i]}" == ★* ]]; then
    _star+=("${T_SIZES[$i]}|$i")
  else
    _rest+=("${T_SIZES[$i]}|$i")
  fi
done
if [[ ${#_star[@]} -gt 0 ]]; then
  IFS=$'\n' read -r -d '' -a _star < <(printf '%s\n' "${_star[@]}" | sort -t'|' -k1 -nr && printf '\0') || true
  SORTED+=("${_star[@]}")
fi
if [[ ${#_rest[@]} -gt 0 ]]; then
  IFS=$'\n' read -r -d '' -a _rest < <(printf '%s\n' "${_rest[@]}" | sort -t'|' -k1 -nr && printf '\0') || true
  SORTED+=("${_rest[@]}")
fi

# ── Display table ────────────────────────────────────────────────────────────

echo -e "${BOLD}${CYAN}  ┌─────┬──────────────────────────────────┬──────────────┬────────────┬──────────────────────────┐${NC}"
printf  "${BOLD}${CYAN}  │${NC}${BOLD} %-3s ${CYAN}│${NC}${BOLD} %-32s ${CYAN}│${NC}${BOLD} %-12s ${CYAN}│${NC}${BOLD} %-10s ${CYAN}│${NC}${BOLD} %-24s ${CYAN}│${NC}\n" "#" "Name" "Category" "Size" "Risk"
echo -e "${BOLD}${CYAN}  ├─────┼──────────────────────────────────┼──────────────┼────────────┼──────────────────────────┤${NC}"

idx=1
for entry in "${SORTED[@]}"; do
  i="${entry#*|}"

  if [[ "${T_METHODS[$i]}" == "tm-thin" ]]; then
    size_fmt="${TM_SNAP_COUNT} snaps"
  else
    size_fmt=$(fmt "${T_SIZES[$i]}")
  fi

  if (( T_SIZES[$i] >= 10485760 )); then
    color="$RED"
  elif (( T_SIZES[$i] >= 1048576 )); then
    color="$YELLOW"
  elif [[ "${T_NAMES[$i]}" == ★* ]]; then
    color="$YELLOW"
  else
    color="$NC"
  fi

  name="${T_NAMES[$i]}"
  (( ${#name} > 32 )) && name="${name:0:29}..."

  tag="${T_RISKS[$i]}"
  rc=$(risk_color "$tag")

  cat="${T_CATS[$i]}"
  (( ${#cat} > 12 )) && cat="${cat:0:12}"

  # Risk tag with its own color, rest of row uses size-based color
  printf "${CYAN}  │${NC} ${color}%-3s${NC} ${CYAN}│${NC} ${color}%-32s${NC} ${CYAN}│${NC} ${color}%-12s${NC} ${CYAN}│${NC} ${color}%10s${NC} ${CYAN}│${NC} ${rc}${BOLD}%-8s${NC}%-16s ${CYAN}│${NC}\n" \
    "$idx" "$name" "$cat" "$size_fmt" "$tag" ""
  ((idx++))
done

echo -e "${BOLD}${CYAN}  ├─────┴──────────────────────────────────┴──────────────┼────────────┼──────────────────────────┤${NC}"
printf  "${BOLD}${CYAN}  │${NC}${BOLD}${MAGENTA}  TOTAL RECOVERABLE                                     ${CYAN}│${NC}${BOLD}${MAGENTA} %10s ${CYAN}│${NC}                          ${CYAN}│${NC}\n" "$(fmt $FOUND_TOTAL)"
echo -e "${BOLD}${CYAN}  └────────────────────────────────────────────────────────┴────────────┴──────────────────────────┘${NC}"
echo ""

# ── Report mode (hierarchical audit tree) ────────────────────────────────────

if [[ "$REPORT_MODE" == true ]]; then
  echo -e "  ${BOLD}${CYAN}diskdoc report — Full Disk Audit${NC}"
  echo ""

  # Collect unique categories preserving insertion order
  declare -a report_cats=()
  for entry in "${SORTED[@]}"; do
    i="${entry#*|}"
    c="${T_CATS[$i]}"
    found_cat=false
    for rc in "${report_cats[@]+"${report_cats[@]}"}"; do
      [[ "$rc" == "$c" ]] && found_cat=true && break
    done
    $found_cat || report_cats+=("$c")
  done

  grand_total=0
  for rcat in "${report_cats[@]}"; do
    cat_total=0
    cat_items=()
    for entry in "${SORTED[@]}"; do
      i="${entry#*|}"
      [[ "${T_CATS[$i]}" == "$rcat" ]] || continue
      cat_items+=("$i")
      cat_total=$((cat_total + T_SIZES[$i]))
    done

    printf "  ${BOLD}%s${NC}  ${DIM}(%s)${NC}\n" "$rcat" "$(fmt "$cat_total")"

    for ci in "${cat_items[@]}"; do
      local_tag="${T_RISKS[$ci]}"
      local_rc=$(risk_color "$local_tag")
      if [[ "${T_METHODS[$ci]}" == "tm-thin" ]]; then
        local_size="${TM_SNAP_COUNT} snaps"
      else
        local_size=$(fmt "${T_SIZES[$ci]}")
      fi
      name="${T_NAMES[$ci]}"
      (( ${#name} > 40 )) && name="${name:0:37}..."
      printf "  ${DIM}├──${NC} %-40s %10s  ${local_rc}${BOLD}%s${NC}\n" "$name" "$local_size" "$local_tag"
    done

    grand_total=$((grand_total + cat_total))
    echo ""
  done

  printf "  ${BOLD}${MAGENTA}Total: %s${NC}  ${DIM}(%d items across %d categories)${NC}\n" \
    "$(fmt "$grand_total")" "${#T_NAMES[@]}" "${#report_cats[@]}"
  echo ""
  printf "  ${DIM}Report mode: nothing was deleted.${NC}\n"
  printf "  ${DIM}Items tagged PERSONAL are included for audit only.${NC}\n"
  echo ""
  exit 0
fi

# ── Dry-run output ───────────────────────────────────────────────────────────

if [[ "$DRY_RUN" == true ]]; then
  echo -e "  ${BOLD}${YELLOW}Dry run — commands that would execute:${NC}"
  echo ""

  idx=1
  for entry in "${SORTED[@]}"; do
    i="${entry#*|}"
    method="${T_METHODS[$i]}"
    path="${T_PATHS[$i]}"
    name="${T_NAMES[$i]}"
    (( ${#name} > 36 )) && name="${name:0:33}..."

    cmd=""
    case "$method" in
      rm)           cmd="rm -rf \"$path\"" ;;
      rm-sudo)      cmd="sudo rm -rf \"$path\"" ;;
      find-nm)      cmd="find \"$path\" -name node_modules -maxdepth 4 -type d -exec rm -rf {} +" ;;
      find-rust)    cmd="find \"$path\" -name Cargo.toml -maxdepth 5 → rm -rf target/" ;;
      npm-cache)    cmd="npm cache clean --force" ;;
      pnpm-prune)   cmd="pnpm store prune" ;;
      brew-cleanup) cmd="brew cleanup --prune=all" ;;
      tm-thin)      cmd="sudo tmutil thinlocalsnapshots / 99999999999" ;;
      xcrun-sim)    cmd="xcrun simctl delete unavailable" ;;
      qlmanage-reset) cmd="qlmanage -r cache && rm -rf \"$path\"" ;;
      find-artifact)  cmd="find \"$path\" -name '${name%% (*}' -maxdepth 5 -type d -exec rm -rf {} +" ;;
      docker-prune)   cmd="docker system prune -a --volumes -f" ;;
    esac

    printf "  ${DIM}[%2d]${NC} %-36s  ${DIM}%s${NC}\n" "$idx" "$name" "$cmd"
    ((idx++))
  done

  echo ""
  printf "  ${DIM}Total: %s would be recovered${NC}\n" "$(fmt $FOUND_TOTAL)"
  printf "  ${DIM}Run 'diskdoc' without --dry-run to execute.${NC}\n"
  echo ""
  exit 0
fi

# ── Scan only mode ───────────────────────────────────────────────────────────

if [[ "$SCAN_ONLY" == true ]]; then
  echo -e "  ${DIM}Scan mode: nothing was deleted.${NC}"
  echo -e "  ${DIM}Run 'diskdoc' to interactively select and clean.${NC}"
  echo ""
  exit 0
fi

# ── Selection ────────────────────────────────────────────────────────────────

if [[ "$AUTO_MODE" == true ]]; then
  personal_skipped=0
  for ((i=0; i<${#SORTED[@]}; i++)); do
    auto_idx="${SORTED[$i]#*|}"
    if [[ "${T_RISKS[$auto_idx]}" == "PERSONAL" || "${T_RISKS[$auto_idx]}" == "UNTOUCHABLE" ]]; then
      SELECTED[$i]=0
      ((personal_skipped++)) || true
    else
      SELECTED[$i]=1
    fi
  done
  echo -e "  ${YELLOW}Auto mode: proceeding with cleanup (SAFE items only)...${NC}"
  if (( personal_skipped > 0 )); then
    echo -e "  ${DIM}Skipped ${personal_skipped} personal/untouchable items${NC}"
  fi
else
  echo -e "  ${BOLD}Select items to delete:${NC}"
  echo ""
  interactive_select

  any_selected=false
  for s in "${SELECTED[@]}"; do
    [[ "$s" == "1" ]] && any_selected=true && break
  done

  if ! $any_selected; then
    echo ""
    echo -e "  ${DIM}No items selected. Nothing was deleted.${NC}"
    exit 0
  fi
fi

echo ""
echo -e "  ${YELLOW}${BOLD}Cleaning...${NC}"
echo ""

# ── Cleanup ──────────────────────────────────────────────────────────────────

ITEMS_CLEANED=0
ITEMS_FAILED=0
START_TIME=$(date +%s)

selector_idx=0
for entry in "${SORTED[@]}"; do
  i="${entry#*|}"

  if [[ "${SELECTED[$selector_idx]}" != "1" ]]; then
    ((selector_idx++))
    continue
  fi
  ((selector_idx++))

  method="${T_METHODS[$i]}"
  path="${T_PATHS[$i]}"
  name="${T_NAMES[$i]}"
  (( ${#name} > 42 )) && name="${name:0:39}..."

  printf "  ${DIM}[%d/%d]${NC} %-42s " "$((ITEMS_CLEANED + ITEMS_FAILED + 1))" "${#SORTED[@]}" "$name"

  ok=false
  case "$method" in
    rm)
      rm -rf "$path" 2>/dev/null && ok=true
      ;;
    rm-sudo)
      sudo rm -rf "$path" 2>/dev/null && ok=true
      ;;
    find-nm)
      find "$path" -name "node_modules" -maxdepth 4 -type d -exec rm -rf {} + 2>/dev/null
      ok=true
      ;;
    find-rust)
      while IFS= read -r cargo_file; do
        target_dir="$(dirname "$cargo_file")/target"
        [[ -d "$target_dir" ]] && rm -rf "$target_dir" 2>/dev/null
      done < <(find "$path" -name "Cargo.toml" -maxdepth 5 2>/dev/null)
      ok=true
      ;;
    npm-cache)
      npm cache clean --force &>/dev/null && ok=true
      ;;
    pnpm-prune)
      pnpm store prune &>/dev/null && ok=true
      ;;
    brew-cleanup)
      brew cleanup --prune=all -q &>/dev/null && ok=true
      ;;
    tm-thin)
      sudo tmutil thinlocalsnapshots / 99999999999 &>/dev/null && ok=true
      ;;
    xcrun-sim)
      xcrun simctl delete unavailable &>/dev/null && ok=true
      ;;
    qlmanage-reset)
      qlmanage -r cache &>/dev/null && rm -rf "$path" 2>/dev/null && ok=true
      ;;
    find-artifact)
      artifact_name="${name%% (*}"
      find "$path" -name "$artifact_name" -maxdepth 5 -type d -exec rm -rf {} + 2>/dev/null
      ok=true
      ;;
    docker-prune)
      docker system prune -a --volumes -f &>/dev/null && ok=true
      ;;
  esac

  if $ok; then
    echo -e "${GREEN}done${NC}"
    ((ITEMS_CLEANED++))
  else
    echo -e "${RED}failed${NC}"
    ((ITEMS_FAILED++))
  fi
done

END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))

# ── Final Report ─────────────────────────────────────────────────────────────

DISK_LINE_AFTER=$(df -k / | tail -1)
DISK_AVAIL_AFTER=$(echo "$DISK_LINE_AFTER" | awk '{print $4}')
DISK_USED_AFTER=$((DISK_TOTAL - DISK_AVAIL_AFTER))
ACTUAL_RECOVERED=$((DISK_AVAIL_AFTER - DISK_AVAIL_BEFORE))

(( ACTUAL_RECOVERED < 0 )) && ACTUAL_RECOVERED=0

PCT_FREE_BEFORE=$((DISK_AVAIL_BEFORE * 100 / DISK_TOTAL))
PCT_FREE_AFTER=$((DISK_AVAIL_AFTER * 100 / DISK_TOTAL))

echo ""
draw_box "Final Report" "$C_INFO" 60
echo ""
echo -e "  ${DIM}Total disk .........${NC}  $(fmt "$DISK_TOTAL")"
echo -e "  ${DIM}Free before ........${NC}  $(fmt "$DISK_AVAIL_BEFORE") (${PCT_FREE_BEFORE}%)"
echo -e "  ${DIM}Free after .........${NC}  ${GREEN}${BOLD}$(fmt "$DISK_AVAIL_AFTER") (${PCT_FREE_AFTER}%)${NC}"
echo ""
echo -e "  ${BOLD}${GREEN}Space recovered ....  $(fmt $ACTUAL_RECOVERED)${NC}"
echo -e "  ${DIM}Items cleaned ......${NC}  ${ITEMS_CLEANED} succeeded, ${ITEMS_FAILED} failed"
echo -e "  ${DIM}Time elapsed .......${NC}  ${ELAPSED}s"
echo ""

# ── Progress bar ─────────────────────────────────────────────────────────────
BAR=40

echo -ne "  Before: ["
filled_before=$((DISK_USED_BEFORE * BAR / DISK_TOTAL))
empty_before=$((BAR - filled_before))
for ((j=0; j<filled_before; j++)); do echo -ne "${RED}█${NC}"; done
for ((j=0; j<empty_before; j++)); do echo -ne "${DIM}░${NC}"; done
echo -e "]  ${DIM}$(fmt "$DISK_AVAIL_BEFORE") free${NC}"

echo -ne "  After:  ["
filled_after=$((DISK_USED_AFTER * BAR / DISK_TOTAL))
empty_after=$((BAR - filled_after))
for ((j=0; j<filled_after; j++)); do echo -ne "${YELLOW}█${NC}"; done
for ((j=0; j<empty_after; j++)); do echo -ne "${GREEN}░${NC}"; done
echo -e "]  ${GREEN}${BOLD}$(fmt "$DISK_AVAIL_AFTER") free${NC}"

# ── Save to history ──────────────────────────────────────────────────────────

save_history "$ACTUAL_RECOVERED" "$ITEMS_CLEANED" "$ITEMS_FAILED" "$ELAPSED"

echo ""
echo -e "${BOLD}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "  ${DIM}Cleanup saved to ~/.diskdoc/history.log${NC}"
echo -e "  ${DIM}Run periodically to keep your disk clean.${NC}"
echo -e "${BOLD}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
