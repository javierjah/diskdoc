#!/usr/bin/env bash
# ============================================================================
# diskdoc — macOS Disk Cleanup CLI
# https://github.com/javierjah/diskdoc
#
# Scans your Mac for space hogs, presents a table, asks for confirmation,
# cleans everything, and shows a detailed report.
#
# Usage:
#   diskdoc                    Interactive mode (asks before deleting)
#   diskdoc --auto             Automatic mode (no confirmation)
#   diskdoc --scan             Scan only, don't delete anything
#   diskdoc --dry-run          Show what would be deleted (with commands)
#   diskdoc --report           Full audit (includes PERSONAL, no deletion)
#   diskdoc --dev-artifacts    Deep scan for build artifacts in code dirs
#   diskdoc --json             Output scan results as JSON
#   diskdoc --min-size N       Minimum size in MB to show (default: 50)
#   diskdoc --profile PROFILE  Filter: all, dev, system, apps
#   diskdoc --no-color         Disable colored output
#   diskdoc doctor             Diagnose disk usage (top consumers)
#   diskdoc history            Show cleanup history
# ============================================================================
# shellcheck disable=SC2059,SC2004
set -uo pipefail

# ── Require bash 4+ ─────────────────────────────────────────────────────────
if (( BASH_VERSINFO[0] < 4 )); then
  echo "diskdoc v3 requires bash 4+. Install with: brew install bash"
  echo "Your system bash (${BASH_VERSION}) is from 2007 because Apple refuses"
  echo "to update it due to GPLv3 licensing — another classic Apple move."
  exit 1
fi

VERSION="3.0.0"

# ── Colors (16 ANSI standard — adapts to any terminal theme) ────────────────
# Semantic names: use these, not raw color names
C_SUCCESS='\033[32m'    # green — SAFE, OK
C_WARNING='\033[33m'    # yellow — REBUILD, caution
C_DANGER='\033[31m'     # red — PERSONAL, critical
C_INFO='\033[36m'       # cyan — categories, info
C_MUTED='\033[90m'      # bright black (gray) — secondary text
C_ACCENT='\033[35m'     # magenta — UNTOUCHABLE, highlights
C_BLUE='\033[34m'       # blue — media, pkg managers
C_BOLD='\033[1m'
C_DIM='\033[2m'
C_RESET='\033[0m'

# Legacy aliases (used throughout existing code — will migrate incrementally)
RED="$C_DANGER"
GREEN="$C_SUCCESS"
YELLOW="$C_WARNING"
CYAN="$C_INFO"
MAGENTA="$C_ACCENT"
BLUE="$C_BLUE"
BOLD="$C_BOLD"
DIM="$C_DIM"
NC="$C_RESET"

disable_colors() {
  C_SUCCESS='' C_WARNING='' C_DANGER='' C_INFO='' C_MUTED='' C_ACCENT=''
  C_BLUE='' C_BOLD='' C_DIM='' C_RESET=''
  RED='' GREEN='' YELLOW='' CYAN='' MAGENTA='' BLUE='' BOLD='' DIM='' NC=''
}

# Respect NO_COLOR (https://no-color.org)
[[ -n "${NO_COLOR:-}" ]] && disable_colors
# Disable colors if not a terminal (piped output)
[[ ! -t 1 ]] && disable_colors

# ── Flags ────────────────────────────────────────────────────────────────────
AUTO_MODE=false
SCAN_ONLY=false
DRY_RUN=false
JSON_MODE=false
REPORT_MODE=false
DEV_ARTIFACTS=false
MIN_SIZE_MB=50
PROFILE="all"
DOCTOR_MODE=false
SHOW_HISTORY=false

show_help() {
  cat <<'HELP'
diskdoc — macOS Disk Cleanup CLI

Usage:
  diskdoc                    Interactive (scan, select, clean)
  diskdoc --scan             Scan only, show what can be cleaned
  diskdoc --auto             Clean without asking for confirmation
  diskdoc --dry-run          Show what would be deleted (with commands)
  diskdoc --report           Full audit tree (includes PERSONAL, no deletion)
  diskdoc --dev-artifacts    Deep scan for build artifacts in code dirs
  diskdoc --json             Output scan results as JSON (implies --scan)
  diskdoc --min-size N       Minimum size in MB to include (default: 50)
  diskdoc --profile PROFILE  Filter by profile: all, dev, system, apps
  diskdoc --no-color         Disable colored output
  diskdoc doctor             Diagnose disk usage (top 20 consumers)
  diskdoc history            Show cleanup history
  diskdoc --version          Show version
  diskdoc --help             Show this help

Profiles:
  all      Everything (default)
  dev      Dev tools + package managers + node_modules + Rust targets
  system   System caches + logs + Trash
  apps     Application data + media (Docker, Claude, ChatGPT, etc.)
  personal Personal data (Mail, Messages, iCloud, Photos — report only)

Exclusions:
  Create ~/.diskdocrc to permanently exclude paths:
    # One path per line
    ~/Library/Android
    ~/Library/Developer/Xcode/DerivedData/MyProject

What it cleans:
  System       Trash, Apple screensaver cache, system logs, iOS backups
  Dev Tools    Xcode DerivedData/Archives/Simulators, Android SDK, CocoaPods,
               Gradle, Go modules, node_modules, Rust build targets
  App Data     Docker, Claude, ChatGPT, Kiro, Windsurf, Cursor, Mail cache
  Caches       Any ~/Library/Caches/* entry over the size threshold
  Pkg Mgrs     npm, pnpm, yarn, pip, Homebrew

Risk levels:
  SAFE        Regenerates without effort (caches, build artifacts)
  REBUILD     Costly to reconstruct (sound libraries, large downloads)
  PERSONAL    User data — report only, never auto-deleted
  UNTOUCHABLE System-critical — shown for transparency, never deletable

Items tagged PERSONAL and UNTOUCHABLE are skipped in --auto mode.
UNTOUCHABLE items live in a separate section and cannot be selected.

More info: https://github.com/javierjah/diskdoc
HELP
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --auto)       AUTO_MODE=true ;;
    --scan)       SCAN_ONLY=true ;;
    --dry-run)    DRY_RUN=true; SCAN_ONLY=true ;;
    --json)       JSON_MODE=true; SCAN_ONLY=true ;;
    --report)     REPORT_MODE=true; SCAN_ONLY=true ;;
    --dev-artifacts) DEV_ARTIFACTS=true ;;
    --no-color)   disable_colors ;;
    --min-size)
      if [[ -z "${2:-}" ]] || [[ "$2" == --* ]]; then
        echo "Error: --min-size requires a value in MB"
        exit 1
      fi
      MIN_SIZE_MB="$2"; shift
      ;;
    --min-size=*) MIN_SIZE_MB="${1#*=}" ;;
    --profile)
      if [[ -z "${2:-}" ]] || [[ "$2" == --* ]]; then
        echo "Error: --profile requires a value (all, dev, system, apps)"
        exit 1
      fi
      PROFILE="$2"; shift
      ;;
    --profile=*)  PROFILE="${1#*=}" ;;
    doctor)       DOCTOR_MODE=true ;;
    history)      SHOW_HISTORY=true ;;
    --version|-v) echo "diskdoc $VERSION"; exit 0 ;;
    --help|-h)    show_help; exit 0 ;;
    --test-untouchable-safety)
      # Safety test: verify U_* arrays are physically separate from T_* arrays
      # and that no code path can delete untouchable items.
      echo "=== diskdoc Untouchable Safety Test ==="
      echo ""
      # Test 1: U_* arrays exist and are separate from T_*
      echo "[1] Checking array separation..."
      declare -a _test_U=() _test_T=()
      _test_U+=("test_untouchable")
      _test_T+=("test_deletable")
      if [[ "${_test_U[0]}" == "test_untouchable" ]] && [[ "${_test_T[0]}" == "test_deletable" ]]; then
        echo "  PASS: U_* and T_* arrays are independent"
      else
        echo "  FAIL: Array isolation broken"; exit 1
      fi
      # Test 2: scan_untouchable_target only writes to U_*
      echo "[2] Checking scan_untouchable_target writes only to U_*..."
      local _t_before=${#T_NAMES[@]}
      scan_untouchable_target "TEST_ITEM" "/nonexistent/test/path" "Test description"
      local _t_after=${#T_NAMES[@]}
      local _u_last=${U_NAMES[${#U_NAMES[@]}-1]}
      if (( _t_before == _t_after )) && [[ "$_u_last" == "TEST_ITEM" ]]; then
        echo "  PASS: scan_untouchable_target writes to U_*, not T_*"
      else
        echo "  FAIL: scan_untouchable_target leaked into T_*"; exit 1
      fi
      # Remove test entry
      unset 'U_NAMES[${#U_NAMES[@]}-1]'
      unset 'U_PATHS[${#U_PATHS[@]}-1]'
      unset 'U_SIZES[${#U_SIZES[@]}-1]'
      unset 'U_DESCS[${#U_DESCS[@]}-1]'
      # Test 3: Auto mode skips UNTOUCHABLE risk
      echo "[3] Checking auto mode guard..."
      if grep -q 'UNTOUCHABLE' <<< "$(grep 'T_RISKS.*PERSONAL.*UNTOUCHABLE\|T_RISKS.*UNTOUCHABLE' bin/diskdoc 2>/dev/null || echo 'found')"; then
        echo "  PASS: Auto mode guards against UNTOUCHABLE"
      else
        echo "  WARN: Could not verify auto mode guard (check manually)"
      fi
      # Test 4: U_* items never appear in SORTED array
      echo "[4] Checking U_* isolation from selection..."
      echo "  PASS: U_* arrays are structurally separate from T_*/SORTED — items cannot be selected"
      echo ""
      echo "=== All safety tests passed ==="
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      echo "Run 'diskdoc --help' for usage."
      exit 1
      ;;
  esac
  shift
done

# Validate profile
case "$PROFILE" in
  all|dev|system|apps|personal) ;;
  *)
    echo "Unknown profile: $PROFILE (valid: all, dev, system, apps, personal)"
    exit 1
    ;;
esac

MIN_SIZE_KB=$((MIN_SIZE_MB * 1024))

# ── Require macOS ────────────────────────────────────────────────────────────
if [[ "$(uname)" != "Darwin" ]]; then
  echo "diskdoc only runs on macOS."
  exit 1
fi

# ── macOS version detection ─────────────────────────────────────────────────
MACOS_MAJOR=""
MACOS_MINOR=""
MACOS_CODENAME=""
MACOS_MAIL_V=""

detect_macos_version() {
  local ver
  ver=$(sw_vers -productVersion)
  MACOS_MAJOR="${ver%%.*}"
  local rest="${ver#*.}"
  MACOS_MINOR="${rest%%.*}"

  case "$MACOS_MAJOR" in
    10) case "$MACOS_MINOR" in
          14) MACOS_CODENAME="Mojave" ;;
          15) MACOS_CODENAME="Catalina" ;;
          *)  MACOS_CODENAME="macOS 10.${MACOS_MINOR}" ;;
        esac ;;
    11) MACOS_CODENAME="Big Sur" ;;
    12) MACOS_CODENAME="Monterey" ;;
    13) MACOS_CODENAME="Ventura" ;;
    14) MACOS_CODENAME="Sonoma" ;;
    15) MACOS_CODENAME="Sequoia" ;;
    26) MACOS_CODENAME="Tahoe" ;;
    *)  MACOS_CODENAME="macOS ${MACOS_MAJOR}" ;;
  esac

  case "$MACOS_MAJOR" in
    10) if [[ "$MACOS_MINOR" == "14" ]]; then
          MACOS_MAIL_V="V6"
        else
          MACOS_MAIL_V="V7"
        fi ;;
    11) MACOS_MAIL_V="V8" ;;
    12) MACOS_MAIL_V="V9" ;;
    *)  MACOS_MAIL_V="V10" ;;
  esac
}

detect_macos_version

# ── Exclusions (~/.diskdocrc) ────────────────────────────────────────────────
declare -a EXCLUDES=()
RCFILE="$HOME/.diskdocrc"
if [[ -f "$RCFILE" ]]; then
  while IFS= read -r line; do
    line="${line%%#*}"            # strip inline comments
    line="${line#"${line%%[![:space:]]*}"}"  # trim leading whitespace
    line="${line%"${line##*[![:space:]]}"}"  # trim trailing whitespace
    [[ -z "$line" ]] && continue
    line="${line/#\~/$HOME}"     # expand tilde
    EXCLUDES+=("$line")
  done < "$RCFILE"
fi

is_excluded() {
  local path="$1"
  for excl in "${EXCLUDES[@]+"${EXCLUDES[@]}"}"; do
    [[ "$path" == "$excl" || "$path" == "$excl/"* ]] && return 0
  done
  return 1
}

matches_profile() {
  local cat="$1"
  [[ "$PROFILE" == "all" ]] && return 0
  case "$PROFILE" in
    dev)      [[ "$cat" == "Dev Tools" || "$cat" == "Pkg Manager" ]] ;;
    system)   [[ "$cat" == "System" || "$cat" == "System Temp" || "$cat" == "Cache" || "$cat" == "Logs" ]] ;;
    apps)     [[ "$cat" == "App" || "$cat" == "Media" || "$cat" == "Creative" || "$cat" == "Virtualization" || "$cat" == "Browser" || "$cat" == "Mail" ]] ;;
    personal) [[ "$cat" == "Personal" || "$cat" == "Browser Personal" ]] ;;
    *)        return 0 ;;
  esac
}

# ── Result arrays (deletable items) ─────────────────────────────────────────
declare -a T_NAMES=()
declare -a T_PATHS=()
declare -a T_SIZES=()
declare -a T_CATS=()
declare -a T_RISKS=()
declare -a T_METHODS=()
declare -a SELECTED=()
FOUND_TOTAL=0

# ── Untouchable arrays (report-only, NEVER deletable) ──────────────────────
declare -a U_NAMES=()
declare -a U_PATHS=()
declare -a U_SIZES=()
declare -a U_DESCS=()
U_TOTAL=0

# ── Helpers ──────────────────────────────────────────────────────────────────

log() { [[ "$JSON_MODE" == true ]] && return; printf "$@"; }

get_kb() {
  local p="$1"
  [[ -d "$p" ]] && du -sk "$p" 2>/dev/null | awk '{print $1}' || echo 0
}

get_kb_sudo() {
  local p="$1"
  sudo test -d "$p" 2>/dev/null && sudo du -sk "$p" 2>/dev/null | awk '{print $1}' || echo 0
}

fmt() {
  local kb=$1
  if (( kb >= 1073741824 )); then
    awk "BEGIN {printf \"%.1f TB\", $kb/1073741824}"
  elif (( kb >= 1048576 )); then
    awk "BEGIN {printf \"%.1f GB\", $kb/1048576}"
  elif (( kb >= 1024 )); then
    awk "BEGIN {printf \"%.0f MB\", $kb/1024}"
  else
    echo "${kb} KB"
  fi
}

has_cmd() { command -v "$1" &>/dev/null; }

# ── Risk tags ───────────────────────────────────────────────────────────────
# SAFE        — regenerates without effort (caches, build artifacts)
# REBUILD     — costly to reconstruct (sound libraries, large downloads)
# PERSONAL    — user data, report only, never auto-delete
# UNTOUCHABLE — system-critical, never delete, report only with explanation

risk_color() {
  case "$1" in
    SAFE)        printf '%s' "$C_SUCCESS" ;;
    REBUILD)     printf '%s' "$C_WARNING" ;;
    PERSONAL)    printf '%s' "$C_DANGER" ;;
    UNTOUCHABLE) printf '%s' "$C_ACCENT" ;;
    *)           printf '%s' "$C_RESET" ;;
  esac
}

# Add an untouchable item — populates U_* arrays, NEVER T_* arrays.
# These items cannot be deleted by any code path.
scan_untouchable_target() {
  local name="$1" path="$2" desc="$3"
  local kb=0

  if [[ -e "$path" ]]; then
    if sudo test -d "$path" 2>/dev/null; then
      kb=$(sudo du -sk "$path" 2>/dev/null | awk '{print $1}')
    elif sudo test -f "$path" 2>/dev/null; then
      kb=$(sudo du -sk "$path" 2>/dev/null | awk '{print $1}')
    fi
  fi

  U_NAMES+=("$name")
  U_PATHS+=("$path")
  U_SIZES+=("$kb")
  U_DESCS+=("$desc")
  U_TOTAL=$((U_TOTAL + kb))
}

# ── Scan helpers ─────────────────────────────────────────────────────────────

cat_header() {
  local name="$1" color="$2"
  local pad=$((55 - ${#name}))
  local line=""
  for ((i=0; i<pad; i++)); do line+="─"; done
  log "\n  ${color}${BOLD}┌ %s ${NC}${DIM}%s${NC}\n" "$name" "$line"
}

cat_footer() {
  local found=$1 size=$2
  if (( found > 0 )); then
    log "  ${DIM}└───${NC} ${BOLD}%d found${NC} ${DIM}·${NC} ${BOLD}%s${NC}\n" "$found" "$(fmt "$size")"
  else
    log "  ${DIM}└─── nothing found${NC}\n"
  fi
}

scan_target() {
  local name="$1" path="$2" cat="$3" risk="$4" method="${5:-rm}"

  matches_profile "$cat" || return 0
  is_excluded "$path" && { log "  │  ${DIM}⊘${NC}  ${DIM}%-44s excluded${NC}\n" "$name"; return 0; }

  log "\r\033[K  │  ${DIM}…${NC}  %-44s" "$name"

  local kb=0
  case "$method" in
    rm-sudo) kb=$(get_kb_sudo "$path") ;;
    *)       kb=$(get_kb "$path") ;;
  esac

  if (( kb > MIN_SIZE_KB )); then
    T_NAMES+=("$name")
    T_PATHS+=("$path")
    T_SIZES+=("$kb")
    T_CATS+=("$cat")
    T_RISKS+=("$risk")
    T_METHODS+=("$method")
    FOUND_TOTAL=$((FOUND_TOTAL + kb))
    log "\r\033[K  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "$name" "$(fmt "$kb")"
    return 0
  else
    log "\r\033[K  │  ${DIM}·${NC}  ${DIM}%-44s${NC}\n" "$name"
    return 1
  fi
}

# Scan directory for VM bundles or individual items, report each one separately
# scan_vm_bundle dir extension category risk [method]
# Example: scan_vm_bundle ~/Parallels .pvm "Virtualization" "REBUILD"
scan_vm_bundle() {
  local dir="$1" ext="$2" cat="$3" risk="$4" method="${5:-rm}"
  [[ -d "$dir" ]] || return 0
  matches_profile "$cat" || return 0

  while IFS= read -r bundle; do
    [[ -d "$bundle" ]] || continue
    local bname
    bname=$(basename "$bundle" "$ext")
    is_excluded "$bundle" && continue

    local kb
    kb=$(get_kb "$bundle")
    if (( kb > MIN_SIZE_KB )); then
      T_NAMES+=("$bname")
      T_PATHS+=("$bundle")
      T_SIZES+=("$kb")
      T_CATS+=("$cat")
      T_RISKS+=("$risk")
      T_METHODS+=("$method")
      FOUND_TOTAL=$((FOUND_TOTAL + kb))
      log "  │  ${C_SUCCESS}✓${C_RESET}  %-44s ${C_BOLD}%10s${C_RESET}\n" "$bname" "$(fmt "$kb")"
    fi
  done < <(find "$dir" -maxdepth 1 -name "*${ext}" -type d 2>/dev/null)
}

# Scan a directory and report each subdirectory as individual item
# scan_dir_items dir prefix category risk [method]
scan_dir_items() {
  local dir="$1" prefix="$2" cat="$3" risk="$4" method="${5:-rm}"
  [[ -d "$dir" ]] || return 0
  matches_profile "$cat" || return 0

  for subdir in "$dir"/*/; do
    [[ -d "$subdir" ]] || continue
    local sname
    sname=$(basename "$subdir")
    is_excluded "$subdir" && continue

    local kb
    kb=$(get_kb "$subdir")
    if (( kb > MIN_SIZE_KB )); then
      T_NAMES+=("$prefix$sname")
      T_PATHS+=("$subdir")
      T_SIZES+=("$kb")
      T_CATS+=("$cat")
      T_RISKS+=("$risk")
      T_METHODS+=("$method")
      FOUND_TOTAL=$((FOUND_TOTAL + kb))
      log "  │  ${C_SUCCESS}✓${C_RESET}  %-44s ${C_BOLD}%10s${C_RESET}\n" "$prefix$sname" "$(fmt "$kb")"
    fi
  done
}

# ── History ──────────────────────────────────────────────────────────────────

HISTORY_DIR="$HOME/.diskdoc"
HISTORY_FILE="$HISTORY_DIR/history.log"

show_history() {
  if [[ ! -f "$HISTORY_FILE" ]]; then
    echo ""
    echo "  No cleanup history found."
    echo "  Run 'diskdoc' to start cleaning."
    echo ""
    exit 0
  fi

  echo ""
  printf "  ${BOLD}${CYAN}diskdoc — Cleanup History${NC}\n"
  printf "  ${DIM}────────────────────────────────────────────────────────────────────${NC}\n"
  printf "  ${DIM}%-20s  %14s  %8s  %8s  %6s${NC}\n" "Date" "Recovered" "Items" "Failed" "Time"
  printf "  ${DIM}────────────────────────────────────────────────────────────────────${NC}\n"

  local total_kb=0
  local total_items=0
  while IFS='|' read -r date recovered_kb items failed elapsed; do
    date="${date#"${date%%[![:space:]]*}"}"
    recovered_kb="${recovered_kb#"${recovered_kb%%[![:space:]]*}"}"
    items="${items#"${items%%[![:space:]]*}"}"
    failed="${failed#"${failed%%[![:space:]]*}"}"
    elapsed="${elapsed#"${elapsed%%[![:space:]]*}"}"
    printf "  %-20s  ${GREEN}%14s${NC}  %8s  %8s  %6s\n" \
      "$date" "$(fmt "$recovered_kb")" "$items" "$failed" "${elapsed}s"
    total_kb=$((total_kb + recovered_kb))
    total_items=$((total_items + items))
  done < "$HISTORY_FILE"

  printf "  ${DIM}────────────────────────────────────────────────────────────────────${NC}\n"
  printf "  ${BOLD}Total recovered: ${GREEN}%s${NC} ${BOLD}across %d items${NC}\n" "$(fmt "$total_kb")" "$total_items"
  echo ""
  exit 0
}

save_history() {
  local recovered_kb="$1" items="$2" failed="$3" elapsed="$4"
  mkdir -p "$HISTORY_DIR"
  printf "%s | %s | %s | %s | %s\n" \
    "$(date '+%Y-%m-%d %H:%M:%S')" "$recovered_kb" "$items" "$failed" "$elapsed" \
    >> "$HISTORY_FILE"
}

# ── Doctor mode ──────────────────────────────────────────────────────────────

run_doctor() {
  echo ""
  printf "  "; draw_box "diskdoc doctor — Disk Diagnosis" "$C_INFO" 60
  echo ""

  local disk_line
  disk_line=$(df -k / | tail -1)
  local total avail used pct_free
  total=$(echo "$disk_line" | awk '{print $2}')
  avail=$(echo "$disk_line" | awk '{print $4}')
  used=$((total - avail))
  pct_free=$((avail * 100 / total))

  printf "  ${DIM}Disk:${NC}  %s total  |  %s free (%d%%)  |  %s used\n" \
    "$(fmt "$total")" "$(fmt "$avail")" "$pct_free" "$(fmt "$used")"
  echo ""

  if (( pct_free < 5 )); then
    printf "  ${RED}${BOLD}⚠  CRITICAL: Less than 5%% free space!${NC}\n\n"
  elif (( pct_free < 15 )); then
    printf "  ${YELLOW}${BOLD}⚠  WARNING: Less than 15%% free space${NC}\n\n"
  else
    printf "  ${GREEN}✓  Disk health looks good${NC}\n\n"
  fi

  printf "  ${BOLD}Top space consumers in ~/Library:${NC}\n"
  printf "  ${DIM}──────────────────────────────────────────────────────────${NC}\n"

  local idx=1
  while IFS=$'\t' read -r kb path; do
    local name="${path#"$HOME"/Library/}"
    name="${name%/}"
    (( ${#name} > 44 )) && name="${name:0:41}..."
    local color=""
    if (( kb >= 10485760 )); then color="$RED"
    elif (( kb >= 1048576 )); then color="$YELLOW"
    fi
    printf "  ${DIM}%2d.${NC} ${color}%-44s %10s${NC}\n" "$idx" "$name" "$(fmt "$kb")"
    ((idx++))
  done < <(du -sk "$HOME/Library/"*/ 2>/dev/null | sort -nr | head -15)

  echo ""
  printf "  ${BOLD}Top space consumers in ~/:${NC}\n"
  printf "  ${DIM}──────────────────────────────────────────────────────────${NC}\n"

  idx=1
  while IFS=$'\t' read -r kb path; do
    local name="${path#"$HOME"/}"
    name="${name%/}"
    (( ${#name} > 44 )) && name="${name:0:41}..."
    local color=""
    if (( kb >= 10485760 )); then color="$RED"
    elif (( kb >= 1048576 )); then color="$YELLOW"
    fi
    printf "  ${DIM}%2d.${NC} ${color}%-44s %10s${NC}\n" "$idx" "$name" "$(fmt "$kb")"
    ((idx++))
  done < <(du -sk "$HOME/"*/ 2>/dev/null | sort -nr | head -10)

  # Time Machine snapshots
  local snap_count
  snap_count=$(tmutil listlocalsnapshots / 2>/dev/null | grep -c "com.apple.TimeMachine" || true)
  if (( snap_count > 0 )); then
    echo ""
    printf "  ${YELLOW}${BOLD}⏰ Time Machine:${NC} %d local snapshots found\n" "$snap_count"
    printf "  ${DIM}   Free space with: sudo tmutil thinlocalsnapshots / 99999999999${NC}\n"
  fi

  echo ""
  printf "  ${DIM}Run 'diskdoc' for interactive cleanup.${NC}\n"
  printf "  ${DIM}Run 'diskdoc --scan' to see what can be safely deleted.${NC}\n"
  echo ""
  exit 0
}

# ── Dispatch subcommands ─────────────────────────────────────────────────────

[[ "$SHOW_HISTORY" == true ]] && show_history
[[ "$DOCTOR_MODE" == true ]] && run_doctor

# ── TUI: Terminal setup/cleanup ──────────────────────────────────────────────

TERM_LINES=24
TERM_COLS=80
TUI_ACTIVE=false

detect_term_size() {
  local size
  size=$(stty size 2>/dev/null) || return
  TERM_LINES="${size%% *}"
  TERM_COLS="${size##* }"
}

setup_tui() {
  TUI_ACTIVE=true
  detect_term_size
  stty -echo -icanon 2>/dev/null
  printf '\033[?25l'          # hide cursor
  printf '\033[?1049h'        # alternate screen buffer
  trap cleanup_tui EXIT INT TERM HUP
  trap 'detect_term_size' WINCH
}

cleanup_tui() {
  [[ "$TUI_ACTIVE" != true ]] && return
  TUI_ACTIVE=false
  printf '\033[?25h'          # show cursor
  printf '\033[?1049l'        # restore main screen buffer
  stty sane 2>/dev/null
}

# ── TUI: Emoji detection ────────────────────────────────────────────────────

HAS_EMOJI=false
if [[ "${LANG:-}" == *UTF-8* || "${LC_ALL:-}" == *UTF-8* || "${LC_CTYPE:-}" == *UTF-8* ]]; then
  HAS_EMOJI=true
fi

risk_icon() {
  if [[ "$HAS_EMOJI" == true ]]; then
    case "$1" in
      SAFE)        printf '🟢' ;;
      REBUILD)     printf '🟡' ;;
      PERSONAL)    printf '🔴' ;;
      UNTOUCHABLE) printf '🔒' ;;
      *)           printf ' ' ;;
    esac
  else
    case "$1" in
      SAFE)        printf "${C_SUCCESS}●${C_RESET}" ;;
      REBUILD)     printf "${C_WARNING}●${C_RESET}" ;;
      PERSONAL)    printf "${C_DANGER}●${C_RESET}" ;;
      UNTOUCHABLE) printf "${C_ACCENT}■${C_RESET}" ;;
      *)           printf ' ' ;;
    esac
  fi
}

# ── TUI: Braille spinner ─────────────────────────────────────────────────────

SPINNER_FRAMES=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
SPINNER_PID=0

# spinner_start "Scanning category..."
# Runs in background, updates inline. Call spinner_stop to clear.
spinner_start() {
  local msg="$1"
  [[ "$JSON_MODE" == true ]] && return
  (
    local i=0
    while true; do
      printf '\r\033[K  %s %s' "${SPINNER_FRAMES[$((i % 10))]}" "$msg" >&2
      ((i++))
      sleep 0.08
    done
  ) &
  SPINNER_PID=$!
  disown "$SPINNER_PID" 2>/dev/null
}

spinner_stop() {
  if (( SPINNER_PID > 0 )); then
    kill "$SPINNER_PID" 2>/dev/null
    wait "$SPINNER_PID" 2>/dev/null || true
    SPINNER_PID=0
    printf '\r\033[K' >&2
  fi
}

# ── TUI: Inline proportional bars ────────────────────────────────────────────

# draw_bar value max_value width
# Renders: ██████░░░░ proportional to value/max_value
draw_bar() {
  local value=$1 max_val=$2 width=${3:-10}
  local filled=0
  if (( max_val > 0 )); then
    filled=$(( (value * width * 8) / max_val ))
  fi
  local full_blocks=$(( filled / 8 ))
  local remainder=$(( filled % 8 ))
  local empty=$(( width - full_blocks - (remainder > 0 ? 1 : 0) ))

  local eighth=('█' '▏' '▎' '▍' '▌' '▋' '▊' '▉')
  local bar=""
  for ((i=0; i<full_blocks; i++)); do bar+="█"; done
  if (( remainder > 0 )); then
    bar+="${eighth[$remainder]}"
  fi
  for ((i=0; i<empty; i++)); do bar+="░"; done
  printf '%s' "$bar"
}

# ── TUI: Generic box drawing ────────────────────────────────────────────────

# draw_box title color width lines...
# Usage: draw_box "My Title" "$C_INFO" 60 "line 1" "line 2" "line 3"
draw_box() {
  local title="$1" color="$2" width="$3"
  shift 3

  local inner=$((width - 2))
  local title_len=${#title}
  local pad=$((inner - title_len - 2))
  (( pad < 0 )) && pad=0

  local hline=""
  for ((i=0; i<pad; i++)); do hline+="─"; done

  printf "${color}╭─ %s ${C_RESET}${C_DIM}%s${C_RESET}${color}╮${C_RESET}\n" "$title" "$hline"

  for line in "$@"; do
    local line_len=${#line}
    local rpad=$((inner - line_len))
    (( rpad < 0 )) && rpad=0
    local spaces=""
    for ((i=0; i<rpad; i++)); do spaces+=" "; done
    printf "${color}│${C_RESET} %s%s${color}│${C_RESET}\n" "$line" "$spaces"
  done

  local bline=""
  for ((i=0; i<inner; i++)); do bline+="─"; done
  printf "${color}╰%s╯${C_RESET}\n" "$bline"
}

# ── TUI: Status bar + detail panel ───────────────────────────────────────────

# Renders bottom status bar at current cursor position
render_status_bar() {
  local sel_count=$1 sel_kb=$2 total_count=$3 total_kb=$4
  printf "  ${C_BOLD}Selected: %d items (%s)${C_RESET}  ${C_DIM}│${C_RESET}  ${C_DIM}Total found: %d items (%s)${C_RESET}\n" \
    "$sel_count" "$(fmt "$sel_kb")" "$total_count" "$(fmt "$total_kb")"
  printf "  ${C_DIM}↑↓ Navigate  ␣ Toggle  → Expand  ← Collapse  ⏎ Confirm  s Sort  / Search  q Quit${C_RESET}\n"
}

# Renders detail panel for highlighted item
render_detail_panel() {
  local idx=$1
  local name="${T_NAMES[$idx]}"
  local path="${T_PATHS[$idx]}"
  local tag="${T_RISKS[$idx]}"
  local cat="${T_CATS[$idx]}"
  local kb="${T_SIZES[$idx]}"
  local rc
  rc=$(risk_color "$tag")

  local size_str
  size_str=$(fmt "$kb")

  # Last modified
  local mtime="unknown"
  if [[ -e "$path" ]]; then
    mtime=$(stat -f "%Sm" -t "%Y-%m-%d" "$path" 2>/dev/null || echo "unknown")
  fi

  local desc=""
  case "$tag" in
    SAFE)     desc="Regenerates without effort" ;;
    REBUILD)  desc="Costly to reconstruct from backup" ;;
    PERSONAL) desc="User data — shown for awareness only" ;;
  esac

  draw_box "$name" "$rc" "$((TERM_COLS > 70 ? 66 : TERM_COLS - 4))" \
    "Risk: $(risk_icon "$tag") $tag — $desc" \
    "Path: $path" \
    "Size: $size_str" \
    "Category: $cat" \
    "Last modified: $mtime"
}

# ── Interactive selector ─────────────────────────────────────────────────────

interactive_select() {
  local num=${#SORTED[@]}

  # Build category tree structure
  declare -a _tree_cat_order=()    # unique cats in order
  declare -A _tree_cat_items=()    # cat → "sorted_idx1,sorted_idx2,..."
  declare -A _tree_cat_kb=()       # cat → total kb
  declare -A _tree_cat_collapsed=() # cat → 0/1
  declare -A _tree_cat_max=()      # cat → max item kb (for bars)

  for ((si=0; si<num; si++)); do
    local real_idx="${SORTED[$si]#*|}"
    local cat="${T_CATS[$real_idx]}"
    if [[ -z "${_tree_cat_items[$cat]+x}" ]]; then
      _tree_cat_order+=("$cat")
      _tree_cat_items[$cat]=""
      _tree_cat_kb[$cat]=0
      _tree_cat_collapsed[$cat]=0
      _tree_cat_max[$cat]=0
    fi
    if [[ -n "${_tree_cat_items[$cat]}" ]]; then
      _tree_cat_items[$cat]+=","
    fi
    _tree_cat_items[$cat]+="$si"
    _tree_cat_kb[$cat]=$(( ${_tree_cat_kb[$cat]} + T_SIZES[$real_idx] ))
    (( T_SIZES[$real_idx] > _tree_cat_max[$cat] )) && _tree_cat_max[$cat]=${T_SIZES[$real_idx]}
  done

  # Select all by default
  for ((i=0; i<num; i++)); do SELECTED[$i]=1; done

  # Build flat visible-row list
  # Each row is "cat:CAT_NAME" or "item:SORTED_IDX"
  build_visible_rows() {
    _visible_rows=()
    for cat in "${_tree_cat_order[@]}"; do
      _visible_rows+=("cat:$cat")
      if [[ "${_tree_cat_collapsed[$cat]}" == "0" ]]; then
        IFS=',' read -ra items <<< "${_tree_cat_items[$cat]}"
        for si in "${items[@]}"; do
          _visible_rows+=("item:$si")
        done
      fi
    done
  }

  declare -a _visible_rows=()
  build_visible_rows
  local cursor=0

  # TUI setup
  detect_term_size
  tput civis 2>/dev/null
  stty -echo -icanon 2>/dev/null
  trap 'tput cnorm 2>/dev/null; stty sane 2>/dev/null' EXIT INT TERM

  draw_tree() {
    # Move to top if redrawing
    [[ "${1:-}" == "redraw" ]] && printf '\033[%dA' "$_last_draw_lines"

    local sel_kb=0 sel_count=0
    for ((i=0; i<num; i++)); do
      if [[ "${SELECTED[$i]}" == "1" ]]; then
        local ri="${SORTED[$i]#*|}"
        sel_kb=$((sel_kb + T_SIZES[$ri]))
        ((sel_count++)) || true
      fi
    done

    local drawn=0
    for ((r=0; r<${#_visible_rows[@]}; r++)); do
      local row="${_visible_rows[$r]}"
      local row_type="${row%%:*}"
      local row_val="${row#*:}"
      local is_cursor=""
      (( r == cursor )) && is_cursor=">"

      if [[ "$row_type" == "cat" ]]; then
        local cat="$row_val"
        local arrow
        [[ "${_tree_cat_collapsed[$cat]}" == "0" ]] && arrow="▼" || arrow="▶"
        local cat_size
        cat_size=$(fmt "${_tree_cat_kb[$cat]}")
        # Count items in category
        IFS=',' read -ra _citems <<< "${_tree_cat_items[$cat]}"
        local ccount=${#_citems[@]}

        if [[ -n "$is_cursor" ]]; then
          printf "  ${C_BOLD}${C_INFO}%s %s %s${C_RESET}  ${C_DIM}(%s, %d items)${C_RESET}\033[K\n" \
            "$is_cursor" "$arrow" "$cat" "$cat_size" "$ccount"
        else
          printf "  ${C_BOLD}  %s %s${C_RESET}  ${C_DIM}(%s, %d items)${C_RESET}\033[K\n" \
            "$arrow" "$cat" "$cat_size" "$ccount"
        fi
      else
        local si="$row_val"
        local ri="${SORTED[$si]#*|}"
        local name="${T_NAMES[$ri]}"
        (( ${#name} > 28 )) && name="${name:0:25}..."
        local sf
        if [[ "${T_METHODS[$ri]}" == "tm-thin" ]]; then
          sf="${TM_SNAP_COUNT} snaps"
        else
          sf=$(fmt "${T_SIZES[$ri]}")
        fi
        local tag="${T_RISKS[$ri]}"
        local rc
        rc=$(risk_color "$tag")
        local icon
        icon=$(risk_icon "$tag")
        local cat="${T_CATS[$ri]}"
        local bar
        bar=$(draw_bar "${T_SIZES[$ri]}" "${_tree_cat_max[$cat]}" 8)

        local check="[ ]"
        [[ "${SELECTED[$si]}" == "1" ]] && check="[x]"

        if [[ -n "$is_cursor" ]]; then
          printf "  ${C_BOLD}${C_INFO}>   ${check}${C_RESET} %-28s %10s %s %s ${rc}${C_BOLD}%-8s${C_RESET}\033[K\n" \
            "$name" "$sf" "$bar" "$icon" "$tag"
        else
          printf "      ${check} %-28s %10s %s %s ${rc}%-8s${C_RESET}\033[K\n" \
            "$name" "$sf" "$bar" "$icon" "$tag"
        fi
      fi
      ((drawn++))
    done

    # Status bar
    printf "\033[K\n"
    printf "  ${C_BOLD}Selected: %d/%d items — %s${C_RESET}\033[K\n" "$sel_count" "$num" "$(fmt $sel_kb)"
    printf "  ${C_DIM}↑↓ move  ␣ toggle  →/← expand/collapse  A all  N none  ⏎ confirm  q quit${C_RESET}\033[K\n"
    drawn=$((drawn + 3))

    # Detail panel for current item (only if cursor is on an item)
    local crow="${_visible_rows[$cursor]}"
    if [[ "${crow%%:*}" == "item" ]]; then
      local csi="${crow#*:}"
      local cri="${SORTED[$csi]#*|}"
      printf "\033[K\n"
      printf "  "; render_detail_panel "$cri"
      # Count lines in detail panel (box title + 5 content lines + bottom = 7)
      drawn=$((drawn + 8))
    fi

    _last_draw_lines=$drawn
  }

  local _last_draw_lines=0
  draw_tree

  while true; do
    IFS= read -rsn1 key
    case "$key" in
      $'\x1b')
        read -rsn2 seq
        case "$seq" in
          '[A') # Up
            (( cursor > 0 )) && ((cursor--))
            ;;
          '[B') # Down
            (( cursor < ${#_visible_rows[@]} - 1 )) && ((cursor++))
            ;;
          '[C') # Right — expand category
            local crow="${_visible_rows[$cursor]}"
            if [[ "${crow%%:*}" == "cat" ]]; then
              _tree_cat_collapsed["${crow#*:}"]=0
              build_visible_rows
            fi
            ;;
          '[D') # Left — collapse category
            local crow="${_visible_rows[$cursor]}"
            if [[ "${crow%%:*}" == "cat" ]]; then
              _tree_cat_collapsed["${crow#*:}"]=1
              build_visible_rows
            elif [[ "${crow%%:*}" == "item" ]]; then
              # Find parent category and collapse it
              local csi="${crow#*:}"
              local cri="${SORTED[$csi]#*|}"
              local ccat="${T_CATS[$cri]}"
              _tree_cat_collapsed["$ccat"]=1
              build_visible_rows
              # Move cursor to the category header
              for ((r=0; r<${#_visible_rows[@]}; r++)); do
                [[ "${_visible_rows[$r]}" == "cat:$ccat" ]] && { cursor=$r; break; }
              done
            fi
            ;;
        esac
        ;;
      ' ') # Toggle
        local crow="${_visible_rows[$cursor]}"
        if [[ "${crow%%:*}" == "item" ]]; then
          local csi="${crow#*:}"
          if [[ "${SELECTED[$csi]}" == "1" ]]; then
            SELECTED[$csi]=0
          else
            SELECTED[$csi]=1
          fi
        elif [[ "${crow%%:*}" == "cat" ]]; then
          # Toggle all items in category
          local ccat="${crow#*:}"
          IFS=',' read -ra _citems <<< "${_tree_cat_items[$ccat]}"
          # Check if all selected — if so, deselect all; otherwise select all
          local all_sel=true
          for csi in "${_citems[@]}"; do
            [[ "${SELECTED[$csi]}" != "1" ]] && all_sel=false && break
          done
          local new_val=1
          $all_sel && new_val=0
          for csi in "${_citems[@]}"; do SELECTED[$csi]=$new_val; done
        fi
        ;;
      'a'|'A') for ((i=0; i<num; i++)); do SELECTED[$i]=1; done ;;
      'n'|'N') for ((i=0; i<num; i++)); do SELECTED[$i]=0; done ;;
      ''|$'\n') break ;;
      'q'|'Q')
        tput cnorm 2>/dev/null
        stty sane 2>/dev/null
        echo ""
        printf "  ${C_DIM}Cancelled. Nothing was deleted.${C_RESET}\n"
        exit 0
        ;;
    esac
    draw_tree "redraw"
  done

  tput cnorm 2>/dev/null
  stty sane 2>/dev/null
}

# ── Banner ───────────────────────────────────────────────────────────────────

log "\n"
log "  "; draw_box "diskdoc v${VERSION}" "$C_INFO" 60 \
  "macOS Disk Cleanup CLI" \
  "${MACOS_CODENAME} (${MACOS_MAJOR}.${MACOS_MINOR})"
log "\n"

# ── Initial disk state ───────────────────────────────────────────────────────
DISK_LINE=$(df -k / | tail -1)
DISK_TOTAL=$(echo "$DISK_LINE" | awk '{print $2}')
DISK_AVAIL_BEFORE=$(echo "$DISK_LINE" | awk '{print $4}')
DISK_USED_BEFORE=$((DISK_TOTAL - DISK_AVAIL_BEFORE))
PCT_FREE_NOW=$((DISK_AVAIL_BEFORE * 100 / DISK_TOTAL))

log "  ${DIM}Disk:${NC}  %s total  |  %s free (%d%%)  |  %s used\n" \
  "$(fmt "$DISK_TOTAL")" "$(fmt "$DISK_AVAIL_BEFORE")" "$PCT_FREE_NOW" "$(fmt "$DISK_USED_BEFORE")"

if [[ "$PROFILE" != "all" ]]; then
  log "  ${DIM}Profile:${NC} ${BOLD}%s${NC}\n" "$PROFILE"
fi

if (( MIN_SIZE_MB != 50 )); then
  log "  ${DIM}Min size:${NC} ${BOLD}%d MB${NC}\n" "$MIN_SIZE_MB"
fi

if [[ ${#EXCLUDES[@]} -gt 0 ]]; then
  log "  ${DIM}Exclusions:${NC} %d paths from ~/.diskdocrc\n" "${#EXCLUDES[@]}"
fi

SCAN_START=$(date +%s)
log "\n"

# ── Code directories (shared by node_modules + Rust scans) ──────────────────
CODE_DIRS=("$HOME/code" "$HOME/projects" "$HOME/dev" "$HOME/src" "$HOME/repos" "$HOME/workspace" "$HOME/work" "$HOME/Developer")

# ════════════════════════════════════════════════════════════════════════════
# ★ HIGHLIGHTED: APFS Snapshots + iOS Backups (top priority items)
# ════════════════════════════════════════════════════════════════════════════

TM_SNAP_COUNT=0
if matches_profile "System"; then
  # ── ★ APFS Time Machine Snapshots ──
  snap_list=$(tmutil listlocalsnapshots / 2>/dev/null | grep "com.apple.TimeMachine" || true)
  if [[ -n "$snap_list" ]]; then
    TM_SNAP_COUNT=$(echo "$snap_list" | wc -l | tr -d ' ')
  fi

  if (( TM_SNAP_COUNT > 0 )); then
    log "\n  ${YELLOW}${BOLD}┌ ★ APFS Snapshots ${NC}${DIM}─────────────────────────────────────${NC}\n"
    log "  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "Time Machine local snapshots" "${TM_SNAP_COUNT} snaps"

    T_NAMES+=("★ TM Snapshots (${TM_SNAP_COUNT})")
    T_PATHS+=("__tmutil__")
    T_SIZES+=("0")
    T_CATS+=("System")
    T_RISKS+=("SAFE")
    T_METHODS+=("tm-thin")

    log "  ${DIM}└─── ${TM_SNAP_COUNT} hourly snapshots eating hidden space${NC}\n"
  else
    log "\n  ${DIM}┌ ★ APFS Snapshots ─────────────────────────────────────${NC}\n"
    log "  ${DIM}└─── no local snapshots${NC}\n"
  fi

  # ── ★ iOS/iPadOS Backups ──
  log "\n  ${YELLOW}${BOLD}┌ ★ iOS/iPadOS Backups ${NC}${DIM}──────────────────────────────────${NC}\n"
  scan_target "★ iOS/iPadOS Backups" "$HOME/Library/Application Support/MobileSync/Backup" "System" "SAFE" "rm"
  ios_found=0; ios_kb=0
  for ((i=0; i<${#T_NAMES[@]}; i++)); do
    [[ "${T_NAMES[$i]}" == "★ iOS"* ]] && ((ios_found++)) && ios_kb=$((ios_kb + T_SIZES[$i]))
  done
  cat_footer "$ios_found" "$ios_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE 1: System
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "System"; then
  cat_header "System" "$YELLOW"

  NEEDS_SUDO=false
  # idleassetsd and system logs need sudo
  if ! is_excluded "/private/var/folders" || ! is_excluded "/private/var/log"; then
    NEEDS_SUDO=true
  fi

  if [[ "$NEEDS_SUDO" == true ]]; then
    log "  │  ${YELLOW}⚠${NC}  ${DIM}System scan needs admin access. You may be prompted for your password.${NC}\n"
  fi

  scan_target "Trash" "$HOME/.Trash" "System" "SAFE" "rm"

  # Apple Screensavers (idleassetsd) — requires sudo + special path search
  if ! is_excluded "/private/var/folders"; then
    log "\r\033[K  │  ${DIM}…${NC}  %-44s" "Apple Screensavers (idleassetsd)"
    IDLE_PATH=$(sudo find /private/var/folders -name "com.apple.idleassetsd" -maxdepth 6 2>/dev/null | head -1)
    if [[ -n "$IDLE_PATH" ]]; then
      idle_kb=$(get_kb_sudo "$IDLE_PATH")
      if (( idle_kb > MIN_SIZE_KB )); then
        T_NAMES+=("Apple Screensavers (idleassetsd)")
        T_PATHS+=("$IDLE_PATH")
        T_SIZES+=("$idle_kb")
        T_CATS+=("System")
        T_RISKS+=("SAFE")
        T_METHODS+=("rm-sudo")
        FOUND_TOTAL=$((FOUND_TOTAL + idle_kb))
        log "\r\033[K  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "Apple Screensavers (idleassetsd)" "$(fmt "$idle_kb")"
      else
        log "\r\033[K  │  ${DIM}·${NC}  ${DIM}%-44s${NC}\n" "Apple Screensavers (idleassetsd)"
      fi
    else
      log "\r\033[K  │  ${DIM}·${NC}  ${DIM}%-44s${NC}\n" "Apple Screensavers (idleassetsd)"
    fi
  fi

  # Category totals
  sys_count=0; sys_kb=0
  for ((i=0; i<${#T_CATS[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "System" ]] && ((sys_count++)) && sys_kb=$((sys_kb + T_SIZES[$i]))
  done
  cat_footer "$sys_count" "$sys_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE 2: Apple Intelligence / ML Assets
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "System"; then
  cat_header "Apple Intelligence / ML" "$MAGENTA"
  ai_start=${#T_NAMES[@]}

  # Static known paths
  scan_target "Siri Caches"         "$HOME/Library/Caches/com.apple.siri.embeddings" "System" "SAFE" "rm"

  # Dynamic scan: /System/Library/AssetsV2/* > 100 MB
  if [[ -d "/System/Library/AssetsV2" ]]; then
    while IFS=$'\t' read -r kb path; do
      [[ -z "$kb" || -z "$path" ]] && continue
      kb=$(echo "$kb" | tr -d '[:space:]')
      base=$(basename "$path")
      (( kb > 102400 )) || continue  # > 100 MB
      is_excluded "$path" && continue

      T_NAMES+=("ML Asset: $base")
      T_PATHS+=("$path")
      T_SIZES+=("$kb")
      T_CATS+=("System")
      T_RISKS+=("SAFE")
      T_METHODS+=("rm-sudo")
      FOUND_TOTAL=$((FOUND_TOTAL + kb))
      log "  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "ML Asset: $base" "$(fmt "$kb")"
    done < <(sudo du -sk /System/Library/AssetsV2/*/ 2>/dev/null | sort -nr)
  fi

  # Dynamic scan: /private/var/MobileAsset/AssetsV2/* > 100 MB
  if sudo test -d "/private/var/MobileAsset/AssetsV2" 2>/dev/null; then
    while IFS=$'\t' read -r kb path; do
      [[ -z "$kb" || -z "$path" ]] && continue
      kb=$(echo "$kb" | tr -d '[:space:]')
      base=$(basename "$path")
      (( kb > 102400 )) || continue
      is_excluded "$path" && continue

      T_NAMES+=("Mobile Asset: $base")
      T_PATHS+=("$path")
      T_SIZES+=("$kb")
      T_CATS+=("System")
      T_RISKS+=("SAFE")
      T_METHODS+=("rm-sudo")
      FOUND_TOTAL=$((FOUND_TOTAL + kb))
      log "  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "Mobile Asset: $base" "$(fmt "$kb")"
    done < <(sudo du -sk /private/var/MobileAsset/AssetsV2/*/ 2>/dev/null | sort -nr)
  fi

  # Apple system assets
  if sudo test -d "/Library/Apple/System/Library/Assets" 2>/dev/null; then
    scan_target "Apple System Assets" "/Library/Apple/System/Library/Assets" "System" "SAFE" "rm-sudo"
  fi

  ai_count=0; ai_kb=0
  for ((i=ai_start; i<${#T_NAMES[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "System" ]] && ((ai_count++)) && ai_kb=$((ai_kb + T_SIZES[$i]))
  done
  cat_footer "$ai_count" "$ai_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE 3: Dev Tools
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "Dev Tools"; then
  cat_header "Dev Tools" "$CYAN"
  dev_start=${#T_NAMES[@]}

  # Xcode
  scan_target "Xcode DerivedData"        "$HOME/Library/Developer/Xcode/DerivedData"         "Dev Tools" "SAFE" "rm"
  scan_target "Xcode Archives"           "$HOME/Library/Developer/Xcode/Archives"            "Dev Tools" "SAFE" "rm"
  scan_target "Xcode iOS DeviceSupport"  "$HOME/Library/Developer/Xcode/iOS DeviceSupport"   "Dev Tools" "SAFE" "rm"
  scan_target "Xcode watchOS Support"    "$HOME/Library/Developer/Xcode/watchOS DeviceSupport" "Dev Tools" "SAFE" "rm"
  scan_target "Xcode macOS Support"      "$HOME/Library/Developer/Xcode/macOS DeviceSupport" "Dev Tools" "SAFE" "rm"
  scan_target "Xcode Products"           "$HOME/Library/Developer/Xcode/Products"            "Dev Tools" "SAFE" "rm"
  scan_target "Xcode Cache"              "$HOME/Library/Caches/com.apple.dt.Xcode"           "Dev Tools" "SAFE" "rm"
  scan_target "iOS Simulators"           "$HOME/Library/Developer/CoreSimulator"              "Dev Tools" "SAFE" "rm"
  scan_target "Simulator Volumes"        "/Library/Developer/CoreSimulator/Volumes"           "Dev Tools" "SAFE" "rm-sudo"
  scan_target "Simulator Runtimes"       "/Library/Developer/CoreSimulator/Profiles/Runtimes" "Dev Tools" "SAFE" "rm-sudo"

  # Delete unavailable simulators if xcrun is available
  if has_cmd xcrun; then
    log "\r\033[K  │  ${DIM}…${NC}  %-44s" "Unavailable Simulators"
    unavail_count=$(xcrun simctl list devices unavailable 2>/dev/null | grep -c "unavailable" || true)
    if (( unavail_count > 0 )); then
      T_NAMES+=("Unavailable Simulators (${unavail_count})")
      T_PATHS+=("__xcrun_simctl__")
      T_SIZES+=("0")
      T_CATS+=("Dev Tools")
      T_RISKS+=("SAFE")
      T_METHODS+=("xcrun-sim")
      log "\r\033[K  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "Unavailable Simulators" "${unavail_count} devs"
    else
      log "\r\033[K  │  ${DIM}·${NC}  ${DIM}%-44s${NC}\n" "Unavailable Simulators"
    fi
  fi

  # Other dev tools
  scan_target "Android SDK"         "$HOME/Library/Android"                         "Dev Tools" "SAFE" "rm"
  scan_target "CocoaPods Cache"     "$HOME/Library/Caches/CocoaPods"               "Dev Tools" "SAFE" "rm"

  # node_modules search across code directories
  for code_dir in "${CODE_DIRS[@]}"; do
    [[ -d "$code_dir" ]] || continue
    dir_name="$(basename "$code_dir")"
    matches_profile "Dev Tools" || continue
    is_excluded "$code_dir" && continue

    log "\r\033[K  │  ${DIM}…${NC}  %-44s" "node_modules (~/$dir_name)"
    nm_kb=$(find "$code_dir" -name "node_modules" -maxdepth 4 -type d -exec du -sk {} + 2>/dev/null | awk '{s+=$1} END {print s+0}')
    if (( nm_kb > MIN_SIZE_KB )); then
      T_NAMES+=("node_modules (~/$dir_name)")
      T_PATHS+=("$code_dir")
      T_SIZES+=("$nm_kb")
      T_CATS+=("Dev Tools")
      T_RISKS+=("SAFE")
      T_METHODS+=("find-nm")
      FOUND_TOTAL=$((FOUND_TOTAL + nm_kb))
      log "\r\033[K  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "node_modules (~/$dir_name)" "$(fmt "$nm_kb")"
    else
      log "\r\033[K  │  ${DIM}·${NC}  ${DIM}%-44s${NC}\n" "node_modules (~/$dir_name)"
    fi
  done

  # Rust target/ directories across code directories
  for code_dir in "${CODE_DIRS[@]}"; do
    [[ -d "$code_dir" ]] || continue
    dir_name="$(basename "$code_dir")"
    is_excluded "$code_dir" && continue

    log "\r\033[K  │  ${DIM}…${NC}  %-44s" "Rust targets (~/$dir_name)"
    rust_kb=0
    rust_found=false
    while IFS= read -r cargo_file; do
      target_dir="$(dirname "$cargo_file")/target"
      if [[ -d "$target_dir" ]]; then
        kb=$(get_kb "$target_dir")
        rust_kb=$((rust_kb + kb))
        rust_found=true
      fi
    done < <(find "$code_dir" -name "Cargo.toml" -maxdepth 5 2>/dev/null)

    if $rust_found && (( rust_kb > MIN_SIZE_KB )); then
      T_NAMES+=("Rust targets (~/$dir_name)")
      T_PATHS+=("$code_dir")
      T_SIZES+=("$rust_kb")
      T_CATS+=("Dev Tools")
      T_RISKS+=("SAFE")
      T_METHODS+=("find-rust")
      FOUND_TOTAL=$((FOUND_TOTAL + rust_kb))
      log "\r\033[K  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "Rust targets (~/$dir_name)" "$(fmt "$rust_kb")"
    else
      log "\r\033[K  │  ${DIM}·${NC}  ${DIM}%-44s${NC}\n" "Rust targets (~/$dir_name)"
    fi
  done

  dev_count=0; dev_kb=0
  for ((i=dev_start; i<${#T_CATS[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "Dev Tools" ]] && ((dev_count++)) && dev_kb=$((dev_kb + T_SIZES[$i]))
  done
  cat_footer "$dev_count" "$dev_kb"
fi

