  done < <(find "$HOME/Movies/DaVinci Resolve" -name "CacheClip" -type d 2>/dev/null)
  scan_target "Resolve Support" "$HOME/Library/Application Support/Blackmagic Design/DaVinci Resolve" "Creative" "SAFE" "rm"

  cr_count=0; cr_kb=0
