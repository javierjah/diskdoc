  scan_target "Ruby Gems"           "$HOME/.gem"                     "Dev Tools" "SAFE" "rm"
  scan_target "Bundler Cache"       "$HOME/.bundle/cache"            "Dev Tools" "SAFE" "rm"

  # Android
