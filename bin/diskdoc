#!/usr/bin/env bash
# ============================================================================
# diskdoc — macOS Disk Cleanup CLI
# https://github.com/javierjah/diskdoc
#
# Scans your Mac for space hogs, presents a table, asks for confirmation,
# cleans everything, and shows a detailed report.
#
# Usage:
#   diskdoc           Interactive mode (asks before deleting)
#   diskdoc --auto    Automatic mode (no confirmation)
#   diskdoc --scan    Scan only, don't delete anything
# ============================================================================
set -uo pipefail

VERSION="1.0.0"

# ── Colors ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# Disable colors if not a terminal
if [[ ! -t 1 ]]; then
  RED='' GREEN='' YELLOW='' CYAN='' MAGENTA='' BOLD='' DIM='' NC=''
fi

# ── Flags ────────────────────────────────────────────────────────────────────
AUTO_MODE=false
SCAN_ONLY=false

for arg in "$@"; do
  case "$arg" in
    --auto)    AUTO_MODE=true ;;
    --scan)    SCAN_ONLY=true ;;
    --version|-v)
      echo "diskdoc $VERSION"
      exit 0
      ;;
    --help|-h)
      cat <<'HELP'
diskdoc — macOS Disk Cleanup CLI

Usage:
  diskdoc              Interactive (scan, confirm, clean)
  diskdoc --scan       Scan only, show what can be cleaned
  diskdoc --auto       Clean without asking for confirmation
  diskdoc --version    Show version
  diskdoc --help       Show this help

What it cleans:
  - Apple screensaver cache (idleassetsd) — can grow to 100GB+
  - Docker images, containers, and volumes
  - Xcode DerivedData and iOS Simulators
  - Android SDK
  - Application caches (Spotify, Chrome, Edge, Slack, etc.)
  - node_modules across your code directories
  - Package manager caches (npm, pnpm, Homebrew)
  - Trash

All targets are safe to remove — they are caches, build artifacts,
or regenerable data. Nothing personal is ever deleted.

More info: https://github.com/javierjah/diskdoc
HELP
      exit 0
      ;;
    *)
      echo "Unknown option: $arg"
      echo "Run 'diskdoc --help' for usage."
      exit 1
      ;;
  esac
done

# ── Require macOS ────────────────────────────────────────────────────────────
if [[ "$(uname)" != "Darwin" ]]; then
  echo "diskdoc only runs on macOS."
  exit 1
fi

# ── Result arrays ────────────────────────────────────────────────────────────
declare -a T_NAMES=()
declare -a T_PATHS=()
declare -a T_SIZES=()
declare -a T_CATS=()
declare -a T_RISKS=()
declare -a T_METHODS=()
declare -a SELECTED=()

# ── Helpers ──────────────────────────────────────────────────────────────────

get_kb() {
  local p="$1"
  [[ -d "$p" ]] && du -sk "$p" 2>/dev/null | awk '{print $1}' || echo 0
}

get_kb_sudo() {
  local p="$1"
  sudo test -d "$p" 2>/dev/null && sudo du -sk "$p" 2>/dev/null | awk '{print $1}' || echo 0
}

fmt() {
  local kb=$1
  if (( kb >= 1048576 )); then
    awk "BEGIN {printf \"%.1f GB\", $kb/1048576}"
  elif (( kb >= 1024 )); then
    awk "BEGIN {printf \"%.0f MB\", $kb/1024}"
  else
    echo "${kb} KB"
  fi
}

add() {
  local name="$1" path="$2" cat="$3" risk="$4" method="${5:-rm}"
  local kb=0

  case "$method" in
    rm-sudo)       kb=$(get_kb_sudo "$path") ;;
    find-nm)       kb=$(find "$path" -name "node_modules" -maxdepth 4 -type d -exec du -sk {} + 2>/dev/null | awk '{s+=$1} END {print s+0}') ;;
    npm-cache)     kb=$(get_kb "$HOME/.npm") ;;
    pnpm-prune)    kb=$(get_kb "$HOME/Library/pnpm/store") ;;
    brew-cleanup)  kb=$(get_kb "$HOME/Library/Caches/Homebrew") ;;
    *)             kb=$(get_kb "$path") ;;
  esac

  if (( kb > 51200 )); then
    T_NAMES+=("$name")
    T_PATHS+=("$path")
    T_SIZES+=("$kb")
    T_CATS+=("$cat")
    T_RISKS+=("$risk")
    T_METHODS+=("$method")
  fi
}

has_cmd() { command -v "$1" &>/dev/null; }

interactive_select() {
  local num=${#SORTED[@]}
  local cursor=0
  local total_lines=$((num + 3))

  # All selected by default
  for ((i=0; i<num; i++)); do SELECTED[$i]=1; done

  # Save terminal state
  tput civis 2>/dev/null
  stty -echo 2>/dev/null
  trap 'tput cnorm 2>/dev/null; stty echo 2>/dev/null' EXIT INT TERM

  draw_selector() {
    # On redraws, move cursor back up to overwrite
    [[ "${1:-}" == "redraw" ]] && printf '\033[%dA' "$total_lines"

    local sel_kb=0
    local sel_count=0

    for ((i=0; i<num; i++)); do
      local entry="${SORTED[$i]}"
      local idx="${entry#*|}"
      local name="${T_NAMES[$idx]}"
      (( ${#name} > 34 )) && name="${name:0:31}..."
      local sf
      sf=$(fmt "${T_SIZES[$idx]}")

      local check="[ ]"
      if [[ "${SELECTED[$i]}" == "1" ]]; then
        check="[x]"
        sel_kb=$((sel_kb + T_SIZES[$idx]))
        ((sel_count++)) || true
      fi

      if (( i == cursor )); then
        printf "  ${BOLD}${CYAN}> ${check} %-34s %10s${NC}\033[K\n" "$name" "$sf"
      else
        printf "    ${check} %-34s %10s\033[K\n" "$name" "$sf"
      fi
    done

    printf "\033[K\n"
    printf "  ${BOLD}Selected: ${sel_count}/${num} items — $(fmt $sel_kb)${NC}\033[K\n"
    printf "  ${DIM}arrows=move  space=toggle  a=all  n=none  enter=confirm  q=cancel${NC}\033[K\n"
  }

  # First draw
  draw_selector

  # Input loop
  while true; do
    IFS= read -rsn1 key

    case "$key" in
      $'\x1b')
        read -rsn2 seq
        case "$seq" in
          '[A') (( cursor > 0 )) && ((cursor--)) ;;
          '[B') (( cursor < num - 1 )) && ((cursor++)) ;;
        esac
        ;;
      ' ')
        if [[ "${SELECTED[$cursor]}" == "1" ]]; then
          SELECTED[$cursor]=0
        else
          SELECTED[$cursor]=1
        fi
        ;;
      'a'|'A')
        for ((i=0; i<num; i++)); do SELECTED[$i]=1; done
        ;;
      'n'|'N')
        for ((i=0; i<num; i++)); do SELECTED[$i]=0; done
        ;;
      ''|$'\n')
        break
        ;;
      'q'|'Q')
        tput cnorm 2>/dev/null
        stty echo 2>/dev/null
        echo ""
        echo -e "  ${DIM}Cancelled. Nothing was deleted.${NC}"
        exit 0
        ;;
    esac

    draw_selector "redraw"
  done

  # Restore terminal
  tput cnorm 2>/dev/null
  stty echo 2>/dev/null
}

# ── Banner ───────────────────────────────────────────────────────────────────

clear
echo ""
echo -e "${BOLD}${CYAN}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${NC}"
echo -e "${BOLD}${CYAN}┃              diskdoc v${VERSION}                                 ┃${NC}"
echo -e "${BOLD}${CYAN}┃          macOS Disk Cleanup CLI                              ┃${NC}"
echo -e "${BOLD}${CYAN}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${NC}"
echo ""

# ── Initial disk state ───────────────────────────────────────────────────────
DISK_LINE=$(df -k / | tail -1)
DISK_TOTAL=$(echo "$DISK_LINE" | awk '{print $2}')
DISK_AVAIL_BEFORE=$(echo "$DISK_LINE" | awk '{print $4}')
DISK_USED_BEFORE=$((DISK_TOTAL - DISK_AVAIL_BEFORE))

echo -e "  ${DIM}Disk:${NC}  $(fmt $DISK_TOTAL) total  |  $(fmt $DISK_AVAIL_BEFORE) free  |  $(fmt $DISK_USED_BEFORE) used"
echo ""
echo -e "  ${YELLOW}Scanning disk... this may take a moment${NC}"
echo ""

# ── Phase 1: System targets (may need sudo) ─────────────────────────────────

IDLE_PATH=$(sudo find /private/var/folders -name "com.apple.idleassetsd" -maxdepth 6 2>/dev/null | head -1)
[[ -n "$IDLE_PATH" ]] && add "Apple Screensavers (idleassetsd)" "$IDLE_PATH" "System" "Safe — re-downloads" "rm-sudo"

add "Trash" "$HOME/.Trash" "System" "Safe" "rm"

# ── Phase 2: Large app data ─────────────────────────────────────────────────

add "Docker Data"           "$HOME/Library/Containers/com.docker.docker/Data"       "App"       "Recreated on launch"   "rm"
add "iOS Simulators"        "$HOME/Library/Developer/CoreSimulator"                 "Dev Tools" "Recreated by Xcode"    "rm"
add "Xcode DerivedData"     "$HOME/Library/Developer/Xcode/DerivedData"             "Dev Tools" "Safe — build cache"    "rm"
add "Android SDK"           "$HOME/Library/Android"                                 "Dev Tools" "Reinstall if needed"   "rm"
add "Claude VM Bundles"     "$HOME/Library/Application Support/Claude/vm_bundles"   "App"       "Re-downloads on open"  "rm"
add "Claude Cache"          "$HOME/Library/Application Support/Claude/Cache"        "App"       "Safe"                  "rm"
add "Claude Code Cache"     "$HOME/Library/Application Support/Claude/Code Cache"   "App"       "Safe"                  "rm"
add "ChatGPT App Data"      "$HOME/Library/Application Support/com.openai.atlas"    "App"       "Recreated on open"     "rm"
add "Kiro Data"             "$HOME/Library/Application Support/Kiro"                "App"       "Remove if unused"      "rm"
add "Windsurf Data"         "$HOME/Library/Application Support/Windsurf"            "App"       "Remove if unused"      "rm"
add "Cursor Data"           "$HOME/Library/Application Support/Cursor"              "App"       "Remove if unused"      "rm"

# ── Phase 3: Dynamic cache scan ─────────────────────────────────────────────

if [[ -d "$HOME/Library/Caches" ]]; then
  while IFS=$'\t' read -r size path; do
    base=$(basename "$path")
    name="Cache: $base"

    already=false
    for existing in "${T_PATHS[@]+"${T_PATHS[@]}"}"; do
      [[ "$existing" == "$path" ]] && already=true && break
    done
    $already && continue

    kb=$(echo "$size" | tr -d '[:space:]')
    if (( kb > 51200 )); then
      T_NAMES+=("$name")
      T_PATHS+=("$path")
      T_SIZES+=("$kb")
      T_CATS+=("Cache")
      T_RISKS+=("Safe — regenerates")
      T_METHODS+=("rm")
    fi
  done < <(du -sk "$HOME/Library/Caches/"* 2>/dev/null)
fi

# ── Phase 4: Code directories — node_modules ────────────────────────────────

for code_dir in "$HOME/code" "$HOME/projects" "$HOME/dev" "$HOME/src" "$HOME/repos" "$HOME/workspace" "$HOME/work"; do
  [[ -d "$code_dir" ]] && add "node_modules ($(basename "$code_dir"))" "$code_dir" "Dev Tools" "Safe — npm install" "find-nm"
done

# ── Phase 5: Package manager caches ─────────────────────────────────────────

add "npm Cache"      "$HOME/.npm"                       "Pkg Manager" "Safe" "npm-cache"
has_cmd pnpm  && add "pnpm Store"    "$HOME/Library/pnpm/store"     "Pkg Manager" "Safe" "pnpm-prune"
has_cmd yarn  && add "Yarn Cache"    "$HOME/Library/Caches/Yarn"    "Pkg Manager" "Safe" "rm"
has_cmd brew  && add "Homebrew Cache" "$HOME/Library/Caches/Homebrew" "Pkg Manager" "Safe" "brew-cleanup"

# ── Display table ────────────────────────────────────────────────────────────

if [[ ${#T_NAMES[@]} -eq 0 ]]; then
  echo -e "  ${GREEN}Your disk is clean! No large items found.${NC}"
  exit 0
fi

# Sort indices by size descending
declare -a SORTED=()
for i in "${!T_SIZES[@]}"; do
  SORTED+=("${T_SIZES[$i]}|$i")
done
IFS=$'\n' SORTED=($(printf '%s\n' "${SORTED[@]}" | sort -t'|' -k1 -nr)); unset IFS

# Calculate total
TOTAL_KB=0
for s in "${T_SIZES[@]}"; do
  TOTAL_KB=$((TOTAL_KB + s))
done

# Header
echo -e "${BOLD}${CYAN}  ┌─────┬──────────────────────────────────┬──────────────┬────────────┬──────────────────────────┐${NC}"
printf  "${BOLD}${CYAN}  │${NC}${BOLD} %-3s ${CYAN}│${NC}${BOLD} %-32s ${CYAN}│${NC}${BOLD} %-12s ${CYAN}│${NC}${BOLD} %-10s ${CYAN}│${NC}${BOLD} %-24s ${CYAN}│${NC}\n" "#" "Name" "Category" "Size" "Risk"
echo -e "${BOLD}${CYAN}  ├─────┼──────────────────────────────────┼──────────────┼────────────┼──────────────────────────┤${NC}"

idx=1
for entry in "${SORTED[@]}"; do
  i="${entry#*|}"
  size_fmt=$(fmt "${T_SIZES[$i]}")

  if (( T_SIZES[$i] >= 10485760 )); then
    color="$RED"
  elif (( T_SIZES[$i] >= 1048576 )); then
    color="$YELLOW"
  else
    color="$NC"
  fi

  name="${T_NAMES[$i]}"
  (( ${#name} > 32 )) && name="${name:0:29}..."

  risk="${T_RISKS[$i]}"
  (( ${#risk} > 24 )) && risk="${risk:0:21}..."

  cat="${T_CATS[$i]}"
  (( ${#cat} > 12 )) && cat="${cat:0:12}"

  printf "${CYAN}  │${NC} ${color}%-3s${NC} ${CYAN}│${NC} ${color}%-32s${NC} ${CYAN}│${NC} ${color}%-12s${NC} ${CYAN}│${NC} ${color}%10s${NC} ${CYAN}│${NC} ${color}%-24s${NC} ${CYAN}│${NC}\n" \
    "$idx" "$name" "$cat" "$size_fmt" "$risk"
  ((idx++))
done

echo -e "${BOLD}${CYAN}  ├─────┴──────────────────────────────────┴──────────────┼────────────┼──────────────────────────┤${NC}"
printf  "${BOLD}${CYAN}  │${NC}${BOLD}${MAGENTA}  TOTAL RECOVERABLE                                     ${CYAN}│${NC}${BOLD}${MAGENTA} %10s ${CYAN}│${NC}                          ${CYAN}│${NC}\n" "$(fmt $TOTAL_KB)"
echo -e "${BOLD}${CYAN}  └────────────────────────────────────────────────────────┴────────────┴──────────────────────────┘${NC}"
echo ""

# ── Scan only mode ───────────────────────────────────────────────────────────

if [[ "$SCAN_ONLY" == true ]]; then
  echo -e "  ${DIM}Scan mode: nothing was deleted.${NC}"
  exit 0
fi

# ── Selection ────────────────────────────────────────────────────────────────

if [[ "$AUTO_MODE" == true ]]; then
  # Auto mode: select all
  for ((i=0; i<${#SORTED[@]}; i++)); do SELECTED[$i]=1; done
  echo -e "  ${YELLOW}Auto mode: proceeding with cleanup...${NC}"
else
  echo -e "  ${BOLD}Select items to delete:${NC}"
  echo ""
  interactive_select

  # Check if anything is selected
  any_selected=false
  for s in "${SELECTED[@]}"; do
    [[ "$s" == "1" ]] && any_selected=true && break
  done

  if ! $any_selected; then
    echo ""
    echo -e "  ${DIM}No items selected. Nothing was deleted.${NC}"
    exit 0
  fi
fi

echo ""
echo -e "  ${YELLOW}Cleaning...${NC}"
echo ""

# ── Cleanup ──────────────────────────────────────────────────────────────────

ITEMS_CLEANED=0
ITEMS_FAILED=0
START_TIME=$(date +%s)

selector_idx=0
for entry in "${SORTED[@]}"; do
  i="${entry#*|}"

  # Skip unselected items
  if [[ "${SELECTED[$selector_idx]}" != "1" ]]; then
    ((selector_idx++))
    continue
  fi
  ((selector_idx++))

  method="${T_METHODS[$i]}"
  path="${T_PATHS[$i]}"
  name="${T_NAMES[$i]}"
  (( ${#name} > 40 )) && name="${name:0:37}..."

  printf "  %-42s " "$name"

  ok=false
  case "$method" in
    rm)
      rm -rf "$path" 2>/dev/null && ok=true
      ;;
    rm-sudo)
      sudo rm -rf "$path" 2>/dev/null && ok=true
      ;;
    find-nm)
      find "$path" -name "node_modules" -maxdepth 4 -type d -exec rm -rf {} + 2>/dev/null
      ok=true
      ;;
    npm-cache)
      npm cache clean --force &>/dev/null && ok=true
      ;;
    pnpm-prune)
      pnpm store prune &>/dev/null && ok=true
      ;;
    brew-cleanup)
      brew cleanup --prune=all -q &>/dev/null && ok=true
      ;;
  esac

  if $ok; then
    echo -e "${GREEN}done${NC}"
    ((ITEMS_CLEANED++))
  else
    echo -e "${RED}failed${NC}"
    ((ITEMS_FAILED++))
  fi
done

END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))

# ── Final Report ─────────────────────────────────────────────────────────────

DISK_LINE_AFTER=$(df -k / | tail -1)
DISK_AVAIL_AFTER=$(echo "$DISK_LINE_AFTER" | awk '{print $4}')
DISK_USED_AFTER=$((DISK_TOTAL - DISK_AVAIL_AFTER))
ACTUAL_RECOVERED=$((DISK_AVAIL_AFTER - DISK_AVAIL_BEFORE))

(( ACTUAL_RECOVERED < 0 )) && ACTUAL_RECOVERED=0

PCT_FREE_BEFORE=$((DISK_AVAIL_BEFORE * 100 / DISK_TOTAL))
PCT_FREE_AFTER=$((DISK_AVAIL_AFTER * 100 / DISK_TOTAL))

echo ""
echo -e "${BOLD}${CYAN}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${NC}"
echo -e "${BOLD}${CYAN}┃                      Final Report                          ┃${NC}"
echo -e "${BOLD}${CYAN}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${NC}"
echo ""
echo -e "  ${DIM}Total disk .........${NC}  $(fmt $DISK_TOTAL)"
echo -e "  ${DIM}Free before ........${NC}  $(fmt $DISK_AVAIL_BEFORE) (${PCT_FREE_BEFORE}%)"
echo -e "  ${DIM}Free after .........${NC}  ${GREEN}${BOLD}$(fmt $DISK_AVAIL_AFTER) (${PCT_FREE_AFTER}%)${NC}"
echo ""
echo -e "  ${BOLD}${GREEN}Space recovered ....  $(fmt $ACTUAL_RECOVERED)${NC}"
echo -e "  ${DIM}Items cleaned ......${NC}  ${ITEMS_CLEANED} succeeded, ${ITEMS_FAILED} failed"
echo -e "  ${DIM}Time elapsed .......${NC}  ${ELAPSED}s"
echo ""

# ── Progress bar ─────────────────────────────────────────────────────────────
BAR=40

echo -ne "  Before: ["
filled_before=$((DISK_USED_BEFORE * BAR / DISK_TOTAL))
empty_before=$((BAR - filled_before))
for ((j=0; j<filled_before; j++)); do echo -ne "${RED}█${NC}"; done
for ((j=0; j<empty_before; j++)); do echo -ne "${DIM}░${NC}"; done
echo -e "]  ${DIM}$(fmt $DISK_AVAIL_BEFORE) free${NC}"

echo -ne "  After:  ["
filled_after=$((DISK_USED_AFTER * BAR / DISK_TOTAL))
empty_after=$((BAR - filled_after))
for ((j=0; j<filled_after; j++)); do echo -ne "${YELLOW}█${NC}"; done
for ((j=0; j<empty_after; j++)); do echo -ne "${GREEN}░${NC}"; done
echo -e "]  ${GREEN}${BOLD}$(fmt $DISK_AVAIL_AFTER) free${NC}"

echo ""
echo -e "${BOLD}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "  ${DIM}Run periodically to keep your disk clean.${NC}"
echo -e "  ${DIM}  diskdoc          Interactive${NC}"
echo -e "  ${DIM}  diskdoc --auto   No confirmation${NC}"
echo -e "  ${DIM}  diskdoc --scan   Scan only${NC}"
echo -e "${BOLD}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
