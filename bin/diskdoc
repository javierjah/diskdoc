  # VS Code
  scan_target "VS Code CachedData"  "$HOME/Library/Application Support/Code/CachedData"          "Dev Tools" "SAFE" "rm"
  scan_target "VS Code Workspaces"  "$HOME/Library/Application Support/Code/User/workspaceStorage" "Dev Tools" "SAFE" "rm"

  tc_count=0; tc_kb=0
  for ((i=tc_start; i<${#T_NAMES[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "Dev Tools" ]] && ((tc_count++)) && tc_kb=$((tc_kb + T_SIZES[$i]))
  done
  cat_footer "$tc_count" "$tc_kb"
