# PHASE: Personal Data (PERSONAL — report only, never auto-delete)
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "Personal" || [[ "$PROFILE" == "all" ]]; then
  cat_header "Personal Data ⚠ report only" "$MAGENTA"
  personal_start=${#T_NAMES[@]}

  # Mail databases (try multiple versions)
  for v in V10 V9 V8; do
    [[ -d "$HOME/Library/Mail/$v" ]] && {
      scan_target "Mail Database ($v)" "$HOME/Library/Mail/$v" "Personal" "PERSONAL" "rm"
      break
    }
  done

  scan_target "Mail Downloads"        "$HOME/Library/Containers/com.apple.mail/Data/Library/Mail Downloads" "Personal" "PERSONAL" "rm"
  scan_target "Messages Attachments"  "$HOME/Library/Messages/Attachments"                                  "Personal" "PERSONAL" "rm"
  if ! scan_target "Messages Database"     "$HOME/Library/Messages"                                              "Personal" "PERSONAL" "rm"; then
    if [[ -d "$HOME/Library/Messages" ]]; then
      local _msg_kb
      _msg_kb=$(du -sk "$HOME/Library/Messages" 2>/dev/null | awk '{print $1}')
      if [[ -z "$_msg_kb" || "$_msg_kb" == "0" ]]; then
        log "  │  ${C_WARNING}⚠${C_RESET}  ${C_DIM}Messages exists but unreadable (TCC). Grant Full Disk Access.${C_RESET}\n"
      fi
    fi
  fi

  # iCloud Drive local cache
  scan_target "iCloud Drive (local)"  "$HOME/Library/Mobile Documents"                                      "Personal" "PERSONAL" "rm"

  # Photos Library derivatives (face recognition cache — takes hours to rebuild)
  scan_target "Photos Derivatives"    "$HOME/Pictures/Photos Library.photoslibrary/resources"                "Personal" "PERSONAL" "rm"

  personal_count=0; personal_kb=0
  for ((i=personal_start; i<${#T_NAMES[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "Personal" ]] && ((++personal_count)) && personal_kb=$((personal_kb + T_SIZES[$i]))
  done
  cat_footer "$personal_count" "$personal_kb"
fi

