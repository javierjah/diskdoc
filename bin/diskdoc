# ── A10: /private/var/folders/ — the forgotten temp ───────────────────────

if matches_profile "System" || [[ "$PROFILE" == "all" ]]; then
  if ! is_excluded "/private/var/folders"; then
    cat_header "/var/folders" "$YELLOW"
    vf_start=${#T_NAMES[@]}

    log "  │  ${C_WARNING}⚠${C_RESET}  ${C_DIM}Scanning /private/var/folders/ requires admin access${C_RESET}\n"
    # Scan top consumers dynamically
    while IFS=$'\t' read -r kb path; do
      [[ -z "$kb" || -z "$path" ]] && continue
      kb=$(echo "$kb" | tr -d '[:space:]')
      (( kb > MIN_SIZE_KB )) || continue
      local vf_name
      vf_name=$(basename "$path")
      is_excluded "$path" && continue

      T_NAMES+=("var/folders: $vf_name")
      T_PATHS+=("$path")
      T_SIZES+=("$kb")
      T_CATS+=("System Temp")
      T_RISKS+=("SAFE")
      T_METHODS+=("rm-sudo")
      FOUND_TOTAL=$((FOUND_TOTAL + kb))
      log "  │  ${C_SUCCESS}✓${C_RESET}  %-44s ${C_BOLD}%10s${C_RESET}\n" "var/folders: $vf_name" "$(fmt "$kb")"
    done < <(sudo du -sk /private/var/folders/*/*/ 2>/dev/null | sort -nr | head -20)

    vf_count=0; vf_kb=0
    for ((i=vf_start; i<${#T_CATS[@]}; i++)); do
      [[ "${T_CATS[$i]}" == "System Temp" ]] && ((vf_count++)) && vf_kb=$((vf_kb + T_SIZES[$i]))
    done
    cat_footer "$vf_count" "$vf_kb"
  fi
fi

