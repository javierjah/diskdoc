# ── B16: Homebrew Extras ────────────────────────────────────────────────

if has_cmd brew && (matches_profile "Pkg Manager" || [[ "$PROFILE" == "all" ]]); then
  cat_header "Homebrew Extras" "$CYAN"
  local cask_count=0 cask_total_kb=0
  # B16: Homebrew Caskroom .dmg/.pkg files
  local _caskroom
  _caskroom="$(brew --prefix 2>/dev/null)/Caskroom"
  if [[ -d "$_caskroom" ]]; then
    logp "\r\033[K  ${C_DIM}⠹ Scanning Caskroom installers${C_RESET}"
    local cask_kb
    cask_kb=$(find "$_caskroom" -type f \( -name '*.dmg' -o -name '*.pkg' \) -exec du -sk {} + 2>/dev/null | awk '{s+=$1} END {print s+0}')
    if (( cask_kb > MIN_SIZE_KB )); then
      _flush_cat_header
      T_NAMES+=("Homebrew Caskroom installers")
      T_PATHS+=("$_caskroom")
      T_SIZES+=("$cask_kb")
      T_CATS+=("Pkg Manager")
      T_RISKS+=("SAFE")
      T_METHODS+=("caskroom-clean")
      FOUND_TOTAL=$((FOUND_TOTAL + cask_kb))
      cask_count=1; cask_total_kb=$cask_kb
      log "\r\033[K  │  ${C_SUCCESS}✓${C_RESET}  %-44s ${C_BOLD}%10s${C_RESET}\n" "Homebrew Caskroom installers" "$(fmt "$cask_kb")"
    else
      logp "\r\033[K"
    fi
  fi
  cat_footer "$cask_count" "$cask_total_kb"
fi

