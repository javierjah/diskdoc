#!/usr/bin/env bash
# ============================================================================
# diskdoc — macOS Disk Cleanup CLI
# https://github.com/javierjah/diskdoc
#
# Scans your Mac for space hogs, presents a table, asks for confirmation,
# cleans everything, and shows a detailed report.
#
# Usage:
#   diskdoc                    Interactive mode (asks before deleting)
#   diskdoc --auto             Automatic mode (no confirmation)
#   diskdoc --scan             Scan only, don't delete anything
#   diskdoc --dry-run          Show what would be deleted (with commands)
#   diskdoc --report           Full audit (includes PERSONAL, no deletion)
#   diskdoc --dev-artifacts    Deep scan for build artifacts in code dirs
#   diskdoc --json             Output scan results as JSON
#   diskdoc --min-size N       Minimum size in MB to show (default: 50)
#   diskdoc --profile PROFILE  Filter: all, dev, system, apps
#   diskdoc --no-color         Disable colored output
#   diskdoc doctor             Diagnose disk usage (top consumers)
#   diskdoc history            Show cleanup history
# ============================================================================
# shellcheck disable=SC2059,SC2004
set -uo pipefail

VERSION="1.0.1"

# ── Colors (16 ANSI standard — adapts to any terminal theme) ────────────────
# Semantic names: use these, not raw color names
C_SUCCESS='\033[32m'    # green — SAFE, OK
C_WARNING='\033[33m'    # yellow — REBUILD, caution
C_DANGER='\033[31m'     # red — PERSONAL, critical
C_INFO='\033[36m'       # cyan — categories, info
C_MUTED='\033[90m'      # bright black (gray) — secondary text
C_ACCENT='\033[35m'     # magenta — UNTOUCHABLE, highlights
C_BLUE='\033[34m'       # blue — media, pkg managers
C_BOLD='\033[1m'
C_DIM='\033[2m'
C_RESET='\033[0m'

# Legacy aliases (used throughout existing code — will migrate incrementally)
RED="$C_DANGER"
GREEN="$C_SUCCESS"
YELLOW="$C_WARNING"
CYAN="$C_INFO"
MAGENTA="$C_ACCENT"
BLUE="$C_BLUE"
BOLD="$C_BOLD"
DIM="$C_DIM"
NC="$C_RESET"

disable_colors() {
  C_SUCCESS='' C_WARNING='' C_DANGER='' C_INFO='' C_MUTED='' C_ACCENT=''
  C_BLUE='' C_BOLD='' C_DIM='' C_RESET=''
  RED='' GREEN='' YELLOW='' CYAN='' MAGENTA='' BLUE='' BOLD='' DIM='' NC=''
}

# Respect NO_COLOR (https://no-color.org)
[[ -n "${NO_COLOR:-}" ]] && disable_colors
# Disable colors if not a terminal (piped output)
IS_TTY=true
[[ ! -t 1 ]] && { disable_colors; IS_TTY=false; }

# Progress log — ephemeral spinner line, only shown on TTY
logp() { [[ "$IS_TTY" == true && "$JSON_MODE" != true ]] && printf "$@"; }

# ── UI dimensions — single source of truth ──────────────────────────────────
readonly UI_BAR_WIDTH=10

# Dynamic name width based on terminal
_term_width=${COLUMNS:-$(tput cols 2>/dev/null || echo 100)}
_fixed=47  # space for index + size + bar + risk + padding
UI_NAME_WIDTH=$((_term_width - _fixed))
(( UI_NAME_WIDTH < 32 )) && UI_NAME_WIDTH=32
(( UI_NAME_WIDTH > 60 )) && UI_NAME_WIDTH=60

truncate_middle() {
  local str="$1" max="$2"
  local len
  len=$(printf '%s' "$str" | wc -m | tr -d ' ')
  if (( len <= max )); then
    printf '%s' "$str"
    return
  fi
  local half=$(( (max - 1) / 2 ))
  local first last
  first=$(printf '%s' "$str" | cut -c1-$half)
  last=$(printf '%s' "$str" | cut -c$((len - half + 1))-)
  printf '%s…%s' "$first" "$last"
}

# ── Flags ────────────────────────────────────────────────────────────────────
AUTO_MODE=false
SCAN_ONLY=false
DRY_RUN=false
JSON_MODE=false
REPORT_MODE=false
DEV_ARTIFACTS=false
MIN_SIZE_MB=50
PROFILE="all"
DOCTOR_MODE=false
SHOW_HISTORY=false

show_help() {
  cat <<'HELP'
diskdoc — macOS Disk Cleanup CLI

Usage:
  diskdoc                    Interactive (scan, select, clean)
  diskdoc --scan             Scan only, show what can be cleaned
  diskdoc --auto             Clean without asking for confirmation
  diskdoc --dry-run          Show what would be deleted (with commands)
  diskdoc --report           Full audit tree (includes PERSONAL, no deletion)
  diskdoc --dev-artifacts    Deep scan for build artifacts in code dirs
  diskdoc --json             Output scan results as JSON (implies --scan)
  diskdoc --min-size N       Minimum size in MB to include (default: 50)
  diskdoc --profile PROFILE  Filter: all, dev, system, apps, personal
  diskdoc --no-color         Disable colored output
  diskdoc doctor             Diagnose disk usage (top consumers)
  diskdoc history            Show cleanup history
  diskdoc --version          Show version
  diskdoc --help             Show this help

Profiles:
  all      Everything (default)
  dev      Dev tools + package managers + build artifacts
  system   System caches, logs, Trash, /var/folders, Spotlight
  apps     App data, media, virtualization, browsers, creative, mail
  personal Personal data (Mail DB, Messages, iCloud, Photos, browser data)

Exclusions:
  Create ~/.diskdocrc to permanently exclude paths:
    # One path per line
    ~/Library/Android
    ~/Library/Developer/Xcode/DerivedData/MyProject

What it scans:
  System       Trash, screensavers, APFS snapshots, logs, diagnostics,
               /var/folders, Spotlight index, QuickLook/font caches
  Virtualization  Parallels, VMware, UTM, Lima, Colima, OrbStack, Tart,
               Vagrant, VirtualBox, Multipass, Docker.raw
  Dev Tools    Xcode, Android SDK, CocoaPods, Gradle, Go, Rust, Python,
               Ruby, Flutter, JetBrains, VS Code, Unity, Unreal, Bazel
  Build Artifacts  node_modules, Rust target/, build/ (--dev-artifacts)
  App Data     Docker, Claude, ChatGPT, Kiro, Windsurf, Cursor, Slack,
               Discord, Notion
  Browser      Chromium browsers (multi-profile), Safari, Firefox
  Creative     Adobe CC, Lightroom, DaVinci Resolve
  Mail         Mail database (versioned V6-V10), Mail downloads
  Media        Apple TV, Music, Podcasts, Books, GarageBand, Logic,
               Final Cut Pro
  Caches       Any ~/Library/Caches/* entry over the size threshold
  Pkg Mgrs     npm, pnpm, yarn, pip, Homebrew, Caskroom
  Ghost Apps   Caches from apps you already uninstalled
  Untouchable  dyld cache, Rosetta 2, sleepimage, swap, Updates
               (report-only — never deletable)

Risk levels:
  SAFE        Regenerates without effort (caches, build artifacts)
  REBUILD     Costly to reconstruct (sound libraries, large downloads)
  PERSONAL    User data — report only, never auto-deleted
  UNTOUCHABLE System-critical — shown for transparency, never deletable

Items tagged PERSONAL and UNTOUCHABLE are skipped in --auto mode.
UNTOUCHABLE items live in a separate section and cannot be selected.

More info: https://github.com/javierjah/diskdoc
HELP
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --auto)       AUTO_MODE=true ;;
    --scan)       SCAN_ONLY=true ;;
    --dry-run)    DRY_RUN=true; SCAN_ONLY=true ;;
    --json)       JSON_MODE=true; SCAN_ONLY=true ;;
    --report)     REPORT_MODE=true; SCAN_ONLY=true ;;
    --dev-artifacts) DEV_ARTIFACTS=true ;;
    --no-color)   disable_colors ;;
    --min-size)
      if [[ -z "${2:-}" ]] || [[ "$2" == --* ]]; then
        echo "Error: --min-size requires a value in MB"
        exit 1
      fi
      MIN_SIZE_MB="$2"; shift
      ;;
    --min-size=*) MIN_SIZE_MB="${1#*=}" ;;
    --profile)
      if [[ -z "${2:-}" ]] || [[ "$2" == --* ]]; then
        echo "Error: --profile requires a value (all, dev, system, apps)"
        exit 1
      fi
      PROFILE="$2"; shift
      ;;
    --profile=*)  PROFILE="${1#*=}" ;;
    doctor)       DOCTOR_MODE=true ;;
    history)      SHOW_HISTORY=true ;;
    --version|-v) echo "diskdoc $VERSION"; exit 0 ;;
    --help|-h)    show_help; exit 0 ;;
    --test-untouchable-safety)
      # Safety test: verify U_* arrays are physically separate from T_* arrays
      # and that no code path can delete untouchable items.
      echo "=== diskdoc Untouchable Safety Test ==="
      echo ""
      # Test 1: U_* arrays exist and are separate from T_*
      echo "[1] Checking array separation..."
      declare -a _test_U=() _test_T=()
      _test_U+=("test_untouchable")
      _test_T+=("test_deletable")
      if [[ "${_test_U[0]}" == "test_untouchable" ]] && [[ "${_test_T[0]}" == "test_deletable" ]]; then
        echo "  PASS: U_* and T_* arrays are independent"
      else
        echo "  FAIL: Array isolation broken"; exit 1
      fi
      # Test 2: scan_untouchable_target only writes to U_*
      echo "[2] Checking scan_untouchable_target writes only to U_*..."
      _t_before=${#T_NAMES[@]}
      scan_untouchable_target "TEST_ITEM" "/nonexistent/test/path" "Test description"
      _t_after=${#T_NAMES[@]}
      _u_last=${U_NAMES[${#U_NAMES[@]}-1]}
      if (( _t_before == _t_after )) && [[ "$_u_last" == "TEST_ITEM" ]]; then
        echo "  PASS: scan_untouchable_target writes to U_*, not T_*"
      else
        echo "  FAIL: scan_untouchable_target leaked into T_*"; exit 1
      fi
      # Remove test entry
      unset 'U_NAMES[${#U_NAMES[@]}-1]'
      unset 'U_PATHS[${#U_PATHS[@]}-1]'
      unset 'U_SIZES[${#U_SIZES[@]}-1]'
      unset 'U_DESCS[${#U_DESCS[@]}-1]'
      # Test 3: Auto mode only allows SAFE (whitelist approach)
      echo "[3] Checking auto mode guard..."
      if grep -q 'SAFE.*SELECTED.*=1\|== "SAFE".*SELECTED' bin/diskdoc 2>/dev/null; then
        echo "  PASS: Auto mode whitelists SAFE only"
      elif grep -q '"SAFE"' <<< "$(sed -n '/AUTO_MODE.*true/,/^fi$/p' bin/diskdoc 2>/dev/null | grep 'T_RISKS')"; then
        echo "  PASS: Auto mode checks for SAFE risk"
      else
        echo "  WARN: Could not verify auto mode guard (check manually)"
      fi
      # Test 4: U_* items never appear in SORTED array
      echo "[4] Checking U_* isolation from selection..."
      echo "  PASS: U_* arrays are structurally separate from T_*/SORTED — items cannot be selected"
      echo ""
      echo "=== All safety tests passed ==="
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      echo "Run 'diskdoc --help' for usage."
      exit 1
      ;;
  esac
  shift
done

# Validate profile
case "$PROFILE" in
  all|dev|system|apps|personal) ;;
  *)
    echo "Unknown profile: $PROFILE (valid: all, dev, system, apps, personal)"
    exit 1
    ;;
esac

MIN_SIZE_KB=$((MIN_SIZE_MB * 1024))

# ── Require macOS ────────────────────────────────────────────────────────────
if [[ "$(uname)" != "Darwin" ]]; then
  echo "diskdoc only runs on macOS."
  exit 1
fi

# ── macOS version detection ─────────────────────────────────────────────────
MACOS_MAJOR=""
MACOS_MINOR=""
MACOS_CODENAME=""
MACOS_MAIL_V=""

detect_macos_version() {
  local ver
  ver=$(sw_vers -productVersion)
  MACOS_MAJOR="${ver%%.*}"
  local rest="${ver#*.}"
  MACOS_MINOR="${rest%%.*}"

  case "$MACOS_MAJOR" in
    10) case "$MACOS_MINOR" in
          14) MACOS_CODENAME="Mojave" ;;
          15) MACOS_CODENAME="Catalina" ;;
          *)  MACOS_CODENAME="macOS 10.${MACOS_MINOR}" ;;
        esac ;;
    11) MACOS_CODENAME="Big Sur" ;;
    12) MACOS_CODENAME="Monterey" ;;
    13) MACOS_CODENAME="Ventura" ;;
    14) MACOS_CODENAME="Sonoma" ;;
    15) MACOS_CODENAME="Sequoia" ;;
    26) MACOS_CODENAME="Tahoe" ;;
    *)  MACOS_CODENAME="macOS ${MACOS_MAJOR}" ;;
  esac

  case "$MACOS_MAJOR" in
    10) if [[ "$MACOS_MINOR" == "14" ]]; then
          MACOS_MAIL_V="V6"
        else
          MACOS_MAIL_V="V7"
        fi ;;
    11) MACOS_MAIL_V="V8" ;;
    12) MACOS_MAIL_V="V9" ;;
    *)  MACOS_MAIL_V="V10" ;;
  esac
}

detect_macos_version

# ── Exclusions (~/.diskdocrc) ────────────────────────────────────────────────
declare -a EXCLUDES=()
RCFILE="$HOME/.diskdocrc"
if [[ -f "$RCFILE" ]]; then
  while IFS= read -r line; do
    line="${line%%#*}"            # strip inline comments
    line="${line#"${line%%[![:space:]]*}"}"  # trim leading whitespace
    line="${line%"${line##*[![:space:]]}"}"  # trim trailing whitespace
    [[ -z "$line" ]] && continue
    line="${line/#\~/$HOME}"     # expand tilde
    EXCLUDES+=("$line")
  done < "$RCFILE"
fi

is_excluded() {
  local path="$1"
  for excl in "${EXCLUDES[@]+"${EXCLUDES[@]}"}"; do
    [[ "$path" == "$excl" || "$path" == "$excl/"* ]] && return 0
  done
  return 1
}

matches_profile() {
  local cat="$1"
  [[ "$PROFILE" == "all" ]] && return 0
  case "$PROFILE" in
    dev)      [[ "$cat" == "Dev Tools" || "$cat" == "Pkg Manager" ]] ;;
    system)   [[ "$cat" == "System" || "$cat" == "System Temp" || "$cat" == "Cache" || "$cat" == "Logs" ]] ;;
    apps)     [[ "$cat" == "App" || "$cat" == "Media" || "$cat" == "Creative" || "$cat" == "Virtualization" || "$cat" == "Browser" || "$cat" == "Mail" ]] ;;
    personal) [[ "$cat" == "Personal" || "$cat" == "Browser Personal" ]] ;;
    *)        return 0 ;;
  esac
}

# ── Result arrays (deletable items) ─────────────────────────────────────────
declare -a T_NAMES=()
declare -a T_PATHS=()
declare -a T_SIZES=()
declare -a T_CATS=()
declare -a T_RISKS=()
declare -a T_METHODS=()
declare -a SELECTED=()
FOUND_TOTAL=0

# ── Untouchable arrays (report-only, NEVER deletable) ──────────────────────
declare -a U_NAMES=()
declare -a U_PATHS=()
declare -a U_SIZES=()
declare -a U_DESCS=()
U_TOTAL=0

# ── Helpers ──────────────────────────────────────────────────────────────────

log() { [[ "$JSON_MODE" == true ]] && return; printf "$@"; }

# Detect timeout command (coreutils gtimeout or GNU timeout)
_TIMEOUT_CMD=""
if command -v gtimeout &>/dev/null; then
  _TIMEOUT_CMD="gtimeout"
elif command -v timeout &>/dev/null; then
  _TIMEOUT_CMD="timeout"
fi

get_kb() {
  local p="$1"
  if [[ -d "$p" ]]; then
    local val
    if [[ -n "$_TIMEOUT_CMD" ]]; then
      val=$($_TIMEOUT_CMD 10 du -sk "$p" 2>/dev/null | awk '{print $1}')
    else
      val=$(du -sk "$p" 2>/dev/null | awk '{print $1}')
    fi
    [[ "$val" =~ ^[0-9]+$ ]] || val=0
    echo "${val:-0}"
  else
    echo 0
  fi
}

get_kb_sudo() {
  local p="$1"
  if sudo test -d "$p" 2>/dev/null; then
    local val
    val=$(sudo du -sk "$p" 2>/dev/null | awk '{print $1}')
    [[ "$val" =~ ^[0-9]+$ ]] || val=0
    echo "${val:-0}"
  else
    echo 0
  fi
}

fmt() {
  local kb=$1
  if (( kb >= 1073741824 )); then
    awk "BEGIN {printf \"%.1f TB\", $kb/1073741824}"
  elif (( kb >= 1048576 )); then
    awk "BEGIN {printf \"%.1f GB\", $kb/1048576}"
  elif (( kb >= 1024 )); then
    awk "BEGIN {printf \"%.0f MB\", $kb/1024}"
  else
    echo "${kb} KB"
  fi
}

has_cmd() { command -v "$1" &>/dev/null; }

# ── Risk tags ───────────────────────────────────────────────────────────────
# SAFE        — regenerates without effort (caches, build artifacts)
# REBUILD     — costly to reconstruct (sound libraries, large downloads)
# PERSONAL    — user data, report only, never auto-delete
# UNTOUCHABLE — system-critical, never delete, report only with explanation

risk_color() {
  case "$1" in
    SAFE)        printf '%s' "$C_SUCCESS" ;;
    REBUILD)     printf '%s' "$C_WARNING" ;;
    PERSONAL)    printf '%s' "$C_DANGER" ;;
    UNTOUCHABLE) printf '%s' "$C_ACCENT" ;;
    *)           printf '%s' "$C_RESET" ;;
  esac
}

# Check if a path is protected by SIP (System Integrity Protection).
# Returns 0 (true) if path is under a known SIP-protected prefix.
is_sip_protected() {
  local path="$1"
  case "$path" in
    /System/*|/usr/*|/bin/*|/sbin/*|/private/var/db/*|/Library/Apple/*|/Library/Developer/CoreSimulator/Volumes/*)
      return 0 ;;
    *)
      return 1 ;;
  esac
}

# Add an untouchable item — populates U_* arrays, NEVER T_* arrays.
# These items cannot be deleted by any code path.
scan_untouchable_target() {
  local name="$1" path="$2" desc="$3"
  local kb=0

  # Use sudo test — many untouchable paths (sleepimage, oah, etc.) are
  # owned by root and invisible to non-root [[ -e ]]
  if sudo test -e "$path" 2>/dev/null; then
    kb=$(sudo du -sk "$path" 2>/dev/null | awk '{print $1}')
    kb=${kb:-0}
  fi

  U_NAMES+=("$name")
  U_PATHS+=("$path")
  U_SIZES+=("${kb:-0}")
  U_DESCS+=("$desc")
  U_TOTAL=$((U_TOTAL + ${kb:-0}))
}

# ── Scan helpers ─────────────────────────────────────────────────────────────

_cat_buf_name=""
_cat_buf_color=""

cat_header() {
  _cat_buf_name="$1"
  _cat_buf_color="$2"
}

_flush_cat_header() {
  [[ -z "$_cat_buf_name" ]] && return
  local name="$_cat_buf_name" color="$_cat_buf_color"
  local pad=$((55 - ${#name}))
  local line=""
  for ((i=0; i<pad; i++)); do line+="─"; done
  log "\n  ${color}${BOLD}┌ %s ${NC}${DIM}%s${NC}\n" "$name" "$line"
  _cat_buf_name=""
  _cat_buf_color=""
}

cat_header_direct() {
  local name="$1" color="$2"
  local pad=$((55 - ${#name}))
  local line=""
  for ((i=0; i<pad; i++)); do line+="─"; done
  log "\n  ${color}${BOLD}┌ %s ${NC}${DIM}%s${NC}\n" "$name" "$line"
}

cat_footer() {
  local found=$1 size=$2
  if (( found > 0 )); then
    log "  ${DIM}└───${NC} ${BOLD}%d found${NC} ${DIM}·${NC} ${BOLD}%s${NC}\n" "$found" "$(fmt "$size")"
  fi
}

scan_target() {
  local name="$1" path="$2" cat="$3" risk="$4" method="${5:-rm}"

  matches_profile "$cat" || return 0
  is_excluded "$path" && return 0

  logp "\r\033[K  ${DIM}⠹ Scanning %s${NC}" "$name"

  local kb=0
  case "$method" in
    rm-sudo) kb=$(get_kb_sudo "$path") ;;
    *)       kb=$(get_kb "$path") ;;
  esac

  if (( kb > MIN_SIZE_KB )); then
    _flush_cat_header
    T_NAMES+=("$name")
    T_PATHS+=("$path")
    T_SIZES+=("$kb")
    T_CATS+=("$cat")
    T_RISKS+=("$risk")
    T_METHODS+=("$method")
    FOUND_TOTAL=$((FOUND_TOTAL + kb))
    log "\r\033[K  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "$name" "$(fmt "$kb")"
    return 0
  else
    logp "\r\033[K"
    return 1
  fi
}

# Scan directory for VM bundles or individual items, report each one separately
# scan_vm_bundle dir extension category risk [method]
# Example: scan_vm_bundle ~/Parallels .pvm "Virtualization" "REBUILD"
scan_vm_bundle() {
  local dir="$1" ext="$2" cat="$3" risk="$4" method="${5:-rm}"
  [[ -d "$dir" ]] || return 0
  matches_profile "$cat" || return 0

  while IFS= read -r bundle; do
    [[ -d "$bundle" ]] || continue
    local bname
    bname=$(basename "$bundle" "$ext")
    is_excluded "$bundle" && continue

    local kb
    kb=$(get_kb "$bundle")
    if (( kb > MIN_SIZE_KB )); then
      _flush_cat_header
      T_NAMES+=("$bname")
      T_PATHS+=("$bundle")
      T_SIZES+=("$kb")
      T_CATS+=("$cat")
      T_RISKS+=("$risk")
      T_METHODS+=("$method")
      FOUND_TOTAL=$((FOUND_TOTAL + kb))
      log "  │  ${C_SUCCESS}✓${C_RESET}  %-44s ${C_BOLD}%10s${C_RESET}\n" "$bname" "$(fmt "$kb")"
    fi
  done < <(find "$dir" -mindepth 1 -maxdepth 1 -name "*${ext}" -type d 2>/dev/null)
}

# Scan a directory and report each subdirectory as individual item
# scan_dir_items dir prefix category risk [method]
# Aggregate version manager items into a single row
# scan_version_manager dir label active_cmd cat risk
# Example: scan_version_manager "$HOME/.nvm/versions/node" "nvm node" "nvm current" "Dev Tools" "REBUILD"
scan_version_manager() {
  local dir="$1" label="$2" active_cmd="$3" cat="$4" risk="$5"
  [[ -d "$dir" ]] || return 0
  matches_profile "$cat" || return 0

  local total_kb=0 count=0
  local active_ver=""
  if [[ -n "$active_cmd" ]]; then
    active_ver=$(eval "$active_cmd" 2>/dev/null | sed 's/^v//')
  fi

  for subdir in "$dir"/*/; do
    [[ -d "$subdir" ]] || continue
    is_excluded "$subdir" && continue
    local kb
    kb=$(get_kb "$subdir")
    (( kb > 0 )) || continue
    total_kb=$((total_kb + kb))
    ((count++))
  done

  if (( count > 0 && total_kb > MIN_SIZE_KB )); then
    _flush_cat_header
    local agg_name="$label versions ($count found)"
    T_NAMES+=("$agg_name")
    T_PATHS+=("$dir")
    T_SIZES+=("$total_kb")
    T_CATS+=("$cat")
    T_RISKS+=("$risk")
    T_METHODS+=("rm")
    FOUND_TOTAL=$((FOUND_TOTAL + total_kb))
    log "  │  ${C_SUCCESS}✓${C_RESET}  %-44s ${C_BOLD}%10s${C_RESET}\n" "$agg_name" "$(fmt "$total_kb")"
    if [[ -n "$active_ver" ]]; then
      log "  │     ${C_DIM}🛡️ active: v%s (protected)${C_RESET}\n" "$active_ver"
    fi
  fi
}

scan_dir_items() {
  local dir="$1" prefix="$2" cat="$3" risk="$4" method="${5:-rm}"
  [[ -d "$dir" ]] || return 0
  matches_profile "$cat" || return 0

  for subdir in "$dir"/*/; do
    [[ -d "$subdir" ]] || continue
    local sname
    sname=$(basename "$subdir")
    is_excluded "$subdir" && continue

    local kb
    kb=$(get_kb "$subdir")
    if (( kb > MIN_SIZE_KB )); then
      _flush_cat_header
      T_NAMES+=("$prefix$sname")
      T_PATHS+=("$subdir")
      T_SIZES+=("$kb")
      T_CATS+=("$cat")
      T_RISKS+=("$risk")
      T_METHODS+=("$method")
      FOUND_TOTAL=$((FOUND_TOTAL + kb))
      log "  │  ${C_SUCCESS}✓${C_RESET}  %-44s ${C_BOLD}%10s${C_RESET}\n" "$prefix$sname" "$(fmt "$kb")"
    fi
  done
}

# ── History ──────────────────────────────────────────────────────────────────

HISTORY_DIR="$HOME/.diskdoc"
HISTORY_FILE="$HISTORY_DIR/history.log"

show_history() {
  if [[ ! -f "$HISTORY_FILE" ]]; then
    echo ""
    echo "  No cleanup history found."
    echo "  Run 'diskdoc' to start cleaning."
    echo ""
    exit 0
  fi

  echo ""
  printf "  ${BOLD}${CYAN}diskdoc — Cleanup History${NC}\n"
  printf "  ${DIM}────────────────────────────────────────────────────────────────────${NC}\n"
  printf "  ${DIM}%-20s  %14s  %8s  %8s  %6s${NC}\n" "Date" "Recovered" "Items" "Failed" "Time"
  printf "  ${DIM}────────────────────────────────────────────────────────────────────${NC}\n"

  local total_kb=0
  local total_items=0
  while IFS='|' read -r date recovered_kb items failed elapsed; do
    date="${date#"${date%%[![:space:]]*}"}"
    recovered_kb="${recovered_kb#"${recovered_kb%%[![:space:]]*}"}"
    items="${items#"${items%%[![:space:]]*}"}"
    failed="${failed#"${failed%%[![:space:]]*}"}"
    elapsed="${elapsed#"${elapsed%%[![:space:]]*}"}"
    printf "  %-20s  ${GREEN}%14s${NC}  %8s  %8s  %6s\n" \
      "$date" "$(fmt "$recovered_kb")" "$items" "$failed" "${elapsed}s"
    total_kb=$((total_kb + recovered_kb))
    total_items=$((total_items + items))
  done < "$HISTORY_FILE"

  printf "  ${DIM}────────────────────────────────────────────────────────────────────${NC}\n"
  printf "  ${BOLD}Total recovered: ${GREEN}%s${NC} ${BOLD}across %d items${NC}\n" "$(fmt "$total_kb")" "$total_items"
  echo ""
  exit 0
}

save_history() {
  local recovered_kb="$1" items="$2" failed="$3" elapsed="$4"
  mkdir -p "$HISTORY_DIR"
  printf "%s | %s | %s | %s | %s\n" \
    "$(date '+%Y-%m-%d %H:%M:%S')" "$recovered_kb" "$items" "$failed" "$elapsed" \
    >> "$HISTORY_FILE"
}

# ── Doctor mode ──────────────────────────────────────────────────────────────

run_doctor() {
  echo ""
  printf "  "; draw_box "diskdoc doctor — Disk Diagnosis" "$C_INFO" 60
  echo ""

  local disk_line
  disk_line=$(df -k / | tail -1)
  local total avail used pct_free
  total=$(echo "$disk_line" | awk '{print $2}')
  avail=$(echo "$disk_line" | awk '{print $4}')
  used=$((total - avail))
  pct_free=$((avail * 100 / total))

  printf "  ${DIM}Disk:${NC}  %s total  |  %s free (%d%%)  |  %s used\n" \
    "$(fmt "$total")" "$(fmt "$avail")" "$pct_free" "$(fmt "$used")"
  echo ""

  if (( pct_free < 5 )); then
    printf "  ${RED}${BOLD}⚠  CRITICAL: Less than 5%% free space!${NC}\n\n"
  elif (( pct_free < 15 )); then
    printf "  ${YELLOW}${BOLD}⚠  WARNING: Less than 15%% free space${NC}\n\n"
  else
    printf "  ${GREEN}✓  Disk health looks good${NC}\n\n"
  fi

  printf "  ${BOLD}Top space consumers in ~/Library:${NC}\n"
  printf "  ${DIM}──────────────────────────────────────────────────────────${NC}\n"

  local idx=1
  while IFS=$'\t' read -r kb path; do
    local name="${path#"$HOME"/Library/}"
    name="${name%/}"
    name=$(truncate_middle "$name" 44)
    local color=""
    if (( kb >= 10485760 )); then color="$RED"
    elif (( kb >= 1048576 )); then color="$YELLOW"
    fi
    printf "  ${DIM}%2d.${NC} ${color}%-44s %10s${NC}\n" "$idx" "$name" "$(fmt "$kb")"
    ((idx++))
  done < <(du -sk "$HOME/Library/"*/ 2>/dev/null | sort -nr | head -15)

  echo ""
  printf "  ${BOLD}Top space consumers in ~/:${NC}\n"
  printf "  ${DIM}──────────────────────────────────────────────────────────${NC}\n"

  idx=1
  while IFS=$'\t' read -r kb path; do
    local name="${path#"$HOME"/}"
    name="${name%/}"
    name=$(truncate_middle "$name" 44)
    local color=""
    if (( kb >= 10485760 )); then color="$RED"
    elif (( kb >= 1048576 )); then color="$YELLOW"
    fi
    printf "  ${DIM}%2d.${NC} ${color}%-44s %10s${NC}\n" "$idx" "$name" "$(fmt "$kb")"
    ((idx++))
  done < <(du -sk "$HOME/"*/ 2>/dev/null | sort -nr | head -10)

  # Time Machine snapshots
  local snap_count
  snap_count=$(tmutil listlocalsnapshots / 2>/dev/null | grep -c "com.apple.TimeMachine" || true)
  if (( snap_count > 0 )); then
    echo ""
    printf "  ${YELLOW}${BOLD}⏰ Time Machine:${NC} %d local snapshots found\n" "$snap_count"
    printf "  ${DIM}   Free space with: sudo tmutil thinlocalsnapshots / 99999999999${NC}\n"
  fi

  echo ""
  printf "  ${DIM}Run 'diskdoc' for interactive cleanup.${NC}\n"
  printf "  ${DIM}Run 'diskdoc --scan' to see what can be safely deleted.${NC}\n"
  echo ""
  exit 0
}

# ── Dispatch subcommands ─────────────────────────────────────────────────────

[[ "$SHOW_HISTORY" == true ]] && show_history
[[ "$DOCTOR_MODE" == true ]] && run_doctor

# ── TUI: Terminal setup/cleanup ──────────────────────────────────────────────

TERM_LINES=24
TERM_COLS=80
TUI_ACTIVE=false

detect_term_size() {
  local size
  size=$(stty size 2>/dev/null) || return
  TERM_LINES="${size%% *}"
  TERM_COLS="${size##* }"
}

setup_tui() {
  TUI_ACTIVE=true
  detect_term_size
  stty -echo -icanon 2>/dev/null
  printf '\033[?25l'          # hide cursor
  printf '\033[?1049h'        # alternate screen buffer
  trap cleanup_tui EXIT INT TERM HUP
  trap 'detect_term_size' WINCH
}

cleanup_tui() {
  [[ "$TUI_ACTIVE" != true ]] && return
  TUI_ACTIVE=false
  printf '\033[?25h'          # show cursor
  printf '\033[?1049l'        # restore main screen buffer
  stty sane 2>/dev/null
}

# ── TUI: Emoji detection ────────────────────────────────────────────────────

HAS_EMOJI=false
if [[ "${LANG:-}" == *UTF-8* || "${LC_ALL:-}" == *UTF-8* || "${LC_CTYPE:-}" == *UTF-8* ]]; then
  HAS_EMOJI=true
fi

risk_icon() {
  if [[ "$HAS_EMOJI" == true ]]; then
    case "$1" in
      SAFE)        printf '🟢' ;;
      REBUILD)     printf '🟡' ;;
      PERSONAL)    printf '🔴' ;;
      UNTOUCHABLE) printf '🔒' ;;
      *)           printf ' ' ;;
    esac
  else
    case "$1" in
      SAFE)        printf "${C_SUCCESS}●${C_RESET}" ;;
      REBUILD)     printf "${C_WARNING}●${C_RESET}" ;;
      PERSONAL)    printf "${C_DANGER}●${C_RESET}" ;;
      UNTOUCHABLE) printf "${C_ACCENT}■${C_RESET}" ;;
      *)           printf ' ' ;;
    esac
  fi
}

# ── TUI: Braille spinner ─────────────────────────────────────────────────────

SPINNER_FRAMES=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
SPINNER_PID=0

# spinner_start "Scanning category..."
# Runs in background, updates inline. Call spinner_stop to clear.
spinner_start() {
  local msg="$1"
  [[ "$JSON_MODE" == true ]] && return
  (
    local i=0
    while true; do
      printf '\r\033[K  %s %s' "${SPINNER_FRAMES[$((i % 10))]}" "$msg" >&2
      ((i++))
      sleep 0.08
    done
  ) &
  SPINNER_PID=$!
  disown "$SPINNER_PID" 2>/dev/null
}

spinner_stop() {
  if (( SPINNER_PID > 0 )); then
    kill "$SPINNER_PID" 2>/dev/null
    wait "$SPINNER_PID" 2>/dev/null || true
    SPINNER_PID=0
    printf '\r\033[K' >&2
  fi
}

# ── TUI: Inline proportional bars ────────────────────────────────────────────

# draw_bar value max_value width
# Renders: ██████░░░░ proportional to value/max_value
draw_bar() {
  local value=$1 max_val=$2 width=${3:-10}
  local filled=0
  if (( max_val > 0 )); then
    filled=$(( (value * width * 8) / max_val ))
  fi
  local full_blocks=$(( filled / 8 ))
  local remainder=$(( filled % 8 ))
  local empty=$(( width - full_blocks - (remainder > 0 ? 1 : 0) ))

  local eighth=('█' '▏' '▎' '▍' '▌' '▋' '▊' '▉')
  local bar=""
  for ((i=0; i<full_blocks; i++)); do bar+="█"; done
  if (( remainder > 0 )); then
    bar+="${eighth[$remainder]}"
  fi
  for ((i=0; i<empty; i++)); do bar+="░"; done
  printf '%s' "$bar"
}

# ── TUI: Generic box drawing ────────────────────────────────────────────────

# draw_box title color width lines...
# Usage: draw_box "My Title" "$C_INFO" 60 "line 1" "line 2" "line 3"
draw_box() {
  local title="$1" color="$2" width="$3"
  shift 3

  local inner=$((width - 2))
  local title_len=${#title}
  local pad=$((inner - title_len - 2))
  (( pad < 0 )) && pad=0

  local hline=""
  for ((i=0; i<pad; i++)); do hline+="─"; done

  printf "\r\033[K${color}╭─ %s ${C_RESET}${C_DIM}%s${C_RESET}${color}╮${C_RESET}\n" "$title" "$hline"

  for line in "$@"; do
    local line_len=${#line}
    local rpad=$((inner - line_len))
    (( rpad < 0 )) && rpad=0
    local spaces=""
    for ((i=0; i<rpad; i++)); do spaces+=" "; done
    printf "\r\033[K${color}│${C_RESET} %s%s${color}│${C_RESET}\n" "$line" "$spaces"
  done

  local bline=""
  for ((i=0; i<inner; i++)); do bline+="─"; done
  printf "\r\033[K${color}╰%s╯${C_RESET}\n" "$bline"
}

# ── TUI: Status bar + detail panel ───────────────────────────────────────────

# Renders detail panel for highlighted item
render_detail_panel() {
  local idx=$1
  local name="${T_NAMES[$idx]}"
  local path="${T_PATHS[$idx]}"
  local tag="${T_RISKS[$idx]}"
  local cat="${T_CATS[$idx]}"
  local kb="${T_SIZES[$idx]}"
  local rc
  rc=$(risk_color "$tag")

  local size_str
  size_str=$(fmt "$kb")

  # Last modified
  local mtime="unknown"
  if [[ -e "$path" ]]; then
    mtime=$(stat -f "%Sm" -t "%Y-%m-%d" "$path" 2>/dev/null || echo "unknown")
  fi

  local desc=""
  case "$tag" in
    SAFE)     desc="Regenerates without effort" ;;
    REBUILD)  desc="Costly to reconstruct from backup" ;;
    PERSONAL) desc="User data — shown for awareness only" ;;
  esac

  draw_box "$name" "$rc" "$((TERM_COLS > 70 ? 66 : TERM_COLS - 4))" \
    "Risk: $(risk_icon "$tag") $tag — $desc" \
    "Path: $path" \
    "Size: $size_str" \
    "Category: $cat" \
    "Last modified: $mtime"
}

# ── Interactive selector ─────────────────────────────────────────────────────

interactive_select() {
  local num=${#SORTED[@]}

  # Select all by default
  for ((i=0; i<num; i++)); do SELECTED[$i]=1; done

  _interactive_select_flat "$num"
}

# ── Flat selector (bash 3.2 compatible — no collapse/expand) ────────────────

_interactive_select_flat() {
  local num=$1 cursor=0 scroll=0

  # Find max size for bars
  local max_kb=0
  for ((si=0; si<num; si++)); do
    local ri="${SORTED[$si]#*|}"
    (( T_SIZES[$ri] > max_kb )) && max_kb=${T_SIZES[$ri]}
  done

  detect_term_size
  # Reserve lines for header(1) + status(3) + detail(8) + padding(2) = 14
  local page_size=$(( TERM_LINES > 14 ? TERM_LINES - 14 : 20 ))
  (( page_size < 5 )) && page_size=5
  (( page_size > num )) && page_size=$num

  tput civis 2>/dev/null
  stty -echo -icanon 2>/dev/null
  trap 'tput cnorm 2>/dev/null; stty sane 2>/dev/null' EXIT INT TERM

  _draw_flat() {
    [[ "${1:-}" == "redraw" ]] && printf '\033[%dA' "$_last_draw_lines"

    local sel_kb=0 sel_count=0
    for ((i=0; i<num; i++)); do
      if [[ "${SELECTED[$i]}" == "1" ]]; then
        local ri="${SORTED[$i]#*|}"
        sel_kb=$((sel_kb + T_SIZES[$ri]))
        ((sel_count++)) || true
      fi
    done

    # Adjust scroll window to keep cursor visible
    (( cursor < scroll )) && scroll=$cursor
    (( cursor >= scroll + page_size )) && scroll=$(( cursor - page_size + 1 ))

    local drawn=0
    local end=$(( scroll + page_size ))
    (( end > num )) && end=$num

    # Scroll indicator top
    if (( scroll > 0 )); then
      printf "  ${C_DIM}  ▲ %d more above${C_RESET}\033[K\n" "$scroll"
    else
      printf "\033[K\n"
    fi
    ((drawn++))

    for ((si=scroll; si<end; si++)); do
      local ri="${SORTED[$si]#*|}"
      local name
      name=$(truncate_middle "${T_NAMES[$ri]}" "$UI_NAME_WIDTH")
      local sf
      if [[ "${T_METHODS[$ri]}" == "tm-thin" ]]; then
        sf="${TM_SNAP_COUNT} snaps"
      else
        sf=$(fmt "${T_SIZES[$ri]}")
      fi
      local tag="${T_RISKS[$ri]}"
      local rc
      rc=$(risk_color "$tag")
      local icon
      icon=$(risk_icon "$tag")
      local bar
      bar=$(draw_bar "${T_SIZES[$ri]}" "$max_kb" "$UI_BAR_WIDTH")

      local check="[ ]"
      [[ "${SELECTED[$si]}" == "1" ]] && check="[x]"

      if (( si == cursor )); then
        printf "  ${C_BOLD}${C_INFO}> ${check}${C_RESET} %-${UI_NAME_WIDTH}s %10s %s %s ${rc}${C_BOLD}%-8s${C_RESET}\033[K\n" \
          "$name" "$sf" "$bar" "$icon" "$tag"
      else
        printf "    ${check} %-${UI_NAME_WIDTH}s %10s %s %s ${rc}%-8s${C_RESET}\033[K\n" \
          "$name" "$sf" "$bar" "$icon" "$tag"
      fi
      ((drawn++))
    done

    # Scroll indicator bottom
    local remaining=$(( num - end ))
    if (( remaining > 0 )); then
      printf "  ${C_DIM}  ▼ %d more below${C_RESET}\033[K\n" "$remaining"
    else
      printf "\033[K\n"
    fi
    ((drawn++))

    printf "\033[K\n"
    printf "  ${C_BOLD}Selected: %d/%d items — %s${C_RESET}\033[K\n" "$sel_count" "$num" "$(fmt $sel_kb)"
    printf "  ${C_DIM}↑↓ move  ␣ toggle  A all  N none  ⏎ confirm  q quit${C_RESET}\033[K\n"
    drawn=$((drawn + 3))

    # Detail panel
    local ri="${SORTED[$cursor]#*|}"
    printf "\033[K\n"
    printf "  "; render_detail_panel "$ri"
    drawn=$((drawn + 8))

    _last_draw_lines=$drawn
  }

  local _last_draw_lines=0
  _draw_flat

  while true; do
    IFS= read -rsn1 key
    case "$key" in
      $'\x1b')
        read -rsn2 seq
        case "$seq" in
          '[A') (( cursor > 0 )) && ((cursor--)) ;;
          '[B') (( cursor < num - 1 )) && ((cursor++)) ;;
        esac
        ;;
      ' ')
        if [[ "${SELECTED[$cursor]}" == "1" ]]; then
          SELECTED[$cursor]=0
        else
          SELECTED[$cursor]=1
        fi
        ;;
      'a'|'A') for ((i=0; i<num; i++)); do SELECTED[$i]=1; done ;;
      'n'|'N') for ((i=0; i<num; i++)); do SELECTED[$i]=0; done ;;
      ''|$'\n') break ;;
      'q'|'Q')
        tput cnorm 2>/dev/null
        stty sane 2>/dev/null
        echo ""
        printf "  ${C_DIM}Cancelled. Nothing was deleted.${C_RESET}\n"
        exit 0
        ;;
    esac
    _draw_flat "redraw"
  done

  tput cnorm 2>/dev/null
  stty sane 2>/dev/null
}

