# ════════════════════════════════════════════════════════════════════════════
# PHASE: Dynamic caches (~/Library/Caches/* > threshold)
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "Cache"; then
  cat_header "Caches" "$GREEN"
  cache_start=${#T_NAMES[@]}

  if [[ -d "$HOME/Library/Caches" ]]; then
    log "  │  ${DIM}Scanning ~/Library/Caches for entries > %d MB...${NC}\n" "$MIN_SIZE_MB"

    while IFS=$'\t' read -r size path; do
      base=$(basename "$path")
      name="Cache: $base"

      # Skip items covered by dedicated scanners (Package Managers phase runs later)
      already=false
      case "$base" in
        Homebrew|CocoaPods|Yarn|pip|go-build) already=true ;;
      esac
      if ! $already; then
        for existing in "${T_PATHS[@]+"${T_PATHS[@]}"}"; do
          [[ "$existing" == "$path" ]] && already=true && break
        done
      fi
      $already && continue

      is_excluded "$path" && continue
      matches_profile "Cache" || continue

      kb=$(echo "$size" | tr -d '[:space:]')
      if (( kb > MIN_SIZE_KB )); then
        _flush_cat_header
        T_NAMES+=("$name")
        T_PATHS+=("$path")
        T_SIZES+=("$kb")
        T_CATS+=("Cache")
        T_RISKS+=("SAFE")
        T_METHODS+=("rm")
        FOUND_TOTAL=$((FOUND_TOTAL + kb))
        log "  │  ${GREEN}✓${NC}  %-44s ${BOLD}%10s${NC}\n" "$name" "$(fmt "$kb")"
      fi
    done < <(du -sk "$HOME/Library/Caches/"* 2>/dev/null | sort -nr)
  fi

  cache_count=0; cache_kb=0
  for ((i=cache_start; i<${#T_CATS[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "Cache" ]] && ((++cache_count)) && cache_kb=$((cache_kb + T_SIZES[$i]))
  done
  cat_footer "$cache_count" "$cache_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE 5: Package Managers
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "Pkg Manager"; then
  cat_header "Package Managers" "$BLUE"
  pkg_start=${#T_NAMES[@]}

  scan_target "npm Cache"       "$HOME/.npm"                       "Pkg Manager" "SAFE" "npm-cache"
  has_cmd pnpm  && scan_target "pnpm Store"     "$HOME/Library/pnpm/store"     "Pkg Manager" "SAFE" "pnpm-prune"
  has_cmd yarn  && scan_target "Yarn Cache"     "$HOME/Library/Caches/Yarn"    "Pkg Manager" "SAFE" "rm"
  has_cmd pip3  && scan_target "pip Cache"      "$HOME/Library/Caches/pip"     "Pkg Manager" "SAFE" "rm"
  has_cmd brew  && scan_target "Homebrew Cache" "$HOME/Library/Caches/Homebrew" "Pkg Manager" "SAFE" "brew-cleanup"

  pkg_count=0; pkg_kb=0
  for ((i=pkg_start; i<${#T_CATS[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "Pkg Manager" ]] && ((++pkg_count)) && pkg_kb=$((pkg_kb + T_SIZES[$i]))
  done
  cat_footer "$pkg_count" "$pkg_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# PHASE: Ghost Apps (uninstalled apps with leftover data)
# ════════════════════════════════════════════════════════════════════════════

if matches_profile "App" || [[ "$PROFILE" == "all" ]]; then
  cat_header "Ghost Apps" "$RED"
  ghost_start=${#T_NAMES[@]}

  logp "\r\033[K  ${DIM}⠹ Building installed apps index...${NC}"

  # Single-pass: collect all installed bundle IDs once (O(1) lookups after)
  _INSTALLED_BIDS=""
  for app_dir in /Applications ~/Applications /System/Applications; do
    [[ -d "$app_dir" ]] || continue
    while IFS= read -r plist; do
      local pbid
      pbid=$(/usr/libexec/PlistBuddy -c "Print :CFBundleIdentifier" "$plist" 2>/dev/null || true)
      [[ -n "$pbid" ]] && _INSTALLED_BIDS+=$'\n'"$pbid"
    done < <(find "$app_dir" -name "Info.plist" -maxdepth 4 2>/dev/null)
  done
  # Add Spotlight results in one batch
  while IFS= read -r sbid; do
    [[ -n "$sbid" ]] && _INSTALLED_BIDS+=$'\n'"$sbid"
  done < <(mdfind "kMDItemContentType == 'com.apple.application-bundle'" 2>/dev/null \
    | while IFS= read -r app; do
        /usr/libexec/PlistBuddy -c "Print :CFBundleIdentifier" "$app/Contents/Info.plist" 2>/dev/null
      done)
  logp "\r\033[K"

  is_app_installed() {
    local bid="$1"
    printf '%s' "$_INSTALLED_BIDS" | grep -qxF "$bid"
  }

  # Check ~/Library/Containers/*
  for cdir in "$HOME/Library/Containers/"*/; do
    [[ -d "$cdir" ]] || continue
    bid=$(basename "$cdir")
    # Skip system containers and known non-app IDs
    [[ "$bid" == com.apple.* ]] && continue
    is_excluded "$cdir" && continue

    if ! is_app_installed "$bid"; then
      kb=$(get_kb "$cdir")
      if (( kb > MIN_SIZE_KB )); then
        _flush_cat_header
        short="$bid"
        short=$(truncate_middle "$short" 36)
        T_NAMES+=("Ghost: $short")
        T_PATHS+=("$cdir")
        T_SIZES+=("$kb")
        T_CATS+=("App")
        T_RISKS+=("SAFE")
        T_METHODS+=("rm")
        FOUND_TOTAL=$((FOUND_TOTAL + kb))
        log "  │  ${RED}👻${NC} %-44s ${BOLD}%10s${NC}\n" "Ghost: $short" "$(fmt "$kb")"
      fi
    fi
  done

  # Check ~/Library/Application Support/*
  for asdir in "$HOME/Library/Application Support/"*/; do
    [[ -d "$asdir" ]] || continue
    bid=$(basename "$asdir")
    # Skip non-bundle-id names and known dirs
    [[ "$bid" == *"."* ]] || continue
    [[ "$bid" == com.apple.* ]] && continue
    is_excluded "$asdir" && continue

    # Skip if already scanned (Claude, ChatGPT, etc)
    already=false
    for existing in "${T_PATHS[@]+"${T_PATHS[@]}"}"; do
      [[ "$asdir" == "$existing" || "$existing" == "$asdir"* ]] && already=true && break
    done
    $already && continue

    if ! is_app_installed "$bid"; then
      kb=$(get_kb "$asdir")
      if (( kb > MIN_SIZE_KB )); then
        _flush_cat_header
        short="$bid"
        short=$(truncate_middle "$short" 36)
        T_NAMES+=("Ghost: $short")
        T_PATHS+=("$asdir")
        T_SIZES+=("$kb")
        T_CATS+=("App")
        T_RISKS+=("SAFE")
        T_METHODS+=("rm")
        FOUND_TOTAL=$((FOUND_TOTAL + kb))
        log "  │  ${RED}👻${NC} %-44s ${BOLD}%10s${NC}\n" "Ghost: $short" "$(fmt "$kb")"
      fi
    fi
  done

  ghost_count=0; ghost_kb=0
  for ((i=ghost_start; i<${#T_NAMES[@]}; i++)); do
    [[ "${T_NAMES[$i]}" == "Ghost:"* ]] && ((++ghost_count)) && ghost_kb=$((ghost_kb + T_SIZES[$i]))
  done
  cat_footer "$ghost_count" "$ghost_kb"
fi

# ════════════════════════════════════════════════════════════════════════════
# ★ TIER 1: Massive impact categories (20-500+ GB)
# ════════════════════════════════════════════════════════════════════════════

# ── A1-A3: Virtualization — Parallels, VMware, UTM ─────────────────────────

if matches_profile "App" || [[ "$PROFILE" == "all" ]]; then
  cat_header "Virtualization" "$YELLOW"
  vm_start=${#T_NAMES[@]}

  # A1: Parallels Desktop
  scan_vm_bundle "$HOME/Parallels" ".pvm" "Virtualization" "REBUILD"
  scan_vm_bundle "$HOME/Parallels" ".macvm" "Virtualization" "REBUILD"
  scan_vm_bundle "$HOME/Documents/Parallels" ".pvm" "Virtualization" "REBUILD"
  scan_vm_bundle "$HOME/Documents/Parallels" ".macvm" "Virtualization" "REBUILD"
  scan_vm_bundle "/Users/Shared/Parallels" ".pvm" "Virtualization" "REBUILD"
  scan_vm_bundle "/Users/Shared/Parallels" ".macvm" "Virtualization" "REBUILD"
  # App Store sandboxed Parallels
  local _prl_appstore="$HOME/Library/Group Containers/4C6364ACXT.com.parallels.desktop.appstore/Shared/Parallels"
  scan_vm_bundle "$_prl_appstore" ".pvm" "Virtualization" "REBUILD"
  scan_vm_bundle "$_prl_appstore" ".macvm" "Virtualization" "REBUILD"
  scan_target "Parallels Prefs" "$HOME/Library/Preferences/Parallels" "Virtualization" "SAFE" "rm"
  scan_target "Parallels Support" "$HOME/Library/Application Support/Parallels" "Virtualization" "SAFE" "rm"

  # A2: VMware Fusion
  scan_vm_bundle "$HOME/Virtual Machines" ".vmwarevm" "Virtualization" "REBUILD"
  scan_vm_bundle "$HOME/Documents/Virtual Machines" ".vmwarevm" "Virtualization" "REBUILD"
  scan_target "VMware Fusion Support" "$HOME/Library/Application Support/VMware Fusion" "Virtualization" "SAFE" "rm"

  # A3: UTM
  local _utm_sandboxed="$HOME/Library/Containers/com.utmapp.UTM/Data/Documents"
  scan_vm_bundle "$_utm_sandboxed" ".utm" "Virtualization" "REBUILD"
  # Non-sandboxed UTM stores .utm in ~/Documents
  if [[ -d "$HOME/Documents" ]]; then
    while IFS= read -r utm_bundle; do
      [[ -d "$utm_bundle" ]] || continue
      local bname
      bname=$(basename "$utm_bundle" ".utm")
      is_excluded "$utm_bundle" && continue
      local kb
      kb=$(get_kb "$utm_bundle")
      if (( kb > MIN_SIZE_KB )); then
        _flush_cat_header
        T_NAMES+=("UTM: $bname")
        T_PATHS+=("$utm_bundle")
        T_SIZES+=("$kb")
        T_CATS+=("Virtualization")
        T_RISKS+=("REBUILD")
        T_METHODS+=("rm")
        FOUND_TOTAL=$((FOUND_TOTAL + kb))
        log "  │  ${C_SUCCESS}✓${C_RESET}  %-44s ${C_BOLD}%10s${C_RESET}\n" "UTM: $bname" "$(fmt "$kb")"
      fi
    done < <(find "$HOME/Documents" -maxdepth 1 -name "*.utm" -type d 2>/dev/null)
  fi

  # A4: Lima — each ~/.lima/<instance>/disk is a VM
  # Skip colima subdir here — scanned separately below to avoid double-count
  if [[ -d "$HOME/.lima" ]]; then
    for _lima_sub in "$HOME/.lima"/*/; do
      [[ -d "$_lima_sub" ]] || continue
      local _lima_name
      _lima_name=$(basename "$_lima_sub")
      [[ "$_lima_name" == "colima"* ]] && continue
      is_excluded "$_lima_sub" && continue
      local _lima_kb
      _lima_kb=$(get_kb "$_lima_sub")
      if (( _lima_kb > MIN_SIZE_KB )); then
        _flush_cat_header
        T_NAMES+=("Lima: $_lima_name")
        T_PATHS+=("$_lima_sub")
        T_SIZES+=("$_lima_kb")
        T_CATS+=("Virtualization")
        T_RISKS+=("REBUILD")
        T_METHODS+=("rm")
        FOUND_TOTAL=$((FOUND_TOTAL + _lima_kb))
        log "  │  ${C_SUCCESS}✓${C_RESET}  %-44s ${C_BOLD}%10s${C_RESET}\n" "Lima: $_lima_name" "$(fmt "$_lima_kb")"
      fi
    done
  fi

  # A4: Colima (v0.6+ uses ~/.colima, pre-v0.6 uses ~/.lima/colima)
  scan_dir_items "$HOME/.colima" "Colima: " "Virtualization" "REBUILD"
  scan_target "Colima (legacy)" "$HOME/.lima/colima" "Virtualization" "REBUILD" "rm"

  # A4: OrbStack �� sparse file, use du not ls
  local _orbstack_data="$HOME/Library/Group Containers/HUAQ24HBR6.dev.orbstack/data"
  if [[ -d "$_orbstack_data" ]]; then
    logp "\r\033[K  ${C_DIM}⠹ Scanning OrbStack data${C_RESET}"
    local orb_kb
    orb_kb=$(du -sk "$_orbstack_data" 2>/dev/null | awk '{print $1}')
    orb_kb=${orb_kb:-0}
    if (( orb_kb > MIN_SIZE_KB )); then
      _flush_cat_header
      T_NAMES+=("OrbStack data (sparse)")
      T_PATHS+=("$_orbstack_data")
      T_SIZES+=("$orb_kb")
      T_CATS+=("Virtualization")
      T_RISKS+=("REBUILD")
      T_METHODS+=("rm")
      FOUND_TOTAL=$((FOUND_TOTAL + orb_kb))
      log "\r\033[K  │  ${C_SUCCESS}✓${C_RESET}  %-44s ${C_BOLD}%10s${C_RESET}\n" "OrbStack data (sparse)" "$(fmt "$orb_kb")"
    else
      logp "\r\033[K"
    fi
  fi

  # A4: Tart
  scan_dir_items "$HOME/.tart/vms" "Tart VM: " "Virtualization" "REBUILD"
  scan_target "Tart OCI Cache" "$HOME/.tart/cache/OCIs" "Virtualization" "SAFE" "rm"
  scan_target "Tart IPSW Cache" "$HOME/.tart/cache/IPSWs" "Virtualization" "SAFE" "rm"

  # A4: Vagrant
  scan_dir_items "$HOME/.vagrant.d/boxes" "Vagrant box: " "Virtualization" "REBUILD"
  scan_target "Vagrant tmp" "$HOME/.vagrant.d/tmp" "Virtualization" "SAFE" "rm"

  # A4: VirtualBox
  scan_vm_bundle "$HOME/VirtualBox VMs" "" "Virtualization" "REBUILD"

  # A4: Multipass (requires sudo)
  local _multipass="/var/root/Library/Application Support/multipassd"
  if sudo test -d "$_multipass" 2>/dev/null; then
    scan_target "Multipass VMs" "$_multipass" "Virtualization" "REBUILD" "rm-sudo"
  fi

  vm_count=0; vm_kb=0
  for ((i=vm_start; i<${#T_CATS[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "Virtualization" ]] && ((++vm_count)) && vm_kb=$((vm_kb + T_SIZES[$i]))
  done
  cat_footer "$vm_count" "$vm_kb"
fi

# ── A5: Docker.raw — the single giant file ─────────────────────────────────

if matches_profile "App" || [[ "$PROFILE" == "all" ]]; then
  cat_header "Docker" "$YELLOW"
  local docker_count=0 docker_kb=0
  local _docker_raw="$HOME/Library/Containers/com.docker.docker/Data/vms/0/data/Docker.raw"
  if [[ -f "$_docker_raw" ]]; then
    logp "\r\033[K  ${C_DIM}⠹ Scanning Docker.raw${C_RESET}"
    # CRITICAL: use du for sparse file, never ls
    local docker_raw_kb
    docker_raw_kb=$(du -sk "$_docker_raw" 2>/dev/null | awk '{print $1}')
    docker_raw_kb=${docker_raw_kb:-0}
    if (( docker_raw_kb > MIN_SIZE_KB )); then
      _flush_cat_header
      T_NAMES+=("Docker.raw (all images/volumes)")
      T_PATHS+=("__docker_prune__")
      T_SIZES+=("$docker_raw_kb")
      T_CATS+=("Virtualization")
      T_RISKS+=("SAFE")
      T_METHODS+=("docker-prune")
      FOUND_TOTAL=$((FOUND_TOTAL + docker_raw_kb))
      docker_count=1; docker_kb=$docker_raw_kb
      log "\r\033[K  │  ${C_SUCCESS}✓${C_RESET}  %-44s ${C_BOLD}%10s${C_RESET}\n" "Docker.raw (all images/volumes)" "$(fmt "$docker_raw_kb")"
    else
      logp "\r\033[K"
    fi
  fi
  cat_footer "$docker_count" "$docker_kb"
fi

