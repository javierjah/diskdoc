# ── A9: Mail — IMAP logs + versioned databases ────────────────────────────

if matches_profile "Personal" || matches_profile "System" || [[ "$PROFILE" == "all" ]]; then
  cat_header "Mail" "$YELLOW"
  mail_start=${#T_NAMES[@]}

  # IMAP/Exchange sync logs — can reach 200+ GB
  scan_target "Mail Sync Logs" "$HOME/Library/Containers/com.apple.mail/Data/Library/Logs/Mail" "Mail" "SAFE" "rm"
  # Mail Downloads (attachments opened)
  scan_target "Mail Downloads" "$HOME/Library/Containers/com.apple.mail/Data/Library/Mail Downloads" "Mail" "PERSONAL" "rm"

  # Versioned Mail databases — detect active vs obsolete
  local _mail_tcc_blocked=false
  for v in V6 V7 V8 V9 V10; do
    local mail_dir="$HOME/Library/Mail/$v"
    [[ -d "$mail_dir" ]] || continue
    local mail_label="Mail $v"
    local mail_risk="SAFE"
    if [[ "$v" == "$MACOS_MAIL_V" ]]; then
      mail_label="Mail $v (active — $MACOS_CODENAME)"
      mail_risk="PERSONAL"
    else
      mail_label="Mail $v (obsolete)"
    fi
    if ! scan_target "$mail_label" "$mail_dir" "Mail" "$mail_risk" "rm"; then
      # Path exists (passed -d check above) but du returned 0 — likely TCC
      local _mail_du_kb
      _mail_du_kb=$(du -sk "$mail_dir" 2>/dev/null | awk '{print $1}')
      _mail_du_kb=${_mail_du_kb:-0}
      if (( _mail_du_kb == 0 )); then
        _mail_tcc_blocked=true
      fi
    fi
  done

  if [[ "$_mail_tcc_blocked" == true ]]; then
    log "  │\n"
    log "  │  ${C_WARNING}⚠${C_RESET}  Mail folder exists but cannot be read (TCC protection).\n"
    log "  │     Grant Full Disk Access to Terminal in:\n"
    log "  │     ${C_DIM}System Settings → Privacy & Security → Full Disk Access${C_RESET}\n"
  fi

  mail_count=0; mail_kb=0
  for ((i=mail_start; i<${#T_CATS[@]}; i++)); do
    [[ "${T_CATS[$i]}" == "Mail" ]] && ((++mail_count)) && mail_kb=$((mail_kb + T_SIZES[$i]))
  done
  cat_footer "$mail_count" "$mail_kb"
fi

# ── A10: /private/var/folders/ — moved to Untouchable (SIP/TCC protected) ──
# These are daemon caches (TCC, Screen Time, cloudd, etc.) that macOS
# protects with SIP. Even sudo rm -rf returns "Operation not permitted".
# Apple cleans them automatically. Scanned as untouchable for transparency.

# ── A11: Spotlight index ──────────────────────────────────────────────────

if matches_profile "System" || [[ "$PROFILE" == "all" ]]; then
  cat_header "Spotlight" "$YELLOW"
  local spot_count=0 spot_total_kb=0
  local _spotlight_path
  if (( MACOS_MAJOR >= 11 )); then
    _spotlight_path="/System/Volumes/Data/.Spotlight-V100"
  else
    _spotlight_path="/.Spotlight-V100"
  fi
  if sudo test -d "$_spotlight_path" 2>/dev/null; then
    logp "\r\033[K  ${C_DIM}⠹ Scanning Spotlight Index${C_RESET}"
    local spot_kb
    spot_kb=$(sudo du -sk "$_spotlight_path" 2>/dev/null | awk '{print $1}')
    spot_kb=${spot_kb:-0}
    if (( spot_kb > MIN_SIZE_KB )); then
      _flush_cat_header
      T_NAMES+=("Spotlight Index")
      T_PATHS+=("__spotlight_rebuild__")
      T_SIZES+=("$spot_kb")
      T_CATS+=("System")
      T_RISKS+=("REBUILD")
      T_METHODS+=("spotlight-rebuild")
      FOUND_TOTAL=$((FOUND_TOTAL + spot_kb))
      spot_count=1; spot_total_kb=$spot_kb
      log "\r\033[K  │  ${C_SUCCESS}✓${C_RESET}  %-44s ${C_BOLD}%10s${C_RESET}\n" "Spotlight Index" "$(fmt "$spot_kb")"
    else
      logp "\r\033[K"
    fi
  fi
  cat_footer "$spot_count" "$spot_total_kb"
fi

